<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List page (theo picking outgoing của franchise) ============== -->
    <template id="portal_delivery_tracking" name="Wujia Portal — Delivery Tracking List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Theo dõi giao hàng</t>
            <!-- Desktop ≥992px — PC Giao hàng, batch-centric (Figma 4766:860). -->
            <div class="content-wrapper d-none d-lg-block wujia-dlv-pc">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'pc'"/>
                    <t t-set="ph_variant" t-value="'title'"/>
                    <t t-set="ph_title">Giao hàng</t>
                </t>

                <div t-if="no_franchise" class="wj-pc-empty">
                    <span class="wj-pc-empty__icon"><i class="feather icon-alert-circle"/></span>
                    <h3 class="wj-pc-empty__title">Chưa có cửa hàng</h3>
                    <p class="wj-pc-empty__sub">Bạn chưa được gán vào cửa hàng nào.</p>
                </div>

                <t t-else="">
                    <!-- Bộ lọc: search mã chuyến/SO + 2 date + trạng thái + Xóa lọc/Tìm -->
                    <form method="get" action="/portal/delivery" class="wj-pc-filterbar">
                        <div class="wj-pc-filterbar__row">
                            <span class="wj-pc-filter-search wj-pc-filterbar__grow">
                                <i class="feather icon-search"/>
                                <input type="text" name="q" t-att-value="q"
                                       placeholder="Tìm mã chuyến / mã SO" class="wj-pc-filter-control"/>
                            </span>
                            <input type="date" name="date_from" t-att-value="date_from"
                                   class="wj-pc-filter-control" style="max-width:180px;"/>
                            <input type="date" name="date_to" t-att-value="date_to"
                                   class="wj-pc-filter-control" style="max-width:180px;"/>
                            <select name="bs" class="wj-pc-filter-control" style="max-width:200px;">
                                <option value="">Tất cả trạng thái</option>
                                <option value="going" t-att-selected="'selected' if bs == 'going' else None">Đang giao</option>
                                <option value="soon" t-att-selected="'selected' if bs == 'soon' else None">Sắp giao</option>
                                <option value="done" t-att-selected="'selected' if bs == 'done' else None">Đã giao</option>
                            </select>
                            <span class="wj-pc-filterbar__actions">
                                <a href="/portal/delivery" class="wj-pc-btn wj-pc-btn--secondary">Xóa lọc</a>
                                <button type="submit" class="wj-pc-btn wj-pc-btn--primary"><i class="feather icon-search"/>Tìm</button>
                            </span>
                        </div>
                    </form>

                    <t t-set="_dq" t-value="(('&amp;date_from=%s' % date_from) if date_from else '') + (('&amp;date_to=%s' % date_to) if date_to else '') + (('&amp;q=%s' % q) if q else '')"/>
                    <div class="wj-pc-card">
                        <div class="wj-pc-card__head">
                            <div>
                                <h3 class="wj-pc-card__title">Danh sách chuyến giao</h3>
                                <p t-if="view_state == 'loading'" class="wj-pc-card__subtitle">Đang tải dữ liệu...</p>
                                <p t-elif="view_state == 'list'" class="wj-pc-card__subtitle">
                                    <t t-out="len(batches)"/> chuyến · Mới nhất trước
                                </p>
                                <p t-elif="view_state == 'empty'" class="wj-pc-card__subtitle">0 chuyến</p>
                            </div>
                            <!-- Chips số đếm (clickable filter, luôn hiện màu status) -->
                            <div t-if="view_state == 'list'" class="wj-pc-dlv-chips">
                                <a t-attf-href="/portal/delivery?bs=#{_dq}"
                                   t-attf-class="wj-pc-dlv-chip wj-pc-dlv-chip--going #{'is-active' if not bs else ''}">Tất cả <t t-out="chip_counts.get('all', 0)"/></a>
                                <a t-attf-href="/portal/delivery?bs=going#{_dq}"
                                   t-attf-class="wj-pc-dlv-chip wj-pc-dlv-chip--going #{'is-active' if bs == 'going' else ''}">Đang giao <t t-out="chip_counts.get('going', 0)"/></a>
                                <a t-attf-href="/portal/delivery?bs=soon#{_dq}"
                                   t-attf-class="wj-pc-dlv-chip wj-pc-dlv-chip--soon #{'is-active' if bs == 'soon' else ''}">Sắp giao <t t-out="chip_counts.get('soon', 0)"/></a>
                                <a t-attf-href="/portal/delivery?bs=done#{_dq}"
                                   t-attf-class="wj-pc-dlv-chip wj-pc-dlv-chip--done #{'is-active' if bs == 'done' else ''}">Đã giao <t t-out="chip_counts.get('done', 0)"/></a>
                            </div>
                        </div>

                        <!-- STATE: list -->
                        <t t-if="view_state == 'list'">
                            <table class="wj-pc-table wj-pc-dlv-table">
                                <thead>
                                    <tr>
                                        <th>Mã chuyến</th>
                                        <th>Giờ xuất phát</th>
                                        <th>Đơn liên quan</th>
                                        <th>Trạng thái</th>
                                        <th>Xe · tài xế</th>
                                        <th>Biển số</th>
                                        <th>Cập nhật</th>
                                        <th class="text-end">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="batches" t-as="b">
                                        <td class="wj-pc-td--code">
                                            <a t-attf-href="/portal/delivery/#{b['id']}" class="wj-pc-dlv-codelink" t-out="b['name']"/>
                                        </td>
                                        <td t-out="b['departure_full']"/>
                                        <td t-out="b['orders']"/>
                                        <td><span t-attf-class="wj-pc-badge wj-pc-badge--dlv-#{b['pc_modifier']}" t-out="b['pc_label']"/></td>
                                        <td t-out="b['vehicle']"/>
                                        <td t-out="b['plate']"/>
                                        <td class="wj-pc-td--muted" t-out="b['updated']"/>
                                        <td class="text-end">
                                            <a t-attf-href="/portal/delivery/#{b['id']}"
                                               class="wj-pc-btn wj-pc-btn--secondary wj-pc-dlv-btn-xem">Xem</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div t-if="m_pager and m_pager.get('page_total', 0)" class="wj-pc-pagination">
                                <span class="wj-pc-pagination__count">
                                    Hiển thị <t t-out="m_pager['offset'] + 1"/>–<t t-out="m_pager['offset'] + m_pager['count']"/>
                                    / <t t-out="m_pager['page_total']"/> chuyến
                                </span>
                                <select class="wj-pc-pagination__size" disabled="disabled"><option>10 / trang</option></select>
                                <a t-attf-href="/portal/delivery?page=#{m_pager['page_previous']['num']}&amp;#{m_pager['querystring'] or ''}"
                                   t-attf-class="wj-pc-page-btn #{'is-disabled' if m_pager['page']['num'] &lt;= 1 else ''}">‹</a>
                                <t t-foreach="m_pager['page_nums']" t-as="pn">
                                    <span t-if="pn == '…'" class="wj-pc-page-btn">…</span>
                                    <a t-else=""
                                       t-attf-href="/portal/delivery?page=#{pn}&amp;#{m_pager['querystring'] or ''}"
                                       t-attf-class="wj-pc-page-btn #{'is-active' if pn == m_pager['page']['num'] else ''}"
                                       t-out="pn"/>
                                </t>
                                <a t-attf-href="/portal/delivery?page=#{m_pager['page_next']['num']}&amp;#{m_pager['querystring'] or ''}"
                                   t-attf-class="wj-pc-page-btn #{'is-disabled' if m_pager['page']['num'] &gt;= m_pager['page_count'] else ''}">›</a>
                            </div>
                        </t>

                        <!-- STATE: loading (skeleton) -->
                        <div t-if="view_state == 'loading'" class="wj-pc-dlv-skel">
                            <t t-foreach="[0,1,2,3,4,5,6]" t-as="s">
                                <div t-attf-class="wj-pc-dlv-skel-row #{'wj-pc-dlv-skel-row--alt' if s_index % 2 else ''}">
                                    <span class="wj-pc-dlv-skel-bar" style="width:150px;"/>
                                    <span class="wj-pc-dlv-skel-bar" style="width:132px;"/>
                                    <span class="wj-pc-dlv-skel-bar" style="width:150px;"/>
                                    <span class="wj-pc-dlv-skel-bar" style="width:82px;"/>
                                    <span class="wj-pc-dlv-skel-bar" style="width:168px;"/>
                                    <span class="wj-pc-dlv-skel-bar" style="width:90px;"/>
                                    <span class="wj-pc-dlv-skel-bar" style="width:64px;"/>
                                </div>
                            </t>
                        </div>

                        <!-- STATE: empty -->
                        <div t-if="view_state == 'empty'" class="wj-pc-dlv-inner">
                            <span class="wj-pc-dlv-inner__icon"><i class="feather icon-truck"/></span>
                            <h3 class="wj-pc-dlv-inner__title">Không có chuyến giao</h3>
                            <p class="wj-pc-dlv-inner__sub">Không tìm thấy chuyến giao trong khoảng ngày đã chọn.</p>
                            <a href="/portal/delivery" class="wj-pc-btn wj-pc-btn--primary">Đổi bộ lọc</a>
                        </div>

                        <!-- STATE: error -->
                        <div t-if="view_state == 'error'" class="wj-pc-dlv-inner">
                            <span class="wj-pc-dlv-inner__icon wj-pc-dlv-inner__icon--error"><i class="feather icon-alert-circle"/></span>
                            <h3 class="wj-pc-dlv-inner__title">Không tải được dữ liệu giao hàng</h3>
                            <p class="wj-pc-dlv-inner__sub">Vui lòng thử tải lại hoặc kiểm tra kết nối.</p>
                            <a t-attf-href="/portal/delivery?#{m_pager.get('querystring','') if m_pager else ''}"
                               class="wj-pc-btn wj-pc-btn--primary"><i class="feather icon-refresh-cw"/>Tải lại</a>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Mobile <992px — Figma 4731:2 (delivery_mobile_mockup_v4), batch-centric (S24) -->
            <div class="d-lg-none wujia-mpage wujia-mdelivery">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'m'"/>
                    <t t-set="ph_variant" t-value="'title'"/>
                    <t t-set="ph_title">Giao hàng</t>
                </t>

                <div t-if="no_franchise" class="wj-empty-state wj-empty-state--card">
                    <i class="feather icon-alert-circle"/>
                    <p>Bạn chưa được gán vào cửa hàng nào.</p>
                </div>

                <t t-else="">
                    <!-- Filter canonical 03-Advanced (Figma 4785:753) — keyword wire vào q sẵn có -->
                    <form method="get" action="/portal/delivery" class="wj-filter-card">
                        <input t-if="bs" type="hidden" name="bs" t-att-value="bs"/>
                        <div class="wj-filter-search">
                            <div class="wj-filter-search-field">
                                <i class="feather icon-search"/>
                                <input type="text" name="q" t-att-value="q or ''" placeholder="Tìm mã chuyến / mã SO"/>
                            </div>
                            <button type="submit" class="wj-filter-search-btn"><i class="feather icon-search"/></button>
                        </div>
                        <div class="wj-filter-dates">
                            <label class="wj-filter-date">
                                <i class="feather icon-calendar"/>
                                <input type="date" name="date_from" t-att-value="date_from or ''"/>
                            </label>
                            <span class="wj-filter-date-sep">–</span>
                            <label class="wj-filter-date">
                                <i class="feather icon-calendar"/>
                                <input type="date" name="date_to" t-att-value="date_to or ''"/>
                            </label>
                        </div>
                        <!-- Status chips — bs nhóm (soon/going/done), giữ q + date filter -->
                        <t t-set="_dq" t-value="(('&amp;q=%s' % q) if q else '') + (('&amp;date_from=%s' % date_from) if date_from else '') + (('&amp;date_to=%s' % date_to) if date_to else '')"/>
                        <div class="wj-filter-chips">
                            <a t-attf-href="/portal/delivery?bs=#{_dq}"
                               t-attf-class="wj-filter-chip #{'is-active' if not bs else ''}">Tất cả</a>
                            <a t-attf-href="/portal/delivery?bs=soon#{_dq}"
                               t-attf-class="wj-filter-chip #{'is-active' if bs == 'soon' else ''}">Sắp giao</a>
                            <a t-attf-href="/portal/delivery?bs=going#{_dq}"
                               t-attf-class="wj-filter-chip #{'is-active' if bs == 'going' else ''}">Đang giao</a>
                            <a t-attf-href="/portal/delivery?bs=done#{_dq}"
                               t-attf-class="wj-filter-chip #{'is-active' if bs == 'done' else ''}">Đã giao</a>
                        </div>
                    </form>

                    <!-- STATE: list -->
                    <t t-if="view_state == 'list'">
                        <div class="wujia-mdelivery-resulthead">
                            <span class="cnt"><t t-out="len(batches)"/> chuyến</span>
                            <span class="sort">Mới nhất trước</span>
                        </div>
                        <div class="wujia-mdelivery-list">
                            <a t-foreach="batches" t-as="b" t-attf-href="/portal/delivery/#{b['id']}"
                               class="wujia-mdelivery-row">
                                <span class="wujia-mdelivery-row-top">
                                    <span class="wujia-mdelivery-row-headmain">
                                        <span class="wujia-mdelivery-row-label">Chuyến xe</span>
                                        <span class="wujia-mdelivery-row-id" t-out="b['name']"/>
                                    </span>
                                    <span t-attf-class="wujia-mdelivery-badge wujia-mdelivery-badge--#{b['modifier']}"
                                          t-out="b['label']"/>
                                </span>
                                <span class="wujia-mdelivery-row-divider"/>
                                <span class="wujia-mdelivery-row-cols">
                                    <span class="wujia-mdelivery-row-col">
                                        <i class="feather icon-calendar wujia-mdelivery-row-colicon"/>
                                        <span class="wujia-mdelivery-row-colbody">
                                            <span class="wujia-mdelivery-row-collabel">Xuất phát</span>
                                            <span class="wujia-mdelivery-row-colval" t-out="b['departure']"/>
                                        </span>
                                    </span>
                                    <span class="wujia-mdelivery-row-col">
                                        <i class="feather icon-file-text wujia-mdelivery-row-colicon"/>
                                        <span class="wujia-mdelivery-row-colbody">
                                            <span class="wujia-mdelivery-row-collabel">Đơn liên quan</span>
                                            <span class="wujia-mdelivery-row-colval" t-out="b['orders']"/>
                                        </span>
                                    </span>
                                </span>
                            </a>
                        </div>
                        <nav t-if="m_pager and m_pager.get('page_count', 0) &gt; 1" class="wujia-mhist-pager">
                            <a t-attf-href="/portal/delivery?page=#{m_pager['page_previous']['num']}&amp;#{m_pager.get('querystring','')}">«</a>
                            <span>Trang <t t-out="m_pager['page']['num']"/> / <t t-out="m_pager['page_count']"/></span>
                            <a t-attf-href="/portal/delivery?page=#{m_pager['page_next']['num']}&amp;#{m_pager.get('querystring','')}">»</a>
                        </nav>
                    </t>

                    <!-- STATE: empty (no-data chung Figma 4788:974 — lọc rỗng → Xóa lọc) -->
                    <div t-if="view_state == 'empty'" class="wj-empty-state wj-empty-state--rich">
                        <span class="wj-empty-state-icon"/>
                        <p class="wj-empty-state-title">Không có chuyến giao</p>
                        <p class="wj-empty-state-sub">Không tìm thấy chuyến giao trong khoảng ngày đã chọn.</p>
                        <p class="wj-empty-state-sub">Hãy đổi bộ lọc hoặc kiểm tra lại sau.</p>
                        <a href="/portal/delivery" class="wj-empty-state-btn">Xóa lọc</a>
                    </div>

                    <!-- STATE: error (semantic — giữ icon cảnh báo qua dual-mode) -->
                    <div t-if="view_state == 'error'" class="wj-empty-state wj-empty-state--rich">
                        <span class="wj-empty-state-icon wujia-mdelivery-icon-danger"><i class="feather icon-alert-triangle"/></span>
                        <p class="wj-empty-state-title">Không tải được dữ liệu</p>
                        <p class="wj-empty-state-sub">Vui lòng kiểm tra kết nối hoặc thử tải lại.</p>
                        <button type="button" class="wj-empty-state-btn" onclick="window.location.reload()">Tải lại</button>
                    </div>

                    <!-- STATE: loading (skeleton — UI-only, QA ?_preview=loading) -->
                    <t t-if="view_state == 'loading'">
                        <div class="wujia-mdelivery-resulthead">
                            <span class="cnt">Đang tải dữ liệu…</span>
                        </div>
                        <div class="wujia-mdelivery-list">
                            <t t-foreach="[1, 2, 3]" t-as="s">
                                <div class="wujia-mdelivery-row wujia-mdelivery-skel">
                                    <span class="wujia-mdelivery-row-top">
                                        <span class="wujia-mdelivery-row-headmain">
                                            <span class="wujia-mdelivery-skel-bar" style="width:70px;height:10px;"/>
                                            <span class="wujia-mdelivery-skel-bar" style="width:170px;height:14px;"/>
                                        </span>
                                        <span class="wujia-mdelivery-skel-bar" style="width:88px;height:24px;border-radius:8px;"/>
                                    </span>
                                    <span class="wujia-mdelivery-row-divider"/>
                                    <span class="wujia-mdelivery-row-cols">
                                        <span class="wujia-mdelivery-row-col">
                                            <span class="wujia-mdelivery-skel-bar" style="width:96px;height:12px;"/>
                                        </span>
                                        <span class="wujia-mdelivery-row-col">
                                            <span class="wujia-mdelivery-skel-bar" style="width:112px;height:12px;"/>
                                        </span>
                                    </span>
                                </div>
                            </t>
                        </div>
                    </t>
                </t>
            </div>
            <!-- /list -->
        </t>
    </template>

    <!-- ============== Detail page (batch) ============== -->
    <template id="portal_delivery_detail" name="Wujia Portal — Delivery Batch Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="batch.name"/>
            <!-- Desktop ≥992px — PC Chi tiết giao hàng (Figma 4766:1091). -->
            <div class="content-wrapper d-none d-lg-block wujia-dlv-pc">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'pc'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title">Chi tiết giao hàng</t>
                    <t t-set="ph_back_url" t-value="'/portal/delivery'"/>
                </t>

                <!-- Summary card -->
                <div class="wj-pc-order-head wj-pc-dlv-head">
                    <div>
                        <div class="wj-pc-dlv-head-coderow">
                            <h2 class="wj-pc-order-head__code" t-out="batch.name or '—'"/>
                            <span t-attf-class="wj-pc-badge wj-pc-badge--dlv-#{pc_badge[1]}" t-out="pc_badge[0]"/>
                        </div>
                        <p class="wj-pc-dlv-head-meta">Chuyến giao cho <t t-out="store_label"/></p>
                    </div>
                    <div class="wj-pc-dlv-head-kv">
                        <div class="wj-pc-kv">
                            <span class="wj-pc-kv__label">Xuất phát</span>
                            <span class="wj-pc-kv__value" t-out="pc_departure"/>
                        </div>
                        <div class="wj-pc-kv">
                            <span class="wj-pc-kv__label">Đơn liên quan</span>
                            <span class="wj-pc-kv__value" t-out="pc_orders"/>
                        </div>
                        <div class="wj-pc-kv">
                            <span class="wj-pc-kv__label">Cập nhật</span>
                            <span class="wj-pc-kv__value" t-out="pc_updated"/>
                        </div>
                    </div>
                </div>

                <!-- Two-column: vận chuyển | đơn liên quan + timeline -->
                <div class="wj-pc-two-col">
                    <div class="wj-pc-card">
                        <div class="wj-pc-card__head">
                            <h3 class="wj-pc-card__title wj-pc-card__title--sm">Thông tin vận chuyển</h3>
                        </div>
                        <div class="wj-pc-kv-grid">
                            <div class="wj-pc-kv">
                                <span class="wj-pc-kv__label">Xe / tài xế</span>
                                <span class="wj-pc-kv__value">
                                    <t t-if="batch.vehicle_id"><t t-out="batch.vehicle_id.name or '—'"/><t t-if="batch.vehicle_id.driver_name"> · <t t-out="batch.vehicle_id.driver_name"/></t></t>
                                    <t t-else="">—</t>
                                </span>
                            </div>
                            <div class="wj-pc-kv">
                                <span class="wj-pc-kv__label">Biển số</span>
                                <span class="wj-pc-kv__value" t-out="batch.vehicle_id.license_plate or '—'"/>
                            </div>
                        </div>
                        <hr class="wj-pc-dlv-divider"/>
                        <div class="wj-pc-kv-grid">
                            <div class="wj-pc-kv">
                                <span class="wj-pc-kv__label">Kho xuất</span>
                                <span class="wj-pc-kv__value" t-out="src_location"/>
                            </div>
                            <div class="wj-pc-kv">
                                <span class="wj-pc-kv__label">Trạng thái</span>
                                <span class="wj-pc-kv__value wj-pc-kv__value--primary" t-out="pc_badge[0]"/>
                            </div>
                        </div>
                    </div>

                    <div class="wj-pc-card">
                        <div class="wj-pc-card__head">
                            <h3 class="wj-pc-card__title wj-pc-card__title--sm">Đơn liên quan</h3>
                        </div>
                        <div class="wj-pc-dlv-so-chips">
                            <span t-foreach="so_names" t-as="so" class="wj-pc-dlv-so-chip" t-out="so"/>
                            <span t-if="not so_names" class="wj-pc-td--muted">—</span>
                        </div>
                        <!-- Timeline 3 bước: Xuất kho → Đang giao → Hoàn tất -->
                        <div class="wj-pc-dlv-timeline">
                            <div class="wj-pc-dlv-tl-step">
                                <span class="wj-pc-dlv-tl-time" t-out="tl_times[0]"/>
                                <span t-attf-class="wj-pc-dlv-tl-dot wj-pc-dlv-tl-dot--#{tl_steps[0]}"/>
                                <span class="wj-pc-dlv-tl-label">Xuất kho</span>
                            </div>
                            <span class="wj-pc-dlv-tl-line"/>
                            <div class="wj-pc-dlv-tl-step">
                                <span class="wj-pc-dlv-tl-time" t-out="tl_times[1]"/>
                                <span t-attf-class="wj-pc-dlv-tl-dot wj-pc-dlv-tl-dot--#{tl_steps[1]}"/>
                                <span class="wj-pc-dlv-tl-label">Đang giao</span>
                            </div>
                            <span class="wj-pc-dlv-tl-line"/>
                            <div class="wj-pc-dlv-tl-step">
                                <span class="wj-pc-dlv-tl-time" t-out="tl_times[2]"/>
                                <span t-attf-class="wj-pc-dlv-tl-dot wj-pc-dlv-tl-dot--#{tl_steps[2]}"/>
                                <span class="wj-pc-dlv-tl-label">Hoàn tất</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Products -->
                <div class="wj-pc-card">
                    <div class="wj-pc-card__head">
                        <div>
                            <h3 class="wj-pc-card__title">Sản phẩm trong chuyến</h3>
                            <p class="wj-pc-card__subtitle">Dạng bảng để đối chiếu nhanh tên sản phẩm, số lượng và đơn vị tính.</p>
                        </div>
                        <a href="#" class="wj-pc-btn wj-pc-btn--secondary"><i class="feather icon-download"/>Tải danh sách</a>
                    </div>
                    <table class="wj-pc-table wj-pc-dlv-table">
                        <thead>
                            <tr>
                                <th style="width:56px;">STT</th>
                                <th>Tên sản phẩm</th>
                                <th class="text-end">Số lượng</th>
                                <th class="text-end">ĐVT</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-if="products" t-foreach="products" t-as="p">
                                <td class="wj-pc-td--muted" t-out="p_index + 1"/>
                                <td t-out="p['name']"/>
                                <td class="text-end wj-pc-td--amount" t-out="'%g' % p['qty']"/>
                                <td class="text-end wj-pc-td--muted" t-out="p['uom']"/>
                            </tr>
                            <tr t-if="not products">
                                <td colspan="4" class="text-center wj-pc-td--muted">Chưa có sản phẩm trong chuyến.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Mobile <992px — Figma 4731:155 (delivery detail), batch-centric (S24) -->
            <div class="d-lg-none wujia-mpage wujia-mdelivery">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'m'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title">Chi tiết giao hàng</t>
                    <t t-set="ph_back_url" t-value="'/portal/delivery'"/>
                </t>

                <!-- Batch info -->
                <div class="wujia-mdash-card">
                    <div class="wujia-mdelivery-inf-top">
                        <span class="wujia-mdelivery-row-label">Chuyến xe</span>
                        <span t-attf-class="wujia-mdelivery-badge wujia-mdelivery-badge--#{m_badge[1]}" t-out="m_badge[0]"/>
                    </div>
                    <div class="wujia-mdelivery-inf-id" t-out="batch.name"/>
                    <div class="wujia-mdelivery-row-divider"/>
                    <div class="wujia-mdelivery-inf-dep">
                        <i class="feather icon-calendar wujia-mdelivery-row-colicon"/>
                        <span class="wujia-mdelivery-row-colbody">
                            <span class="wujia-mdelivery-row-collabel">Xuất phát</span>
                            <span class="wujia-mdelivery-inf-depval" t-out="m_departure_full"/>
                        </span>
                    </div>
                    <div class="wujia-mdelivery-inf-updated">Cập nhật: <t t-out="m_updated"/></div>
                </div>

                <!-- Thông tin chuyến -->
                <div class="wujia-mdelivery-sectiontop">Thông tin chuyến</div>
                <div class="wujia-mdash-card">
                    <div class="wujia-mdelivery-inforow">
                        <span class="lbl">Đơn liên quan</span>
                        <span class="val" t-out="m_orders"/>
                    </div>
                    <div class="wujia-mdelivery-inforow">
                        <span class="lbl">Xe / tài xế</span>
                        <span class="val">
                            <t t-if="batch.vehicle_id"><t t-out="batch.vehicle_id.name or '—'"/><t t-if="batch.vehicle_id.driver_name"> · <t t-out="batch.vehicle_id.driver_name"/></t></t>
                            <t t-else="">—</t>
                        </span>
                    </div>
                    <div class="wujia-mdelivery-inforow">
                        <span class="lbl">Biển số</span>
                        <span class="val" t-out="batch.vehicle_id.license_plate or '—'"/>
                    </div>
                </div>

                <!-- Sản phẩm trong chuyến -->
                <div class="wujia-mdelivery-sectiontop">Sản phẩm trong chuyến</div>
                <div class="wujia-mdelivery-prodcard">
                    <div class="wujia-mdelivery-prodrow wujia-mdelivery-prodrow--head">
                        <span class="nm">Tên sản phẩm</span>
                        <span class="qt">SL</span>
                        <span class="um">ĐVT</span>
                    </div>
                    <t t-if="products" t-foreach="products" t-as="p">
                        <div class="wujia-mdelivery-prodrow">
                            <span class="nm" t-out="p['name']"/>
                            <span class="qt" t-out="'%g' % p['qty']"/>
                            <span class="um" t-out="p['uom']"/>
                        </div>
                    </t>
                    <div t-if="not products" class="wujia-mdelivery-prodempty">Chưa có sản phẩm trong chuyến.</div>
                </div>
            </div>
        </t>
    </template>

</odoo>
