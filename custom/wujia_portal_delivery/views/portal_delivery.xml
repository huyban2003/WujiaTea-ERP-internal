<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List page (theo picking outgoing của franchise) ============== -->
    <template id="portal_delivery_tracking" name="Wujia Portal — Delivery Tracking List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Theo dõi giao hàng</t>
            <!-- ===== Desktop (>=992px) — GIỮ NGUYÊN 100%, chỉ bọc d-none d-lg-block (Sprint 16) ===== -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-truck me-1"/>Theo dõi giao hàng
                        </h2>
                    </div>
                </div>

                <div t-if="no_franchise" class="alert alert-warning m-3">
                    Bạn chưa được gán vào cửa hàng nào.
                </div>

                <div t-if="not no_franchise" class="content-body">
                    <div class="card mb-2">
                        <div class="card-body p-2">
                            <form method="get" action="/portal/delivery" class="row g-2 align-items-center">
                                <div class="col-md-4 col-12">
                                    <label class="small text-muted mb-1">Trạng thái giao</label>
                                    <select name="status" class="form-select form-select-sm">
                                        <option value="">— Tất cả —</option>
                                        <t t-foreach="picking_labels.items()" t-as="kv">
                                            <option t-att-value="kv[0]"
                                                    t-att-selected="'selected' if status == kv[0] else None"
                                                    t-out="kv[1][0]"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-3 col-12 text-end">
                                    <label class="small text-muted mb-1 d-block">&#160;</label>
                                    <button class="btn btn-primary btn-sm" type="submit"><i class="fa fa-search"/> Lọc</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Sprint 9.13b 2026-05-27: MẪU 02 wujia-content-card-table -->
                    <div class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-truck"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Danh sách chuyến giao</h4>
                            <span t-if="pickings" class="wujia-content-card-header-link">
                                <t t-out="len(pickings)"/> kết quả
                            </span>
                        </div>
                        <div t-if="not pickings" class="wujia-content-card-empty">Chưa có chuyến giao nào.</div>
                        <div t-else="" class="table-responsive">
                            <table class="wujia-content-card-table">
                                <thead>
                                    <tr>
                                        <th>Phiếu xuất</th>
                                        <th>Đơn hàng</th>
                                        <th>Ngày dự kiến</th>
                                        <th>Batch / Xe</th>
                                        <th>Tài xế / SĐT</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="pickings" t-as="p">
                                        <td t-out="p.name"/>
                                        <td>
                                            <a t-if="p.sale_id" t-attf-href="/portal/purchase-history/#{p.sale_id.id}" t-out="p.sale_id.name"/>
                                            <span t-else="" class="text-muted">—</span>
                                        </td>
                                        <td t-out="p.scheduled_date and p.scheduled_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <td>
                                            <t t-if="p.batch_id">
                                                <a t-attf-href="/portal/delivery/#{p.batch_id.id}" t-out="p.batch_id.name"/>
                                                <small t-if="p.vehicle_id" class="text-muted d-block" t-out="p.vehicle_id.name"/>
                                            </t>
                                            <span t-else="" class="text-muted">Chưa xếp xe</span>
                                        </td>
                                        <td>
                                            <t t-if="p.vehicle_id">
                                                <span t-out="p.vehicle_id.driver_name or '—'"/>
                                                <small t-if="p.vehicle_id.driver_phone" class="text-muted d-block" t-out="p.vehicle_id.driver_phone"/>
                                            </t>
                                            <span t-else="" class="text-muted">—</span>
                                        </td>
                                        <td class="text-center">
                                            <t t-set="lbl" t-value="picking_labels.get(p.delivery_status, (p.delivery_status, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-if="p.batch_id"
                                               t-attf-href="/portal/delivery/#{p.batch_id.id}"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fa fa-eye"/>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="mt-2">
                        <ul class="pagination wujia-pagination justify-content-center mb-0">
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/delivery?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                            </li>
                            <li class="page-item active">
                                <span class="page-link"><t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/delivery?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
            <!-- /desktop -->

            <!-- ===== Mobile (<992px) — Sprint 16, Figma Screen_2_Orders 2474:119
                 (frame mobile_dashboard 2474:2, thế hệ CŨ — shell FINAL giữ nguyên,
                 chỉ build content; footer active cyan ≠ đỏ Figma = drift chủ đích).
                 BlankShell .wujia-mpage, đặt NGOÀI .content-wrapper (pattern S15).
                 UI-only notes:
                 - "Tổng tiền" đổi trả: wujia.return.request CHƯA có field tổng tiền
                   → hiện "—", wire khi BA thêm field.
                 - "Xem tất cả" giao hàng trỏ về chính /portal/delivery (list picking
                   desktop; mobile list đầy đủ chờ BA design). -->
            <div class="d-lg-none wujia-mpage wujia-mdash">
                <div t-if="no_franchise" class="wujia-mdash-card wujia-empty-state">
                    <i class="feather icon-home"/>
                    <p>Bạn chưa được gán vào cửa hàng nào.</p>
                </div>
                <t t-else="">
                    <!-- Đơn hàng gần đây -->
                    <section class="wujia-mdash-sec">
                        <div class="wujia-mdash-titlerow">
                            <h2 class="wujia-mdash-title">Đơn hàng gần đây</h2>
                            <a href="/portal/purchase-history" class="wujia-mdash-link">Xem tất cả ›</a>
                        </div>
                        <div class="wujia-mdash-card wujia-mdash-list">
                            <div t-if="not m_recent_orders" class="wujia-mdash-empty">Chưa có đơn hàng.</div>
                            <t t-foreach="m_recent_orders" t-as="o">
                                <a t-attf-href="/portal/purchase-history/#{o.id}" class="wujia-mdash-row">
                                    <span class="wujia-mdash-tile"><i class="feather icon-file-text"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-title is-lg" t-out="o.name"/>
                                        <span class="wujia-mdash-row-sub"
                                              t-out="o.date_order and o.date_order.strftime('%H:%M %d/%m/%Y') or ''"/>
                                    </span>
                                    <span class="wujia-mdash-amount"
                                          t-out="'{:,.0f}'.format(o.amount_total).replace(',', '.') + ' đ'"/>
                                    <t t-set="lbl" t-value="m_order_badges.get(o.state, (o.state, 'wujia-badge-muted'))"/>
                                    <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                    <i class="feather icon-chevron-right wujia-mdash-chev"/>
                                </a>
                            </t>
                        </div>
                    </section>

                    <!-- Giao hàng sắp tới -->
                    <section class="wujia-mdash-sec">
                        <div class="wujia-mdash-titlerow">
                            <h2 class="wujia-mdash-title">Giao hàng sắp tới</h2>
                            <a href="/portal/delivery" class="wujia-mdash-link">Xem tất cả ›</a>
                        </div>
                        <div class="wujia-mdash-stack">
                            <div t-if="not m_upcoming_batches" class="wujia-mdash-card wujia-mdash-empty">Chưa có chuyến giao sắp tới.</div>
                            <t t-foreach="m_upcoming_batches" t-as="it">
                                <a t-attf-href="/portal/delivery/#{it['batch'].id}" class="wujia-mdash-card wujia-mdash-item">
                                    <span class="wujia-mdash-tile"><i class="feather icon-truck"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-title" t-out="it['batch'].name"/>
                                        <span class="wujia-mdash-row-sub is-strong" t-out="it['when']"/>
                                        <span class="wujia-mdash-row-sub">Tổng đơn: <t t-out="it['order_count']"/> đơn</span>
                                        <span class="wujia-mdash-row-sub is-strong">
                                            Tổng tiền: <t t-out="'{:,.0f}'.format(it['total']).replace(',', '.') + ' đ'"/>
                                        </span>
                                    </span>
                                    <span t-attf-class="wujia-badge #{it['badge'][1]}" t-out="it['badge'][0]"/>
                                </a>
                            </t>
                        </div>
                    </section>

                    <!-- Yêu cầu đổi trả gần đây -->
                    <section class="wujia-mdash-sec">
                        <div class="wujia-mdash-titlerow">
                            <h2 class="wujia-mdash-title">Yêu cầu đổi trả gần đây</h2>
                            <a href="/portal/return" class="wujia-mdash-link">Xem tất cả ›</a>
                        </div>
                        <div class="wujia-mdash-stack">
                            <div t-if="not m_recent_returns" class="wujia-mdash-card wujia-mdash-empty">Chưa có yêu cầu đổi trả.</div>
                            <t t-foreach="m_recent_returns" t-as="r">
                                <a t-attf-href="/portal/return/#{r.id}" class="wujia-mdash-card wujia-mdash-item">
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-title" t-out="r.name"/>
                                        <span class="wujia-mdash-row-sub">
                                            Ngày yêu cầu: <t t-out="r.request_date and r.request_date.strftime('%d/%m/%Y') or '—'"/>
                                        </span>
                                        <span class="wujia-mdash-row-sub is-strong">
                                            Lý do: <t t-out="r.error_id.name or '—'"/>
                                        </span>
                                        <!-- UI-only: model chưa có field tổng tiền (NOTE BA) -->
                                        <span class="wujia-mdash-row-sub is-strong is-xs">Tổng tiền: —</span>
                                    </span>
                                    <t t-set="lbl" t-value="m_return_badges.get(r.state, (r.state, 'wujia-badge-muted'))"/>
                                    <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                </a>
                            </t>
                        </div>
                    </section>
                </t>
            </div>
            <!-- /mobile -->
        </t>
    </template>

    <!-- ============== Detail page (batch) ============== -->
    <template id="portal_delivery_detail" name="Wujia Portal — Delivery Batch Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="batch.name"/>
            <div class="content-wrapper">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/delivery">Theo dõi giao hàng</a></li>
                            <li class="breadcrumb-item active" t-out="batch.name"/>
                        </ol></nav>
                        <h2 class="content-header-title float-left mb-0 d-flex align-items-center">
                            <span class="me-2">Chuyến <t t-out="batch.name"/></span>
                            <t t-set="lbl" t-value="batch_labels.get(batch.delivery_batch_status, (batch.delivery_batch_status, 'wujia-badge-muted'))"/>
                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                        </h2>
                    </div>
                </div>

                <div class="content-body">
                    <div class="row">
                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Thông tin chuyến</h5></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-sm-5">Xe</dt>
                                        <dd class="col-sm-7" t-out="batch.vehicle_id.name or '—'"/>
                                        <dt class="col-sm-5">Tài xế</dt>
                                        <dd class="col-sm-7" t-out="batch.vehicle_id.driver_name or '—'"/>
                                        <dt class="col-sm-5">SĐT tài xế</dt>
                                        <dd class="col-sm-7" t-out="batch.vehicle_id.driver_phone or '—'"/>
                                        <dt class="col-sm-5">Nhà xe</dt>
                                        <dd class="col-sm-7" t-out="batch.provider_id.name or '—'"/>
                                        <dt class="col-sm-5">Loại xe</dt>
                                        <dd class="col-sm-7" t-out="batch.fleet_type_id.name or '—'"/>
                                        <dt class="col-sm-5">Tải trọng</dt>
                                        <dd class="col-sm-7" t-out="'{:,.0f}'.format(batch.vehicle_capacity_kg or 0).replace(',', '.') + ' kg' if batch.vehicle_capacity_kg else '—'"/>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Thời gian</h5></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-sm-5">Dự kiến xuất phát</dt>
                                        <dd class="col-sm-7" t-out="batch.planned_departure and batch.planned_departure.strftime('%d/%m/%Y %H:%M') or '—'"/>
                                        <dt class="col-sm-5">Thực tế xuất phát</dt>
                                        <dd class="col-sm-7" t-out="batch.actual_departure and batch.actual_departure.strftime('%d/%m/%Y %H:%M') or '—'"/>
                                        <dt class="col-sm-5">Khối lượng</dt>
                                        <dd class="col-sm-7" t-out="'{:,.2f}'.format(batch.planned_weight or 0) + ' kg'"/>
                                        <dt class="col-sm-5">Số phiếu</dt>
                                        <dd class="col-sm-7" t-out="len(batch.picking_ids)"/>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-list"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Phiếu giao của cửa hàng bạn</h4>
                            <span t-if="own_pickings" class="wujia-content-card-header-link">
                                <t t-out="len(own_pickings)"/> phiếu
                            </span>
                        </div>
                        <div t-if="not own_pickings" class="wujia-content-card-empty">Không có phiếu giao thuộc cửa hàng của bạn trong chuyến này.</div>
                        <div t-else="" class="table-responsive">
                            <table class="wujia-content-card-table">
                                <thead><tr><th>Phiếu</th><th>Đơn</th><th>Cửa hàng</th><th>Trạng thái</th></tr></thead>
                                <tbody>
                                    <tr t-foreach="own_pickings" t-as="p">
                                        <td t-out="p.name"/>
                                        <td><a t-if="p.sale_id" t-attf-href="/portal/purchase-history/#{p.sale_id.id}" t-out="p.sale_id.name"/></td>
                                        <td t-out="p.franchise_id.name or '—'"/>
                                        <td>
                                            <t t-set="lbl" t-value="picking_labels.get(p.delivery_status, (p.delivery_status, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-2">
                        <a href="/portal/delivery" class="btn btn-secondary">
                            <i class="fa fa-arrow-left me-1"/>Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
