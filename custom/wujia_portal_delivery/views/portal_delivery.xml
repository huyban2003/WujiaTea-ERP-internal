<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List page (theo picking outgoing của franchise) ============== -->
    <template id="portal_delivery_tracking" name="Wujia Portal — Delivery Tracking List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Theo dõi giao hàng</t>
            <!-- Desktop ≥992px — bảng phiếu xuất, giữ nguyên, bọc d-none d-lg-block (S24) -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-truck me-1"/>Theo dõi giao hàng
                        </h2>
                    </div>
                </div>

                <div t-if="no_franchise" class="alert alert-warning m-3">
                    Bạn chưa được gán vào cửa hàng nào.
                </div>

                <div t-if="not no_franchise" class="content-body">
                    <div class="card mb-2">
                        <div class="card-body p-2">
                            <form method="get" action="/portal/delivery" class="row g-2 align-items-center">
                                <div class="col-md-4 col-12">
                                    <label class="small text-muted mb-1">Trạng thái giao</label>
                                    <select name="status" class="form-select form-select-sm">
                                        <option value="">— Tất cả —</option>
                                        <t t-foreach="picking_labels.items()" t-as="kv">
                                            <option t-att-value="kv[0]"
                                                    t-att-selected="'selected' if status == kv[0] else None"
                                                    t-out="kv[1][0]"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-3 col-12 text-end">
                                    <label class="small text-muted mb-1 d-block">&#160;</label>
                                    <button class="btn btn-primary btn-sm" type="submit"><i class="fa fa-search"/> Lọc</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Sprint 9.13b 2026-05-27: MẪU 02 wujia-content-card-table -->
                    <div class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-truck"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Danh sách chuyến giao</h4>
                            <span t-if="pickings" class="wujia-content-card-header-link">
                                <t t-out="len(pickings)"/> kết quả
                            </span>
                        </div>
                        <div t-if="not pickings" class="wujia-content-card-empty">Chưa có chuyến giao nào.</div>
                        <div t-else="" class="table-responsive">
                            <table class="wujia-content-card-table">
                                <thead>
                                    <tr>
                                        <th>Phiếu xuất</th>
                                        <th>Đơn hàng</th>
                                        <th>Ngày dự kiến</th>
                                        <th>Batch / Xe</th>
                                        <th>Tài xế / SĐT</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="pickings" t-as="p">
                                        <td t-out="p.name"/>
                                        <td>
                                            <a t-if="p.sale_id" t-attf-href="/portal/purchase-history/#{p.sale_id.id}" t-out="p.sale_id.name"/>
                                            <span t-else="" class="text-muted">—</span>
                                        </td>
                                        <td t-out="p.scheduled_date and p.scheduled_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <td>
                                            <t t-if="p.batch_id">
                                                <a t-attf-href="/portal/delivery/#{p.batch_id.id}" t-out="p.batch_id.name"/>
                                                <small t-if="p.vehicle_id" class="text-muted d-block" t-out="p.vehicle_id.name"/>
                                            </t>
                                            <span t-else="" class="text-muted">Chưa xếp xe</span>
                                        </td>
                                        <td>
                                            <t t-if="p.vehicle_id">
                                                <span t-out="p.vehicle_id.driver_name or '—'"/>
                                                <small t-if="p.vehicle_id.driver_phone" class="text-muted d-block" t-out="p.vehicle_id.driver_phone"/>
                                            </t>
                                            <span t-else="" class="text-muted">—</span>
                                        </td>
                                        <td class="text-center">
                                            <t t-set="lbl" t-value="picking_labels.get(p.delivery_status, (p.delivery_status, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-if="p.batch_id"
                                               t-attf-href="/portal/delivery/#{p.batch_id.id}"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fa fa-eye"/>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="mt-2">
                        <ul class="pagination wujia-pagination justify-content-center mb-0">
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/delivery?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                            </li>
                            <li class="page-item active">
                                <span class="page-link"><t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/delivery?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>

            <!-- Mobile <992px — Figma 4731:2 (delivery_mobile_mockup_v4), batch-centric (S24) -->
            <div class="d-lg-none wujia-mpage wujia-mdelivery">
                <div class="wujia-mdelivery-head">
                    <h1 class="wujia-mdelivery-title">Giao hàng</h1>
                    <p class="wujia-mdelivery-sub">Theo dõi chuyến giao của cửa hàng</p>
                </div>

                <div t-if="no_franchise" class="wj-empty-state wj-empty-state--card">
                    <i class="feather icon-alert-circle"/>
                    <p>Bạn chưa được gán vào cửa hàng nào.</p>
                </div>

                <t t-else="">
                    <!-- Date filter (Từ ngày / Đến ngày / Tìm) -->
                    <form method="get" action="/portal/delivery" class="wujia-mdelivery-filter">
                        <input t-if="bs" type="hidden" name="bs" t-att-value="bs"/>
                        <label class="wujia-mdelivery-datefield">
                            <span class="wujia-mdelivery-datefield-lbl">Từ ngày</span>
                            <input type="date" name="date_from" t-att-value="date_from or ''"/>
                        </label>
                        <label class="wujia-mdelivery-datefield">
                            <span class="wujia-mdelivery-datefield-lbl">Đến ngày</span>
                            <input type="date" name="date_to" t-att-value="date_to or ''"/>
                        </label>
                        <button type="submit" class="wujia-mdelivery-search-btn">
                            <i class="feather icon-search"/> Tìm
                        </button>
                    </form>

                    <!-- Status chips — bs nhóm (soon/going/done), giữ date filter -->
                    <t t-set="_dq" t-value="(('&amp;date_from=%s' % date_from) if date_from else '') + (('&amp;date_to=%s' % date_to) if date_to else '')"/>
                    <div class="wj-filter-chips">
                        <a t-attf-href="/portal/delivery?bs=#{_dq}"
                           t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if not bs else ''}">Tất cả</a>
                        <a t-attf-href="/portal/delivery?bs=soon#{_dq}"
                           t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if bs == 'soon' else ''}">Sắp giao</a>
                        <a t-attf-href="/portal/delivery?bs=going#{_dq}"
                           t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if bs == 'going' else ''}">Đang giao</a>
                        <a t-attf-href="/portal/delivery?bs=done#{_dq}"
                           t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if bs == 'done' else ''}">Đã giao</a>
                    </div>

                    <!-- STATE: list -->
                    <t t-if="view_state == 'list'">
                        <div class="wujia-mdelivery-resulthead">
                            <span class="cnt"><t t-out="len(batches)"/> chuyến</span>
                            <span class="sort">Mới nhất trước</span>
                        </div>
                        <div class="wujia-mdelivery-list">
                            <a t-foreach="batches" t-as="b" t-attf-href="/portal/delivery/#{b['id']}"
                               class="wujia-mdelivery-row">
                                <span class="wujia-mdelivery-row-top">
                                    <span class="wujia-mdelivery-row-headmain">
                                        <span class="wujia-mdelivery-row-label">Chuyến xe</span>
                                        <span class="wujia-mdelivery-row-id" t-out="b['name']"/>
                                    </span>
                                    <span t-attf-class="wujia-mdelivery-badge wujia-mdelivery-badge--#{b['modifier']}"
                                          t-out="b['label']"/>
                                </span>
                                <span class="wujia-mdelivery-row-divider"/>
                                <span class="wujia-mdelivery-row-cols">
                                    <span class="wujia-mdelivery-row-col">
                                        <i class="feather icon-calendar wujia-mdelivery-row-colicon"/>
                                        <span class="wujia-mdelivery-row-colbody">
                                            <span class="wujia-mdelivery-row-collabel">Xuất phát</span>
                                            <span class="wujia-mdelivery-row-colval" t-out="b['departure']"/>
                                        </span>
                                    </span>
                                    <span class="wujia-mdelivery-row-col">
                                        <i class="feather icon-file-text wujia-mdelivery-row-colicon"/>
                                        <span class="wujia-mdelivery-row-colbody">
                                            <span class="wujia-mdelivery-row-collabel">Đơn liên quan</span>
                                            <span class="wujia-mdelivery-row-colval" t-out="b['orders']"/>
                                        </span>
                                    </span>
                                </span>
                            </a>
                        </div>
                        <nav t-if="m_pager and m_pager.get('page_count', 0) &gt; 1" class="wujia-mhist-pager">
                            <a t-attf-href="/portal/delivery?page=#{m_pager['page_previous']['num']}&amp;#{m_pager.get('querystring','')}">«</a>
                            <span>Trang <t t-out="m_pager['page']['num']"/> / <t t-out="m_pager['page_count']"/></span>
                            <a t-attf-href="/portal/delivery?page=#{m_pager['page_next']['num']}&amp;#{m_pager.get('querystring','')}">»</a>
                        </nav>
                    </t>

                    <!-- STATE: empty -->
                    <div t-if="view_state == 'empty'" class="wujia-mdash-card wj-empty-state--rich">
                        <span class="wj-empty-state-icon"><i class="feather icon-truck"/></span>
                        <p class="wj-empty-state-title">Không có chuyến giao</p>
                        <p class="wj-empty-state-sub">Không tìm thấy chuyến giao trong khoảng ngày đã chọn.</p>
                        <p class="wj-empty-state-sub">Hãy đổi bộ lọc hoặc kiểm tra lại sau.</p>
                        <a href="/portal/delivery" class="wujia-mdelivery-cta">Đổi bộ lọc</a>
                    </div>

                    <!-- STATE: error -->
                    <div t-if="view_state == 'error'" class="wujia-mdash-card wj-empty-state--rich">
                        <span class="wj-empty-state-icon wujia-mdelivery-icon-danger"><i class="feather icon-alert-triangle"/></span>
                        <p class="wj-empty-state-title">Không tải được dữ liệu</p>
                        <p class="wj-empty-state-sub">Vui lòng kiểm tra kết nối hoặc thử tải lại.</p>
                        <a href="/portal/delivery" class="wujia-mdelivery-cta">Tải lại</a>
                    </div>

                    <!-- STATE: loading (skeleton — UI-only, QA ?_preview=loading) -->
                    <t t-if="view_state == 'loading'">
                        <div class="wujia-mdelivery-resulthead">
                            <span class="cnt">Đang tải dữ liệu…</span>
                        </div>
                        <div class="wujia-mdelivery-list">
                            <t t-foreach="[1, 2, 3]" t-as="s">
                                <div class="wujia-mdelivery-row wujia-mdelivery-skel">
                                    <span class="wujia-mdelivery-row-top">
                                        <span class="wujia-mdelivery-row-headmain">
                                            <span class="wujia-mdelivery-skel-bar" style="width:70px;height:10px;"/>
                                            <span class="wujia-mdelivery-skel-bar" style="width:170px;height:14px;"/>
                                        </span>
                                        <span class="wujia-mdelivery-skel-bar" style="width:88px;height:24px;border-radius:8px;"/>
                                    </span>
                                    <span class="wujia-mdelivery-row-divider"/>
                                    <span class="wujia-mdelivery-row-cols">
                                        <span class="wujia-mdelivery-row-col">
                                            <span class="wujia-mdelivery-skel-bar" style="width:96px;height:12px;"/>
                                        </span>
                                        <span class="wujia-mdelivery-row-col">
                                            <span class="wujia-mdelivery-skel-bar" style="width:112px;height:12px;"/>
                                        </span>
                                    </span>
                                </div>
                            </t>
                        </div>
                    </t>
                </t>
            </div>
            <!-- /list -->
        </t>
    </template>

    <!-- ============== Detail page (batch) ============== -->
    <template id="portal_delivery_detail" name="Wujia Portal — Delivery Batch Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="batch.name"/>
            <!-- Desktop ≥992px — giữ nguyên, bọc d-none d-lg-block (S24) -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/delivery">Theo dõi giao hàng</a></li>
                            <li class="breadcrumb-item active" t-out="batch.name"/>
                        </ol></nav>
                        <h2 class="content-header-title float-left mb-0 d-flex align-items-center">
                            <span class="me-2">Chuyến <t t-out="batch.name"/></span>
                            <t t-set="lbl" t-value="batch_labels.get(batch.delivery_batch_status, (batch.delivery_batch_status, 'wujia-badge-muted'))"/>
                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                        </h2>
                    </div>
                </div>

                <div class="content-body">
                    <div class="row">
                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Thông tin chuyến</h5></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-sm-5">Xe</dt>
                                        <dd class="col-sm-7" t-out="batch.vehicle_id.name or '—'"/>
                                        <dt class="col-sm-5">Tài xế</dt>
                                        <dd class="col-sm-7" t-out="batch.vehicle_id.driver_name or '—'"/>
                                        <dt class="col-sm-5">SĐT tài xế</dt>
                                        <dd class="col-sm-7" t-out="batch.vehicle_id.driver_phone or '—'"/>
                                        <dt class="col-sm-5">Nhà xe</dt>
                                        <dd class="col-sm-7" t-out="batch.provider_id.name or '—'"/>
                                        <dt class="col-sm-5">Loại xe</dt>
                                        <dd class="col-sm-7" t-out="batch.fleet_type_id.name or '—'"/>
                                        <dt class="col-sm-5">Tải trọng</dt>
                                        <dd class="col-sm-7" t-out="'{:,.0f}'.format(batch.vehicle_capacity_kg or 0).replace(',', '.') + ' kg' if batch.vehicle_capacity_kg else '—'"/>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Thời gian</h5></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-sm-5">Dự kiến xuất phát</dt>
                                        <dd class="col-sm-7" t-out="batch.planned_departure and batch.planned_departure.strftime('%d/%m/%Y %H:%M') or '—'"/>
                                        <dt class="col-sm-5">Thực tế xuất phát</dt>
                                        <dd class="col-sm-7" t-out="batch.actual_departure and batch.actual_departure.strftime('%d/%m/%Y %H:%M') or '—'"/>
                                        <dt class="col-sm-5">Khối lượng</dt>
                                        <dd class="col-sm-7" t-out="'{:,.2f}'.format(batch.planned_weight or 0) + ' kg'"/>
                                        <dt class="col-sm-5">Số phiếu</dt>
                                        <dd class="col-sm-7" t-out="len(batch.picking_ids)"/>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-list"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Phiếu giao của cửa hàng bạn</h4>
                            <span t-if="own_pickings" class="wujia-content-card-header-link">
                                <t t-out="len(own_pickings)"/> phiếu
                            </span>
                        </div>
                        <div t-if="not own_pickings" class="wujia-content-card-empty">Không có phiếu giao thuộc cửa hàng của bạn trong chuyến này.</div>
                        <div t-else="" class="table-responsive">
                            <table class="wujia-content-card-table">
                                <thead><tr><th>Phiếu</th><th>Đơn</th><th>Cửa hàng</th><th>Trạng thái</th></tr></thead>
                                <tbody>
                                    <tr t-foreach="own_pickings" t-as="p">
                                        <td t-out="p.name"/>
                                        <td><a t-if="p.sale_id" t-attf-href="/portal/purchase-history/#{p.sale_id.id}" t-out="p.sale_id.name"/></td>
                                        <td t-out="p.franchise_id.name or '—'"/>
                                        <td>
                                            <t t-set="lbl" t-value="picking_labels.get(p.delivery_status, (p.delivery_status, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-2">
                        <a href="/portal/delivery" class="btn btn-secondary">
                            <i class="fa fa-arrow-left me-1"/>Quay lại
                        </a>
                    </div>
                </div>
            </div>

            <!-- Mobile <992px — Figma 4731:155 (delivery detail), batch-centric (S24) -->
            <div class="d-lg-none wujia-mpage wujia-mdelivery">
                <div class="wujia-mdelivery-detail-head">
                    <a href="/portal/delivery" class="wujia-mdelivery-back" aria-label="Quay lại">
                        <i class="feather icon-chevron-left"/>
                    </a>
                    <div class="wujia-mdelivery-detail-titles">
                        <h1 class="wujia-mticket-h1">Chi tiết giao hàng</h1>
                        <p class="wujia-mdelivery-sub">Thông tin chuyến giao</p>
                    </div>
                </div>

                <!-- Batch info -->
                <div class="wujia-mdash-card">
                    <div class="wujia-mdelivery-inf-top">
                        <span class="wujia-mdelivery-row-label">Chuyến xe</span>
                        <span t-attf-class="wujia-mdelivery-badge wujia-mdelivery-badge--#{m_badge[1]}" t-out="m_badge[0]"/>
                    </div>
                    <div class="wujia-mdelivery-inf-id" t-out="batch.name"/>
                    <div class="wujia-mdelivery-row-divider"/>
                    <div class="wujia-mdelivery-inf-dep">
                        <i class="feather icon-calendar wujia-mdelivery-row-colicon"/>
                        <span class="wujia-mdelivery-row-colbody">
                            <span class="wujia-mdelivery-row-collabel">Xuất phát</span>
                            <span class="wujia-mdelivery-inf-depval" t-out="m_departure_full"/>
                        </span>
                    </div>
                    <div class="wujia-mdelivery-inf-updated">Cập nhật: <t t-out="m_updated"/></div>
                </div>

                <!-- Thông tin chuyến -->
                <div class="wujia-mdelivery-sectiontop">Thông tin chuyến</div>
                <div class="wujia-mdash-card">
                    <div class="wujia-mdelivery-inforow">
                        <span class="lbl">Đơn liên quan</span>
                        <span class="val" t-out="m_orders"/>
                    </div>
                    <div class="wujia-mdelivery-inforow">
                        <span class="lbl">Xe / tài xế</span>
                        <span class="val">
                            <t t-if="batch.vehicle_id"><t t-out="batch.vehicle_id.name or '—'"/><t t-if="batch.vehicle_id.driver_name"> · <t t-out="batch.vehicle_id.driver_name"/></t></t>
                            <t t-else="">—</t>
                        </span>
                    </div>
                    <div class="wujia-mdelivery-inforow">
                        <span class="lbl">Biển số</span>
                        <span class="val" t-out="batch.vehicle_id.license_plate or '—'"/>
                    </div>
                </div>

                <!-- Sản phẩm trong chuyến -->
                <div class="wujia-mdelivery-sectiontop">Sản phẩm trong chuyến</div>
                <div class="wujia-mdelivery-prodcard">
                    <div class="wujia-mdelivery-prodrow wujia-mdelivery-prodrow--head">
                        <span class="nm">Tên sản phẩm</span>
                        <span class="qt">SL</span>
                        <span class="um">ĐVT</span>
                    </div>
                    <t t-if="products" t-foreach="products" t-as="p">
                        <div class="wujia-mdelivery-prodrow">
                            <span class="nm" t-out="p['name']"/>
                            <span class="qt" t-out="'%g' % p['qty']"/>
                            <span class="um" t-out="p['uom']"/>
                        </div>
                    </t>
                    <div t-if="not products" class="wujia-mdelivery-prodempty">Chưa có sản phẩm trong chuyến.</div>
                </div>
            </div>
        </t>
    </template>

