<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_picking_batch_form_wujia_delivery" model="ir.ui.view">
        <field name="name">stock.picking.batch.form.wujia.delivery</field>
        <field name="model">stock.picking.batch</field>
        <field name="inherit_id" ref="stock_picking_batch.stock_picking_batch_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_delivery_assign" type="object"
                        string="Đã gán xe" class="btn-primary"
                        invisible="delivery_batch_status != 'draft' or not vehicle_id"/>
                <button name="action_delivery_loading" type="object"
                        string="Bắt đầu chất hàng"
                        invisible="delivery_batch_status not in ('assigned',)"/>
                <button name="action_delivery_start" type="object"
                        string="Xuất phát" class="btn-warning"
                        invisible="delivery_batch_status not in ('loading',)"/>
                <button name="action_delivery_done" type="object"
                        string="Hoàn tất giao" class="btn-success"
                        invisible="delivery_batch_status not in ('delivering',)"/>
                <button name="action_delivery_cancel" type="object"
                        string="Hủy chuyến"
                        invisible="delivery_batch_status in ('done', 'cancelled')"
                        confirm="Hủy chuyến giao hàng này?"/>
                <field name="delivery_batch_status" widget="statusbar"
                       statusbar_visible="draft,assigned,loading,delivering,done"/>
            </xpath>
            <xpath expr="//sheet/group" position="before">
                <widget name="web_ribbon" title="Vượt tải" bg_color="text-bg-danger"
                        invisible="not is_over_capacity"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Điều phối Wujia" name="wujia_delivery">
                    <group>
                        <group string="Xe &amp; Đội xe">
                            <field name="vehicle_id" options="{'no_create_edit': True}"/>
                            <field name="provider_id" readonly="1"/>
                            <field name="fleet_type_id" readonly="1"/>
                            <field name="vehicle_capacity_ton" readonly="1"/>
                            <field name="vehicle_capacity_kg" readonly="1"/>
                        </group>
                        <group string="Tải trọng">
                            <field name="planned_weight" readonly="1"/>
                            <field name="done_weight" readonly="1"/>
                            <field name="capacity_usage_percent" widget="percentage" readonly="1"/>
                            <field name="is_over_capacity" readonly="1"/>
                            <field name="over_capacity_weight" readonly="1"
                                   invisible="not is_over_capacity"/>
                        </group>
                    </group>
                    <group>
                        <group string="Khu vực &amp; Cửa hàng">
                            <field name="franchise_count" readonly="1"/>
                            <field name="area_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                        <group string="Lịch trình">
                            <field name="planned_departure"/>
                            <field name="actual_departure" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Bảng giá &amp; Chi phí">
                            <field name="pricelist_id"
                                   options="{'no_create_edit': True}"
                                   domain="[('state', '=', 'active'), ('fleet_type_id', '=', fleet_type_id)]"/>
                            <field name="shipping_cost"/>
                            <field name="drop_fee_total"/>
                            <field name="total_shipping_cost" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="delivery_note" placeholder="Ghi chú điều phối cho chuyến..."/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_stock_picking_batch_tree_wujia_delivery" model="ir.ui.view">
        <field name="name">stock.picking.batch.list.wujia.delivery</field>
        <field name="model">stock.picking.batch</field>
        <field name="inherit_id" ref="stock_picking_batch.stock_picking_batch_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="vehicle_id" optional="show"/>
                <field name="provider_id" optional="show"/>
                <field name="planned_weight" optional="show"/>
                <field name="capacity_usage_percent" widget="percentage" optional="show"/>
                <field name="is_over_capacity" optional="hide"/>
                <field name="total_shipping_cost" optional="show" widget="monetary"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="delivery_batch_status" optional="show" widget="badge"
                       decoration-info="delivery_batch_status in ('assigned', 'loading')"
                       decoration-warning="delivery_batch_status == 'delivering'"
                       decoration-success="delivery_batch_status == 'done'"
                       decoration-muted="delivery_batch_status == 'cancelled'"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_picking_batch_search_wujia_delivery" model="ir.ui.view">
        <field name="name">stock.picking.batch.search.wujia.delivery</field>
        <field name="model">stock.picking.batch</field>
        <field name="inherit_id" ref="stock_picking_batch.stock_picking_batch_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="vehicle_id"/>
                <field name="provider_id"/>
                <field name="fleet_type_id"/>
                <field name="pricelist_id"/>
            </xpath>
            <xpath expr="//filter[@name='draft']" position="after">
                <separator/>
                <filter string="Có xe" name="filter_has_vehicle"
                        domain="[('vehicle_id', '!=', False)]"/>
                <filter string="Vượt tải" name="filter_over_capacity"
                        domain="[('is_over_capacity', '=', True)]"/>
                <filter string="Đang giao" name="filter_delivering"
                        domain="[('delivery_batch_status', '=', 'delivering')]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Xe" name="group_vehicle"
                        context="{'group_by': 'vehicle_id'}"/>
                <filter string="Đội xe" name="group_provider"
                        context="{'group_by': 'provider_id'}"/>
                <filter string="Trạng thái điều phối" name="group_delivery_status"
                        context="{'group_by': 'delivery_batch_status'}"/>
            </xpath>
        </field>
    </record>

    <record id="action_stock_picking_batch_wujia_delivery" model="ir.actions.act_window">
        <field name="name">Batch Management</field>
        <field name="res_model">stock.picking.batch</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_has_vehicle': 1}</field>
    </record>

</odoo>
