<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wujia_fleet_management_form_delivery" model="ir.ui.view">
        <field name="name">wujia.fleet.management.form.delivery</field>
        <field name="model">wujia.fleet.management</field>
        <field name="inherit_id" ref="wujia_fleet.view_wujia_fleet_management_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_current_batch" type="object"
                        class="oe_stat_button" icon="fa-truck-fast"
                        invisible="not current_batch_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Batch hiện tại</span>
                        <span class="o_stat_value"><field name="current_batch_name"/></span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
