<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="layout_sidenav_notification"
              inherit_id="wujia_portal_layout.layout_sidenav"
              priority="55"
              name="Wujia Sidenav — Thông báo">
        <xpath expr="//ul[@id='main-menu-navigation']" position="inside">
            <li class="nav-item" id="nav_item_notification">
                <a href="/portal/notification" class="text-black">
                    <i class="feather icon-bell" aria-hidden="true"/>
                    <span class="menu-title">Thông báo</span>
                </a>
            </li>
        </xpath>
    </template>

</odoo>
