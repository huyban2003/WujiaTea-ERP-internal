<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="layout_top_navbar_bell_icon"
              inherit_id="wujia_portal_layout.layout_top_navbar"
              priority="30"
              name="Wujia Header — Notification bell (UI-13)">
        <xpath expr="//li[hasclass('dropdown-user')]" position="before">
            <li class="nav-item wujia-header-icon-item">
                <a class="nav-link wujia-header-icon-btn" href="/portal/notification"
                   aria-label="Notifications">
                    <i class="ficon feather icon-bell text-white"/>
                    <span class="badge badge-pill wujia-header-badge wujia-header-noti-count">0</span>
                </a>
            </li>
        </xpath>
    </template>

</odoo>
