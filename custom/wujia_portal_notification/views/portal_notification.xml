<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List ============== -->
    <template id="portal_notification_list" name="Wujia Portal — Notification List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Thông báo</t>
            <!-- Mobile — loại→icon/tone-màu; ưu tiên→badge (keys BA: normal/important/urgent) -->
            <t t-set="WJ_TONE" t-value="{'URG': 'red', 'GEN': 'cyan', 'PROMO': 'amber', 'SYS': 'violet', 'OTH': 'green'}"/>
            <t t-set="WJ_ICON" t-value="{'URG': 'icon-alert-triangle', 'GEN': 'icon-bell', 'PROMO': 'icon-gift', 'SYS': 'icon-settings', 'OTH': 'icon-info'}"/>
            <t t-set="WJ_PTAG" t-value="{'urgent': ('Cần làm', 'wujia-badge-success', 'icon-check-circle'), 'important': ('Quan trọng', 'wujia-badge-warning', 'icon-alert-triangle'), 'normal': ('Lưu ý', 'wujia-badge-info', 'icon-info')}"/>
            <!-- Desktop ≥992px — Figma PC_Notification_List (4683:101) -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="wj-pc-page-header">
                    <div>
                        <h1 class="wj-pc-page-header__title">Thông báo</h1>
                        <p class="wj-pc-page-header__crumb">Danh sách thông báo của cửa hàng đang thao tác.</p>
                    </div>
                    <div class="wj-pc-page-header__actions">
                        <button type="button" id="wj-noti-bulk-read" class="wj-pc-btn wj-pc-btn--primary">
                            <i class="feather icon-check-circle"/>Đánh dấu đã đọc
                        </button>
                    </div>
                </div>

                <!-- Bộ lọc — Figma 4683:101: 5 field 1 hàng, label nhỏ trên mỗi field -->
                <form method="get" action="/portal/notification" class="wj-pc-filterbar wj-pc-noti-filterbar">
                    <div class="wj-pc-noti-filter-row">
                        <div class="wj-pc-noti-field wj-pc-noti-field--grow">
                            <label>Tìm kiếm</label>
                            <span class="wj-pc-filter-search">
                                <i class="feather icon-search"/>
                                <input type="text" name="keyword" t-att-value="keyword or ''"
                                       placeholder="Nhập tiêu đề, mã thông báo..." class="wj-pc-filter-control"/>
                            </span>
                        </div>
                        <div class="wj-pc-noti-field wj-pc-noti-field--type">
                            <label>Loại thông báo</label>
                            <select name="type_id" class="wj-pc-filter-control">
                                <option value="">Tất cả</option>
                                <t t-foreach="types" t-as="tp">
                                    <option t-att-value="tp.id"
                                            t-att-selected="'selected' if type_id == tp.id else None"
                                            t-out="tp.name"/>
                                </t>
                            </select>
                        </div>
                        <div class="wj-pc-noti-field wj-pc-noti-field--status">
                            <label>Trạng thái</label>
                            <select name="unread" class="wj-pc-filter-control">
                                <option value="">Tất cả</option>
                                <option value="1" t-att-selected="'selected' if unread else None">Chưa đọc</option>
                            </select>
                        </div>
                        <div class="wj-pc-noti-field wj-pc-noti-field--date">
                            <label>Từ ngày</label>
                            <input type="date" name="date_from" t-att-value="date_from or ''" class="wj-pc-filter-control"/>
                        </div>
                        <div class="wj-pc-noti-field wj-pc-noti-field--date">
                            <label>Đến ngày</label>
                            <input type="date" name="date_to" t-att-value="date_to or ''" class="wj-pc-filter-control"/>
                        </div>
                        <input type="hidden" name="tab" t-att-value="tab"/>
                        <div class="wj-pc-noti-filter-actions">
                            <button type="submit" class="wj-pc-btn wj-pc-btn--primary">
                                <i class="feather icon-search"/>Tìm kiếm
                            </button>
                            <a href="/portal/notification" class="wj-pc-btn wj-pc-btn--secondary">Làm mới</a>
                        </div>
                    </div>
                </form>
                <!-- Quick chips: dưới filter card, trên bảng (Figma 4683:101 — strip riêng) -->
                <div class="wj-filter-chips wj-pc-noti-chips">
                    <a t-attf-href="/portal/notification#{('?keyword=' + keyword) if keyword else ''}"
                       t-attf-class="wj-filter-chip #{'is-active' if not unread and not priority else ''}">Tất cả</a>
                    <a t-attf-href="/portal/notification?unread=1#{('&amp;keyword=' + keyword) if keyword else ''}"
                       t-attf-class="wj-filter-chip #{'is-active' if unread else ''}">Chưa đọc</a>
                    <a t-attf-href="/portal/notification?priority=important#{('&amp;keyword=' + keyword) if keyword else ''}"
                       t-attf-class="wj-filter-chip #{'is-active' if priority == 'important' else ''}">Quan trọng</a>
                    <a t-attf-href="/portal/notification?priority=urgent#{('&amp;keyword=' + keyword) if keyword else ''}"
                       t-attf-class="wj-filter-chip #{'is-active' if priority == 'urgent' else ''}">Cần làm</a>
                </div>

                <!-- Bảng danh sách -->
                <div class="wj-pc-card">
                    <div class="wj-pc-card__head">
                        <div>
                            <h3 class="wj-pc-card__title wj-pc-card__title--sm">Danh sách thông báo</h3>
                            <p class="wj-pc-card__subtitle">Hiển thị thông báo còn hiệu lực, đúng đối tượng nhận.</p>
                        </div>
                        <span t-if="cnt_unread" class="wj-pc-badge wj-pc-badge--cancel"><t t-out="cnt_unread"/> chưa đọc</span>
                    </div>

                    <div t-if="not notifications" class="wj-pc-empty">
                        <span class="wj-pc-empty__icon"><i class="feather icon-bell"/></span>
                        <h3 class="wj-pc-empty__title">Không có thông báo</h3>
                        <p class="wj-pc-empty__sub">Không có thông báo nào khớp bộ lọc hiện tại.</p>
                    </div>

                    <table t-else="" class="wj-pc-table wj-pc-noti-table" id="wj-noti-table">
                        <thead>
                            <tr>
                                <th>Loại</th>
                                <th>Thông báo</th>
                                <th>Ngày gửi</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="notifications" t-as="n">
                                <t t-set="is_read" t-value="n.id in read_ids"/>
                                <tr t-attf-class="wj-pc-noti-row #{'' if is_read else 'wj-pc-noti-row--unread'}"
                                    t-att-data-noti-id="n.id">
                                    <td>
                                        <span class="wj-pc-noti-type-chip">
                                            <t t-if="n.type_id" t-out="n.type_id.name"/><t t-else="">—</t>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="wj-pc-noti-title-cell">
                                            <span t-attf-class="wj-pc-noti-title #{'' if is_read else 'wj-pc-noti-title--unread'}">
                                                <span t-if="not is_read" class="wj-pc-noti-dot"/>
                                                <t t-out="n.name"/>
                                            </span>
                                            <span t-if="n.summary" class="wj-pc-noti-summary" t-out="n.summary"/>
                                        </div>
                                    </td>
                                    <td class="wj-pc-td--muted" t-out="n.date and n.date.strftime('%d/%m/%Y') or '—'"/>
                                    <td>
                                        <span t-if="not is_read" class="wj-pc-badge wj-pc-badge--cancel">Chưa đọc</span>
                                        <span t-else="" class="wj-pc-badge wj-pc-badge--pending">Đã đọc</span>
                                        <span t-if="n.is_expired" class="wj-pc-badge wj-pc-badge--confirmed">Đã hết hiệu lực</span>
                                    </td>
                                    <td class="text-end">
                                        <a t-attf-href="/portal/notification/#{n.id}" class="wj-pc-link">Xem</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Pagination — pager keys của notification: page/page_count/page_previous/page_next -->
                    <div t-if="notifications and pager and pager.get('page_count', 0) &gt; 1" class="wj-pc-pagination">
                        <span class="wj-pc-pagination__count">
                            Hiển thị <t t-out="(pager['page']['num'] - 1) * page_size + 1"/>–<t t-out="min(pager['page']['num'] * page_size, total)"/> / <t t-out="total"/> thông báo
                        </span>
                        <a t-attf-href="/portal/notification?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}"
                           t-attf-class="wj-pc-page-btn #{'is-disabled' if pager['page']['num'] &lt;= 1 else ''}">Trước</a>
                        <t t-foreach="range(1, pager['page_count'] + 1)" t-as="pn">
                            <a t-attf-href="/portal/notification?page=#{pn}&amp;#{pager.get('querystring','')}"
                               t-attf-class="wj-pc-page-btn #{'is-active' if pn == pager['page']['num'] else ''}"
                               t-out="pn"/>
                        </t>
                        <a t-attf-href="/portal/notification?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}"
                           t-attf-class="wj-pc-page-btn #{'is-disabled' if pager['page']['num'] &gt;= pager['page_count'] else ''}">Sau</a>
                    </div>
                </div>
            </div>

            <!-- Mobile &lt;992px — Figma Screen_Notification_List_v9 (4651:686) -->
            <div class="d-lg-none wujia-mpage wujia-mnoti">
                <div class="wujia-mnoti-titlerow">
                    <h1 class="wujia-mnoti-title">Thông báo</h1>
                    <p class="wj-count-meta wujia-mnoti-count">
                        <t t-out="total"/> thông báo • <t t-out="cnt_unread"/> chưa đọc
                    </p>
                </div>

                <!-- Filter canonical 01-ChipSlide (Figma 4785:562) — keyword + chips (hidden unread) -->
                <form method="get" action="/portal/notification" class="wj-filter-card">
                    <input type="hidden" name="unread" t-att-value="unread or ''"/>
                    <div class="wj-filter-search">
                        <div class="wj-filter-search-field">
                            <i class="feather icon-search"/>
                            <input type="text" name="keyword" placeholder="Tìm mã / tiêu đề" t-att-value="keyword or ''"/>
                        </div>
                        <button type="submit" class="wj-filter-search-btn"><i class="feather icon-search"/></button>
                    </div>
                    <!-- Tất cả / Chưa đọc / Quan trọng / Cần làm — đều functional (keys BA) -->
                    <div class="wj-filter-chips">
                        <a t-attf-href="/portal/notification#{('?keyword=' + keyword) if keyword else ''}"
                           t-attf-class="wj-filter-chip #{'is-active' if not unread and not priority else ''}">Tất cả</a>
                        <a t-attf-href="/portal/notification?unread=1#{('&amp;keyword=' + keyword) if keyword else ''}"
                           t-attf-class="wj-filter-chip #{'is-active' if unread else ''}">Chưa đọc</a>
                        <a t-attf-href="/portal/notification?priority=important#{('&amp;keyword=' + keyword) if keyword else ''}"
                           t-attf-class="wj-filter-chip #{'is-active' if priority == 'important' else ''}">Quan trọng</a>
                        <a t-attf-href="/portal/notification?priority=urgent#{('&amp;keyword=' + keyword) if keyword else ''}"
                           t-attf-class="wj-filter-chip #{'is-active' if priority == 'urgent' else ''}">Cần làm</a>
                    </div>
                </form>

                <!-- List -->
                <div t-if="not notifications" class="wj-empty-state wj-empty-state--rich">
                    <span class="wj-empty-state-icon"/>
                    <p class="wj-empty-state-title">Chưa có thông báo</p>
                    <p class="wj-empty-state-sub">Hiện chưa có thông báo nào để hiển thị.</p>
                    <p class="wj-empty-state-sub">Thông báo từ HQ sẽ hiển thị tại đây khi có.</p>
                    <a t-if="keyword or unread" href="/portal/notification" class="wj-empty-state-btn">Xóa lọc</a>
                    <button t-else="" type="button" class="wj-empty-state-btn" onclick="window.location.reload()">Tải lại</button>
                </div>
                <div t-else="" class="wujia-mnoti-list">
                    <t t-foreach="notifications" t-as="n">
                        <t t-set="is_read" t-value="n.id in read_ids"/>
                        <!-- UI tạm: icon/màu theo loại + badge theo độ ưu tiên (derive field sẵn có; BA/controller tinh chỉnh sau) -->
                        <t t-set="tone" t-value="WJ_TONE.get(n.type_id.code, 'cyan')"/>
                        <t t-set="ticon" t-value="WJ_ICON.get(n.type_id.code, 'icon-bell')"/>
                        <t t-set="ptag" t-value="WJ_PTAG.get(n.priority)"/>
                        <a t-attf-href="/portal/notification/#{n.id}"
                           t-attf-class="wujia-mnoti-row #{'' if is_read else 'is-unread'}">
                            <span t-attf-class="wujia-mnoti-row-icon wujia-mnoti-tone-#{tone}">
                                <i t-attf-class="feather #{ticon}"/>
                            </span>
                            <span class="wujia-mnoti-row-main">
                                <span class="wujia-mnoti-row-title" t-out="n.name"/>
                                <span class="wujia-mnoti-row-source">
                                    <t t-out="n.type_id.name"/><t t-if="n.dispatch_number"> • <t t-out="n.dispatch_number"/></t>
                                </span>
                                <span class="wujia-mnoti-row-tags">
                                    <span t-if="ptag" t-attf-class="wujia-badge #{ptag[1]}">
                                        <i t-attf-class="feather #{ptag[2]}"/><t t-out="ptag[0]"/>
                                    </span>
                                    <span t-if="n.is_expired" class="wujia-badge wujia-badge-muted">
                                        <i class="feather icon-clock"/>Đã hết hiệu lực
                                    </span>
                                    <span t-if="n.attachment_ids" class="wujia-badge wujia-badge-info">
                                        <i class="feather icon-paperclip"/>Có file
                                    </span>
                                </span>
                            </span>
                            <span class="wujia-mnoti-row-side">
                                <span t-if="not is_read" class="wujia-mnoti-row-dot"/>
                                <span class="wujia-mnoti-row-date"
                                      t-out="n.date and n.date.strftime('%d/%m/%Y · %H:%M') or ''"/>
                            </span>
                        </a>
                    </t>
                </div>

                <!-- Pager gọn -->
                <div t-if="pager and pager.get('page_count', 0) &gt; 1" class="wujia-mnoti-pager">
                    <a t-if="pager['page']['num'] &gt; 1"
                       t-attf-href="/portal/notification?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}"
                       class="wujia-mnoti-pager-btn">‹</a>
                    <span>Trang <t t-out="pager['page']['num']"/>/<t t-out="pager['page_count']"/></span>
                    <a t-if="pager['page']['num'] &lt; pager['page_count']"
                       t-attf-href="/portal/notification?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}"
                       class="wujia-mnoti-pager-btn">›</a>
                </div>
            </div>
        </t>
    </template>

    <!-- ============== Detail ============== -->
    <template id="portal_notification_detail" name="Wujia Portal — Notification Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="noti.name"/>
            <!-- UI tạm (mobile) — map loại→icon/tone/mô tả + ưu tiên→badge; controller/BA wire sau -->
            <t t-set="WJ_TONE" t-value="{'URG': 'red', 'GEN': 'cyan', 'PROMO': 'amber', 'SYS': 'violet', 'OTH': 'green'}"/>
            <t t-set="WJ_ICON" t-value="{'URG': 'icon-alert-triangle', 'GEN': 'icon-bell', 'PROMO': 'icon-gift', 'SYS': 'icon-settings', 'OTH': 'icon-info'}"/>
            <t t-set="WJ_TDESC" t-value="{'URG': 'Thông báo khẩn — cần xử lý ngay', 'GEN': 'Thông báo dành cho cửa hàng nhượng quyền', 'PROMO': 'Chương trình khuyến mãi &amp; ưu đãi', 'SYS': 'Thông báo hệ thống &amp; vận hành', 'OTH': 'Thông báo khác'}"/>
            <t t-set="WJ_PTAG" t-value="{'urgent': ('Cần làm', 'wujia-badge-success', 'icon-check-circle'), 'important': ('Quan trọng', 'wujia-badge-warning', 'icon-alert-triangle'), 'normal': ('Lưu ý', 'wujia-badge-info', 'icon-info')}"/>
            <!-- Desktop ≥992px — Figma PC_Notification_Form (4683:2) -->
            <div class="content-wrapper d-none d-lg-block">
                <t t-set="dptag" t-value="PC_PRIORITY_TAGS.get(noti.priority)"/>
                <div class="wj-pc-page-header">
                    <div>
                        <h1 class="wj-pc-page-header__title">Chi tiết thông báo</h1>
                        <p class="wj-pc-page-header__crumb">Thông báo / <t t-out="noti.name"/></p>
                    </div>
                    <div class="wj-pc-page-header__actions">
                        <a href="/portal/notification" class="wj-pc-btn wj-pc-btn--secondary">
                            <i class="feather icon-arrow-left"/>Quay lại danh sách
                        </a>
                    </div>
                </div>

                <div class="wj-pc-two-col">
                    <!-- Trái: nội dung thông báo -->
                    <div class="wj-pc-card">
                        <h3 class="wj-pc-card__title">Nội dung thông báo</h3>
                        <hr class="wj-pc-noti-rule"/>
                        <div class="wj-pc-noti-detail-badgerow">
                            <span t-if="dptag" t-attf-class="wj-pc-badge #{dptag[1]}" t-out="dptag[0]"/>
                            <span t-if="noti.type_id" class="wj-pc-badge wj-pc-badge--confirmed" t-out="noti.type_id.name"/>
                            <span t-if="noti.is_expired" class="wj-pc-badge wj-pc-badge--pending">Đã hết hiệu lực</span>
                        </div>
                        <h2 class="wj-pc-noti-detail-title" t-out="noti.name"/>
                        <p t-if="noti.priority == 'urgent'" class="wj-pc-noti-urgent-sub">
                            <i class="feather icon-alert-triangle"/>Thông báo khẩn — cần xử lý ngay
                        </p>
                        <div class="wj-pc-noti-detail-body" t-out="noti.content"/>
                    </div>

                    <!-- Phải: thông tin + tài liệu -->
                    <div class="wj-pc-noti-side">
                        <div class="wj-pc-card">
                            <div class="wj-pc-card__head">
                                <h3 class="wj-pc-card__title wj-pc-card__title--sm">Thông tin thông báo</h3>
                            </div>
                            <div class="wj-pc-kv-grid wj-pc-kv-grid--single">
                                <div class="wj-pc-kv">
                                    <span class="wj-pc-kv__label">Mã thông báo</span>
                                    <span class="wj-pc-kv__value" t-out="noti.dispatch_number or '—'"/>
                                </div>
                                <div class="wj-pc-kv">
                                    <span class="wj-pc-kv__label">Loại thông báo</span>
                                    <span class="wj-pc-kv__value">
                                        <t t-out="noti.type_id.name if noti.type_id else '—'"/><t t-if="dptag"> / <t t-out="dptag[0]"/></t>
                                    </span>
                                </div>
                                <div class="wj-pc-kv">
                                    <span class="wj-pc-kv__label">Ngày gửi</span>
                                    <span class="wj-pc-kv__value" t-out="noti.date and noti.date.strftime('%d/%m/%Y · %H:%M') or '—'"/>
                                </div>
                            </div>
                        </div>

                        <div t-if="noti.attachment_ids" class="wj-pc-card">
                            <div class="wj-pc-card__head">
                                <h3 class="wj-pc-card__title wj-pc-card__title--sm">Tài liệu đính kèm</h3>
                            </div>
                            <div class="wj-pc-noti-attach-list">
                                <t t-foreach="noti.attachment_ids" t-as="att">
                                    <div class="wj-pc-noti-attach-row">
                                        <span class="wj-pc-noti-attach-icon"><i class="feather icon-file-text"/></span>
                                        <div class="wj-pc-noti-attach-main">
                                            <span class="wj-pc-noti-attach-name" t-out="att.name"/>
                                            <span class="wj-pc-noti-attach-meta">
                                                <t t-out="(att.mimetype or '').split('/')[-1].upper() or 'FILE'"/> · <t t-out="'%.0f KB' % ((att.file_size or 0) / 1024.0)"/>
                                            </span>
                                        </div>
                                        <a t-attf-href="/portal/notification/#{noti.id}/attachment/#{att.id}"
                                           class="wj-pc-btn wj-pc-btn--primary wj-pc-noti-attach-dl">
                                            <i class="feather icon-download"/>Tải xuống
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile &lt;992px — Figma Screen_Notification_Detail_v9 (4651:825) -->
            <div class="d-lg-none wujia-mpage wujia-mnoti-detail">
                <div class="wujia-mnoti-detail-head">
                    <a href="/portal/notification" class="wujia-mnoti-back">
                        <i class="feather icon-chevron-left"/>
                    </a>
                    <div class="wujia-mnoti-detail-headmain">
                        <h1 class="wujia-mnoti-detail-title">Chi tiết thông báo</h1>
                        <p class="wujia-mnoti-detail-sub">
                            <t t-if="noti.dispatch_number"><t t-out="noti.dispatch_number"/> • </t>
                            <t t-out="noti.date and noti.date.strftime('%d/%m/%Y %H:%M') or ''"/>
                        </p>
                    </div>
                </div>

                <div class="wujia-mnoti-detail-card">
                    <div t-if="noti.type_id" class="wujia-mnoti-detail-typerow">
                        <t t-set="dtone" t-value="WJ_TONE.get(noti.type_id.code, 'cyan')"/>
                        <span t-attf-class="wujia-mnoti-detail-typeicon wujia-mnoti-tone-#{dtone}">
                            <i t-attf-class="feather #{WJ_ICON.get(noti.type_id.code, 'icon-bell')}"/>
                        </span>
                        <span class="wujia-mnoti-detail-typemeta">
                            <span class="wujia-mnoti-detail-typename" t-out="noti.type_id.name"/>
                            <t t-set="tdesc" t-value="WJ_TDESC.get(noti.type_id.code)"/>
                            <span t-if="tdesc" class="wujia-mnoti-detail-typedesc" t-out="tdesc"/>
                        </span>
                    </div>
                    <div class="wujia-mnoti-detail-divider"/>

                    <h2 class="wujia-mnoti-detail-name" t-out="noti.name"/>
                    <t t-set="dptag" t-value="WJ_PTAG.get(noti.priority)"/>
                    <div class="wujia-mnoti-detail-badges">
                        <span t-if="dptag" t-attf-class="wujia-badge #{dptag[1]}">
                            <i t-attf-class="feather #{dptag[2]}"/><t t-out="dptag[0]"/>
                        </span>
                        <span t-if="noti.is_expired" class="wujia-badge wujia-badge-muted">
                            <i class="feather icon-clock"/>Đã hết hiệu lực
                        </span>
                        <span t-if="noti.attachment_ids" class="wujia-badge wujia-badge-info">
                            <i class="feather icon-paperclip"/>Có file
                        </span>
                    </div>

                    <!-- BA FINAL: view form chỉ render field HTML content — không tách block
                         "Liên kết liên quan" (link nằm trong content). -->
                    <div class="wujia-mnoti-detail-body" t-out="noti.content"/>

                    <t t-if="noti.attachment_ids">
                        <h3 class="wujia-mnoti-detail-sectitle">File đính kèm</h3>
                        <div class="wujia-mnoti-detail-files">
                            <a t-foreach="noti.attachment_ids" t-as="att"
                               t-attf-href="/portal/notification/#{noti.id}/attachment/#{att.id}"
                               class="wujia-mnoti-detail-file">
                                <span class="wujia-mnoti-detail-file-icon"><i class="feather icon-file-text"/></span>
                                <span class="wujia-mnoti-detail-file-main">
                                    <span class="wujia-mnoti-detail-file-name" t-out="att.name"/>
                                    <span class="wujia-mnoti-detail-file-meta">
                                        <t t-out="(att.mimetype or '').split('/')[-1].upper() or 'FILE'"/> · <t t-out="'%.0f KB' % ((att.file_size or 0) / 1024.0)"/>
                                    </span>
                                </span>
                                <span class="wujia-mnoti-detail-file-dl"><i class="feather icon-download"/></span>
                            </a>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

</odoo>
