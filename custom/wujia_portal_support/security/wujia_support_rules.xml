<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal user sees only tickets they created AND that are portal_visible.
         HQ (internal users) see everything. -->
    <record id="rule_wujia_support_ticket_portal_own" model="ir.rule">
        <field name="name">Wujia Support Ticket — Portal own visible</field>
        <field name="model_id" ref="model_wujia_support_ticket"/>
        <field name="domain_force">[('created_by_id', '=', user.id), ('portal_visible', '=', True)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_wujia_support_ticket_internal_all" model="ir.rule">
        <field name="name">Wujia Support Ticket — Internal see all</field>
        <field name="model_id" ref="model_wujia_support_ticket"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
