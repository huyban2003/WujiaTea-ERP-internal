<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Category — list (editable inline)
    ============================================================ -->
    <record id="view_support_category_list" model="ir.ui.view">
        <field name="name">wujia.support.category.list</field>
        <field name="model">wujia.support.category</field>
        <field name="arch" type="xml">
            <list string="Support categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="default_assigned_user_id" optional="show"/>
                <field name="default_assigned_team_id" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_support_category" model="ir.actions.act_window">
        <field name="name">Support categories</field>
        <field name="res_model">wujia.support.category</field>
        <field name="view_mode">list</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <!-- ============================================================
         Ticket — form view
    ============================================================ -->
    <record id="view_support_ticket_form" model="ir.ui.view">
        <field name="name">wujia.support.ticket.form</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_in_progress" type="object"
                            string="Take" class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_set_waiting_customer" type="object"
                            string="Wait for customer"
                            invisible="state not in ('new', 'in_progress')"/>
                    <button name="action_set_resolved" type="object"
                            string="Resolve" class="btn-success"
                            invisible="state not in ('new', 'in_progress', 'waiting_customer')"/>
                    <button name="action_set_closed" type="object"
                            string="Close"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state == 'cancelled'"
                            confirm="Cancel this ticket? Provide a cancel reason first."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,in_progress,waiting_customer,resolved,closed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Cancelled"
                            invisible="state != 'cancelled'" bg_color="text-bg-danger"/>
                    <widget name="web_ribbon" title="Archived"
                            invisible="active" bg_color="text-bg-secondary"/>
                    <div class="oe_button_box" name="button_box">
                        <field name="message_count" invisible="1"/>
                        <field name="attachment_count" invisible="1"/>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Ticket code"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="title" placeholder="Ticket title..."/></h2>
                    </div>
                    <group>
                        <group string="Origin">
                            <field name="franchise_id"/>
                            <field name="store_partner_id" readonly="1"/>
                            <field name="created_by_id"/>
                            <field name="created_by_role" readonly="1"/>
                            <field name="open_date" readonly="1"/>
                        </group>
                        <group string="Classification">
                            <field name="category_id"/>
                            <field name="priority" widget="priority"/>
                            <field name="portal_visible"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <group string="Linked records">
                            <field name="sale_order_id"
                                   options="{'no_create': True}"/>
                            <field name="picking_batch_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Assignment">
                            <field name="assigned_user_id"/>
                            <field name="assigned_team_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Analytics">
                            <field name="last_message_date" readonly="1"/>
                            <field name="last_response_by" readonly="1"/>
                            <field name="need_customer_reply" readonly="1"
                                   invisible="not need_customer_reply"/>
                        </group>
                        <group string="Timeline">
                            <field name="in_progress_date" readonly="1"
                                   invisible="not in_progress_date"/>
                            <field name="resolved_date" readonly="1"
                                   invisible="not resolved_date"/>
                            <field name="closed_date" readonly="1"
                                   invisible="not closed_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                        <page string="Internal note" name="internal_note"
                              groups="base.group_user">
                            <field name="internal_note" nolabel="1"
                                   placeholder="HQ-only notes, not visible on portal..."/>
                        </page>
                        <page string="Cancellation" name="cancel_reason"
                              invisible="state != 'cancelled' and not cancel_reason">
                            <field name="cancel_reason" nolabel="1"
                                   placeholder="Reason for cancellation..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Ticket — list view
    ============================================================ -->
    <record id="view_support_ticket_list" model="ir.ui.view">
        <field name="name">wujia.support.ticket.list</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <list string="Support tickets"
                  decoration-info="state == 'new'"
                  decoration-warning="state == 'in_progress' or need_customer_reply"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state in ('closed', 'cancelled')"
                  decoration-danger="need_customer_reply">
                <field name="name" string="Code"/>
                <field name="title"/>
                <field name="franchise_id"/>
                <field name="created_by_id"/>
                <field name="category_id"/>
                <field name="priority" widget="priority"/>
                <field name="assigned_user_id" string="Assigned to"/>
                <field name="last_message_date" optional="show"/>
                <field name="need_customer_reply" optional="hide"/>
                <field name="create_date" string="Opened" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'new'"
                       decoration-warning="state == 'in_progress' or state == 'waiting_customer'"
                       decoration-success="state == 'resolved'"
                       decoration-muted="state in ('closed', 'cancelled')"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         Ticket — kanban view (grouped by state)
    ============================================================ -->
    <record id="view_support_ticket_kanban" model="ir.ui.view">
        <field name="name">wujia.support.ticket.kanban</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="title"/>
                <field name="franchise_id"/>
                <field name="created_by_id"/>
                <field name="category_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="assigned_user_id"/>
                <field name="need_customer_reply"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="title"/>
                                        </strong>
                                    </div>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <span class="text-muted">
                                        <i class="fa fa-building-o" title="Franchise"/>
                                        <field name="franchise_id"/>
                                    </span>
                                    <br/>
                                    <span class="text-muted small">
                                        <field name="category_id"/>
                                    </span>
                                    <span t-if="record.need_customer_reply.raw_value"
                                          class="badge text-bg-danger ms-1">
                                        Waiting
                                    </span>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="text-muted small">
                                            <field name="name"/>
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="assigned_user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         Ticket — search view
    ============================================================ -->
    <record id="view_support_ticket_search" model="ir.ui.view">
        <field name="name">wujia.support.ticket.search</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Code"/>
                <field name="title"/>
                <field name="franchise_id"/>
                <field name="created_by_id"/>
                <field name="assigned_user_id"/>
                <field name="category_id"/>
                <field name="sale_order_id"/>
                <field name="picking_batch_id"/>
                <separator/>
                <filter string="New" name="state_new"
                        domain="[('state', '=', 'new')]"/>
                <filter string="In progress" name="state_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Waiting customer" name="state_waiting_customer"
                        domain="[('state', '=', 'waiting_customer')]"/>
                <filter string="Resolved" name="state_resolved"
                        domain="[('state', '=', 'resolved')]"/>
                <filter string="Closed" name="state_closed"
                        domain="[('state', '=', 'closed')]"/>
                <filter string="Cancelled" name="state_cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Unassigned" name="filter_unassigned"
                        domain="[('assigned_user_id', '=', False), ('state', 'in', ['new', 'in_progress'])]"/>
                <filter string="Assigned to me" name="filter_my_tickets"
                        domain="[('assigned_user_id', '=', uid)]"/>
                <filter string="Need customer reply" name="filter_need_reply"
                        domain="[('need_customer_reply', '=', True)]"/>
                <filter string="Urgent" name="filter_urgent"
                        domain="[('priority', '=', 'urgent')]"/>
                <group name="group_by">
                    <filter string="State" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Franchise" name="group_franchise"
                            context="{'group_by': 'franchise_id'}"/>
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                    <filter string="Assigned to" name="group_assigned"
                            context="{'group_by': 'assigned_user_id'}"/>
                    <filter string="Team" name="group_team"
                            context="{'group_by': 'assigned_team_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Actions
    ============================================================ -->
    <record id="action_support_ticket" model="ir.actions.act_window">
        <field name="name">Support tickets</field>
        <field name="res_model">wujia.support.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_support_ticket_search"/>
        <field name="context">{'search_default_state_new': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ticket yet!
            </p>
            <p>Support requests from franchise stores will appear here.</p>
        </field>
    </record>

    <record id="action_support_ticket_all" model="ir.actions.act_window">
        <field name="name">All tickets</field>
        <field name="res_model">wujia.support.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_support_ticket_search"/>
    </record>

    <!-- ============================================================
         Menu items
    ============================================================ -->
    <menuitem id="menu_wujia_support_root"
              name="Hỗ Trợ"
              parent="wujia_franchise.menu_wujia_root"
              sequence="50"/>

    <menuitem id="menu_wujia_support_tickets"
              name="Ticket hỗ trợ"
              parent="menu_wujia_support_root"
              action="action_support_ticket"
              sequence="10"/>

    <menuitem id="menu_wujia_support_tickets_all"
              name="Tất cả ticket"
              parent="menu_wujia_support_root"
              action="action_support_ticket_all"
              sequence="20"/>

    <menuitem id="menu_wujia_support_categories"
              name="Danh mục ticket"
              parent="menu_wujia_support_root"
              action="action_support_category"
              sequence="30"/>

</odoo>
