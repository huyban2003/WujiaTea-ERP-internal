<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Ticket — form view (with chatter + action buttons)
    ============================================================ -->

    <record id="view_support_ticket_form" model="ir.ui.view">
        <field name="name">wujia.support.ticket.form</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_in_progress" type="object"
                            string="Nhận xử lý" class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_set_resolved" type="object"
                            string="Đã giải quyết" class="btn-success"
                            invisible="state not in ('new', 'in_progress')"/>
                    <button name="action_set_closed" type="object"
                            string="Đóng ticket" class="btn-secondary"
                            invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Mã ticket"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="subject" placeholder="Tiêu đề yêu cầu..."/></h2>
                    </div>
                    <group>
                        <group string="Thông tin yêu cầu">
                            <field name="franchise_id"/>
                            <field name="user_id" string="Người gửi"/>
                            <field name="category"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Xử lý">
                            <field name="handler_user_id" string="Người xử lý (HQ)"
                                   domain="[('share', '=', False)]"/>
                            <field name="resolved_date" string="Ngày giải quyết"
                                   invisible="state not in ('resolved', 'closed')"/>
                            <field name="create_date" string="Ngày gửi" readonly="1"/>
                        </group>
                    </group>
                    <group string="Mô tả">
                        <field name="description" nolabel="1" readonly="1"/>
                    </group>
                    <group string="File đính kèm">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Ticket — list view
    ============================================================ -->

    <record id="view_support_ticket_list" model="ir.ui.view">
        <field name="name">wujia.support.ticket.list</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <list string="Ticket hỗ trợ"
                  decoration-info="state == 'new'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'closed'">
                <field name="name" string="Mã"/>
                <field name="subject"/>
                <field name="franchise_id"/>
                <field name="user_id" string="Người gửi"/>
                <field name="category"/>
                <field name="priority" widget="priority"/>
                <field name="handler_user_id" string="Xử lý bởi"/>
                <field name="create_date" string="Ngày gửi"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'new'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'resolved'"
                       decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         Ticket — kanban view (grouped by state)
    ============================================================ -->

    <record id="view_support_ticket_kanban" model="ir.ui.view">
        <field name="name">wujia.support.ticket.kanban</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="subject"/>
                <field name="franchise_id"/>
                <field name="user_id"/>
                <field name="category"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="handler_user_id"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="subject"/>
                                        </strong>
                                    </div>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <span class="text-muted">
                                        <i class="fa fa-building-o"/> <field name="franchise_id"/>
                                    </span>
                                    <br/>
                                    <span class="text-muted small">
                                        <field name="category"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="text-muted small">
                                            <field name="name"/>
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         Ticket — search view
    ============================================================ -->

    <record id="view_support_ticket_search" model="ir.ui.view">
        <field name="name">wujia.support.ticket.search</field>
        <field name="model">wujia.support.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Mã ticket"/>
                <field name="subject" string="Tiêu đề"/>
                <field name="franchise_id"/>
                <field name="user_id" string="Người gửi"/>
                <field name="handler_user_id" string="Người xử lý"/>
                <separator/>
                <filter string="Mới" name="state_new"
                        domain="[('state', '=', 'new')]"/>
                <filter string="Đang xử lý" name="state_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Đã giải quyết" name="state_resolved"
                        domain="[('state', '=', 'resolved')]"/>
                <filter string="Đã đóng" name="state_closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="Chưa có người xử lý" name="unhandled"
                        domain="[('handler_user_id', '=', False), ('state', 'in', ['new', 'in_progress'])]"/>
                <filter string="Phân cho tôi" name="my_tickets"
                        domain="[('handler_user_id', '=', uid)]"/>
                <group name="group_by">
                    <filter string="Trạng thái" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Cửa hàng" name="group_franchise"
                            context="{'group_by': 'franchise_id'}"/>
                    <filter string="Phân loại" name="group_category"
                            context="{'group_by': 'category'}"/>
                    <filter string="Người xử lý" name="group_handler"
                            context="{'group_by': 'handler_user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Actions
    ============================================================ -->

    <record id="action_support_ticket" model="ir.actions.act_window">
        <field name="name">Ticket hỗ trợ</field>
        <field name="res_model">wujia.support.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_support_ticket_search"/>
        <field name="context">{'search_default_state_new': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có ticket nào!
            </p>
            <p>Ticket hỗ trợ từ cửa hàng nhượng quyền sẽ xuất hiện ở đây.</p>
        </field>
    </record>

    <record id="action_support_ticket_all" model="ir.actions.act_window">
        <field name="name">Tất cả ticket</field>
        <field name="res_model">wujia.support.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_support_ticket_search"/>
    </record>

    <!-- ============================================================
         Menu items
    ============================================================ -->

    <menuitem id="menu_wujia_support_root"
              name="Hỗ Trợ"
              parent="wujia_franchise.menu_wujia_root"
              sequence="50"/>

    <menuitem id="menu_wujia_support_tickets"
              name="Ticket hỗ trợ"
              parent="menu_wujia_support_root"
              action="action_support_ticket"
              sequence="10"/>

    <menuitem id="menu_wujia_support_tickets_all"
              name="Tất cả ticket"
              parent="menu_wujia_support_root"
              action="action_support_ticket_all"
              sequence="20"/>

</odoo>
