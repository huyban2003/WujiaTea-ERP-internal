<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List ============== -->
    <template id="portal_support_list" name="Wujia Portal — Support List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Yêu cầu hỗ trợ</t>
            <!-- ===== Desktop (>=992px) — GIỮ NGUYÊN 100%, chỉ bọc d-none d-lg-block (Sprint 16) ===== -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1 d-flex justify-content-between align-items-center flex-wrap">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-life-ring me-1" title="Support"/>Yêu cầu hỗ trợ
                        </h2>
                        <a href="/portal/support/new" class="btn btn-primary">
                            <i class="fa fa-plus me-1" title="New"/>Tạo yêu cầu mới
                        </a>
                    </div>
                </div>
                <div class="content-body">
                    <div class="card mb-2">
                        <div class="card-body p-2">
                            <form method="get" action="/portal/support" class="row g-2">
                                <div class="col-md-3 col-12">
                                    <label class="small text-muted mb-1">Trạng thái</label>
                                    <select name="state" class="form-select form-select-sm">
                                        <option value="">— Tất cả —</option>
                                        <t t-foreach="state_labels.items()" t-as="kv">
                                            <option t-att-value="kv[0]"
                                                    t-att-selected="'selected' if state == kv[0] else None"
                                                    t-out="kv[1][0]"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-9 col-12 text-end">
                                    <label class="small text-muted mb-1 d-block">&#160;</label>
                                    <button class="btn btn-primary btn-sm" type="submit">
                                        <i class="fa fa-search" title="Search"/> Lọc
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Tickets — MẪU 06 Card ticket (Sprint 9.13b 2026-05-27) -->
                    <div class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-life-buoy"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Yêu cầu hỗ trợ đang mở</h4>
                            <span t-if="tickets" class="wujia-content-card-header-link">
                                <t t-out="len(tickets)"/> ticket
                            </span>
                        </div>
                        <div t-if="not tickets" class="wujia-empty-state">
                            <i class="feather icon-life-buoy"/>
                            <p>Bạn chưa có ticket nào. <a href="/portal/support/new">Gửi yêu cầu hỗ trợ</a>.</p>
                        </div>
                        <table t-else="" class="wujia-content-card-table">
                            <thead>
                                <tr>
                                    <th>Mã yêu cầu</th>
                                    <th>Tiêu đề</th>
                                    <th>Phân loại</th>
                                    <th>Cửa hàng</th>
                                    <th>Ngày tạo</th>
                                    <th class="text-center">Ưu tiên</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th class="text-end"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="tickets" t-as="t">
                                    <td><a t-attf-href="/portal/support/#{t.id}" t-out="t.name"/></td>
                                    <td t-out="t.title"/>
                                    <td t-out="t.category_id.name or '—'"/>
                                    <td t-out="t.franchise_id.name or '—'"/>
                                    <td t-out="t.create_date and t.create_date.strftime('%d/%m/%Y') or ''"/>
                                    <td class="text-center">
                                        <t t-set="prio" t-value="priority_labels.get(t.priority, (t.priority, 'wujia-badge-muted'))"/>
                                        <span t-attf-class="wujia-badge #{prio[1]}" t-out="prio[0]"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-set="lbl" t-value="state_labels.get(t.state, (t.state, 'wujia-badge-muted'))"/>
                                        <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                    </td>
                                    <td class="text-end">
                                        <a t-attf-href="/portal/support/#{t.id}" class="btn btn-sm btn-primary">
                                            <i class="fa fa-eye" title="View"/>
                                        </a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="mt-2">
                        <ul class="pagination wujia-pagination justify-content-center mb-0">
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/support?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                            </li>
                            <li class="page-item active">
                                <span class="page-link"><t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/support?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
            <!-- /desktop -->

            <!-- ===== Mobile (<992px) — Sprint 17, Figma Mobile_Ticket (List + Empty).
                 BlankShell .wujia-mpage, đặt NGOÀI .content-wrapper (pattern S15).
                 Thay khối hub dashboard SAI của Sprint 16 (đã gộp về Home /portal). -->
            <div class="d-lg-none wujia-mpage wujia-mticket">
                <!-- Top row: tiêu đề + nút Tạo -->
                <div class="wujia-mticket-toprow">
                    <h1 class="wujia-mticket-h1">Hỗ trợ / Ticket</h1>
                    <a href="/portal/support/new" class="wujia-mticket-create-pill">
                        <i class="feather icon-plus"/> Tạo
                    </a>
                </div>

                <!-- Empty state thật sự (chưa có ticket nào, không lọc/tìm) — Figma màn 4 -->
                <t t-if="not tickets and not q and not state">
                    <div class="wujia-mdash-card wj-empty-state--rich">
                        <span class="wj-empty-state-icon"><i class="feather icon-help-circle"/></span>
                        <p class="wj-empty-state-title">Chưa có yêu cầu hỗ trợ nào</p>
                        <p class="wj-empty-state-sub">Tạo ticket đầu tiên để Wujia tiếp nhận xử lý</p>
                        <a href="/portal/support/new" class="wujia-mticket-create-pill">
                            <i class="feather icon-plus"/> Tạo ticket
                        </a>
                    </div>
                </t>
                <t t-else="">
                    <!-- Search card (functional GET q; giữ state qua hidden) -->
                    <form method="get" action="/portal/support" class="wujia-mknow-card wujia-mknow-search">
                        <div class="wujia-mknow-search-field">
                            <i class="feather icon-search"/>
                            <input type="text" name="q" class="wujia-mknow-search-input"
                                   placeholder="Tìm mã / tiêu đề ticket" t-att-value="q or ''"/>
                        </div>
                        <input type="hidden" name="state" t-att-value="state or ''"/>
                        <button type="submit" class="wujia-mknow-search-btn">Tìm</button>
                    </form>

                    <!-- Chips lọc trạng thái (scroll-x, active solid cyan).
                         NOTE BA: resolved/closed vẫn hiện trong list nhưng không có chip riêng. -->
                    <div class="wj-filter-chips">
                        <a href="/portal/support"
                           t-attf-class="wj-filter-chip #{'is-active' if not state else ''}">Tất cả</a>
                        <a href="/portal/support?state=new"
                           t-attf-class="wj-filter-chip #{'is-active' if state == 'new' else ''}">Mới</a>
                        <a href="/portal/support?state=in_progress"
                           t-attf-class="wj-filter-chip #{'is-active' if state == 'in_progress' else ''}">Đang xử lý</a>
                        <a href="/portal/support?state=waiting_customer"
                           t-attf-class="wj-filter-chip #{'is-active' if state == 'waiting_customer' else ''}">Có phản hồi</a>
                    </div>

                    <!-- Danh sách ticket / không tìm thấy -->
                    <div t-if="not tickets" class="wujia-mdash-card wj-empty-state--compact">
                        Không tìm thấy ticket phù hợp.
                    </div>
                    <div t-else="" class="wujia-mdash-card wujia-mdash-list">
                        <a t-foreach="tickets" t-as="tk" t-attf-href="/portal/support/#{tk.id}"
                           class="wujia-mdash-row">
                            <span class="wujia-mdash-row-main">
                                <span class="wujia-mdash-row-sub is-primary" t-out="tk.name"/>
                                <span class="wujia-mdash-row-title is-sm" t-out="tk.title"/>
                                <span t-if="tk.category_id" class="wujia-mticket-tag" t-out="tk.category_id.name"/>
                            </span>
                            <span class="wujia-mticket-rowside">
                                <t t-set="lbl" t-value="m_ticket_badges.get(tk.state, (tk.state, 'wujia-badge-muted'))"/>
                                <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                <span class="wujia-mdash-row-sub"
                                      t-out="tk.create_date and tk.create_date.strftime('%d/%m') or ''"/>
                            </span>
                        </a>
                    </div>

                    <nav t-if="pager and pager.get('page_count', 0) &gt; 1">
                        <ul class="pagination wujia-pagination justify-content-center mb-0">
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/support?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                            </li>
                            <li class="page-item active">
                                <span class="page-link"><t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/support?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                            </li>
                        </ul>
                    </nav>
                </t>
            </div>
            <!-- /mobile -->
        </t>
    </template>

    <!-- ============== Form ============== -->
    <template id="portal_support_form" name="Wujia Portal — Support Form">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Tạo yêu cầu hỗ trợ</t>
            <!-- ===== Desktop (>=992px) — GIỮ NGUYÊN, bọc d-none d-lg-block (Sprint 17) ===== -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/support">Hỗ trợ</a></li>
                            <li class="breadcrumb-item active">Tạo mới</li>
                        </ol></nav>
                        <h2 class="content-header-title float-left mb-0">Tạo yêu cầu hỗ trợ</h2>
                    </div>
                </div>
                <div class="content-body">
                    <form method="post" action="/portal/support/new" enctype="multipart/form-data" class="card">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-md-6 col-12">
                                    <label class="form-label">Cửa hàng</label>
                                    <select name="franchise_id" class="form-select" required="required">
                                        <t t-foreach="franchises" t-as="f">
                                            <option t-att-value="f.id" t-out="f.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-3 col-12">
                                    <label class="form-label">Phân loại</label>
                                    <select name="category_id" class="form-select" required="required">
                                        <t t-foreach="categories" t-as="c">
                                            <option t-att-value="c.id" t-out="c.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-3 col-12">
                                    <label class="form-label">Mức độ</label>
                                    <select name="priority" class="form-select">
                                        <option value="normal" selected="selected">Bình thường</option>
                                        <option value="urgent">Khẩn</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Tiêu đề</label>
                                    <input type="text" name="title" class="form-control" required="required"
                                           placeholder="VD: Không đặt được đơn hàng số ..."/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Mô tả chi tiết</label>
                                    <textarea name="description" rows="6" class="form-control"
                                              placeholder="Mô tả chi tiết tình huống, các bước đã thử, screenshot..."/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">File đính kèm (tùy chọn)</label>
                                    <input type="file" name="attachments" class="form-control" multiple="multiple"/>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer text-end">
                            <a href="/portal/support" class="btn btn-secondary me-2">Hủy</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-paper-plane me-1" title="Send"/>Gửi yêu cầu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- /desktop -->

            <!-- ===== Mobile (<992px) — Sprint 17, Figma Mobile_Ticket màn "Tạo yêu cầu hỗ trợ".
                 BlankShell .wujia-mpage, route POST /portal/support/new GIỮ NGUYÊN. -->
            <div class="d-lg-none wujia-mpage wujia-mticket">
                <a href="/portal/support" class="wujia-mticket-back">
                    <i class="feather icon-arrow-left"/> Hỗ trợ
                </a>
                <h1 class="wujia-mticket-h1">Tạo yêu cầu hỗ trợ</h1>

                <form method="post" action="/portal/support/new" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="wujia-mdash-card">
                        <p class="wujia-mdash-title mb-3">Thông tin ticket</p>

                        <label class="wujia-mticket-label">Loại yêu cầu</label>
                        <select name="category_id" class="form-select mb-3" required="required">
                            <option value="">Chọn loại yêu cầu</option>
                            <t t-foreach="categories" t-as="c">
                                <option t-att-value="c.id" t-out="c.name"/>
                            </t>
                        </select>

                        <label class="wujia-mticket-label">Tiêu đề</label>
                        <input type="text" name="title" class="form-control mb-3" required="required"
                               placeholder="Nhập tiêu đề ngắn gọn"/>

                        <label class="wujia-mticket-label">Nội dung chi tiết</label>
                        <textarea name="description" rows="4" class="form-control mb-3"
                                  placeholder="Mô tả vấn đề cần hỗ trợ, thời điểm phát sinh và mã chứng từ liên quan nếu có."/>

                        <label class="wujia-mticket-label">Mức độ ưu tiên</label>
                        <!-- BA: 'Gấp' và 'Khẩn cấp' đều map 'urgent' — model chưa có giá trị riêng cho 'Gấp' -->
                        <div class="wj-filter-chips mb-3">
                            <label class="wj-filter-chip">
                                <input type="radio" name="priority" value="normal" checked="checked"
                                       class="d-none"/> Bình thường
                            </label>
                            <label class="wj-filter-chip">
                                <input type="radio" name="priority" value="urgent" class="d-none"/> Gấp
                            </label>
                            <label class="wj-filter-chip">
                                <input type="radio" name="priority" value="urgent" class="d-none"/> Khẩn cấp
                            </label>
                        </div>

                        <label class="wujia-mticket-label">Tệp đính kèm</label>
                        <p class="wujia-mticket-hint">Thêm ảnh / file lỗi — PNG, JPG, PDF — tối đa 5 tệp</p>
                        <input type="file" name="attachments" class="form-control mb-1"
                               multiple="multiple" accept=".png,.jpg,.jpeg,.pdf"/>

                        <!-- Cửa hàng: 1 franchise → hidden; nhiều → select -->
                        <t t-if="franchises and len(franchises) == 1">
                            <input type="hidden" name="franchise_id" t-att-value="franchises[0].id"/>
                        </t>
                        <t t-elif="franchises">
                            <label class="wujia-mticket-label mt-3">Cửa hàng</label>
                            <select name="franchise_id" class="form-select" required="required">
                                <t t-foreach="franchises" t-as="f">
                                    <option t-att-value="f.id" t-out="f.name"/>
                                </t>
                            </select>
                        </t>
                    </div>

                    <p t-if="error == 'missing_fields'" class="text-danger small mt-2 mb-0">
                        Vui lòng điền đầy đủ thông tin bắt buộc.
                    </p>
                    <p t-if="error == 'invalid_franchise'" class="text-danger small mt-2 mb-0">
                        Cửa hàng không hợp lệ.
                    </p>

                    <button type="submit" class="btn btn-primary w-100 mt-3">Gửi yêu cầu hỗ trợ</button>
                </form>
            </div>
            <!-- /mobile -->
        </t>
    </template>

    <!-- ============== Detail ============== -->
    <template id="portal_support_detail" name="Wujia Portal — Support Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="ticket.name"/>
            <!-- ===== Desktop (>=992px) — GIỮ NGUYÊN, bọc d-none d-lg-block (Sprint 17) ===== -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/support">Hỗ trợ</a></li>
                            <li class="breadcrumb-item active" t-out="ticket.name"/>
                        </ol></nav>
                        <h2 class="content-header-title float-left mb-0 d-flex align-items-center">
                            <span class="me-2"><t t-out="ticket.name"/> — <t t-out="ticket.title"/></span>
                            <t t-set="lbl" t-value="state_labels.get(ticket.state, (ticket.state, 'wujia-badge-muted'))"/>
                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                        </h2>
                    </div>
                </div>
                <div class="content-body">
                    <div class="row">
                        <div class="col-md-8 col-12">
                            <div class="card mb-2">
                                <div class="card-header"><h5 class="mb-0">Nội dung yêu cầu</h5></div>
                                <div class="card-body">
                                    <div t-out="ticket.description or '—'"/>
                                </div>
                            </div>
                            <div t-if="ticket.attachment_ids" class="card mb-2">
                                <div class="card-header"><h6 class="mb-0">File đính kèm</h6></div>
                                <ul class="list-group list-group-flush">
                                    <li t-foreach="ticket.attachment_ids" t-as="att" class="list-group-item">
                                        <a t-attf-href="/web/content/ir.attachment/#{att.id}/datas?download=true">
                                            <i class="fa fa-paperclip me-1" title="Attachment"/><t t-out="att.name"/>
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Chatter — show comment messages, oldest first -->
                            <div class="card support-chatter mb-2">
                                <div class="card-header"><h6 class="mb-0">Trao đổi</h6></div>
                                <div class="card-body">
                                    <t t-set="comments" t-value="ticket.message_ids.filtered(lambda m: m.message_type == 'comment').sorted('date')"/>
                                    <div t-if="not comments" class="wujia-empty-state">
                                        <i class="feather icon-message-square"/>
                                        <p>Chưa có trao đổi.</p>
                                    </div>
                                    <div t-else="">
                                        <div t-foreach="comments" t-as="msg" class="mb-2 pb-2 border-bottom">
                                            <div class="d-flex justify-content-between">
                                                <strong t-out="msg.author_id.name or 'System'"/>
                                                <small class="text-muted" t-out="msg.date and msg.date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                            </div>
                                            <div t-out="msg.body"/>
                                        </div>
                                    </div>
                                </div>
                                <div t-if="ticket.state not in ('closed', 'cancelled')" class="card-footer">
                                    <form method="post" t-attf-action="/portal/support/#{ticket.id}/reply">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <textarea name="body" rows="3" class="form-control mb-2"
                                                  placeholder="Trả lời cho HQ..." required="required"/>
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <i class="fa fa-paper-plane me-1" title="Send"/>Gửi
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 col-12">
                            <div class="card">
                                <div class="card-header"><h6 class="mb-0">Thông tin</h6></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-5">Cửa hàng</dt>
                                        <dd class="col-7" t-out="ticket.franchise_id.name or '—'"/>
                                        <dt class="col-5">Phân loại</dt>
                                        <dd class="col-7" t-out="ticket.category_id.name or '—'"/>
                                        <dt class="col-5">Mức độ</dt>
                                        <dd class="col-7" t-out="dict(ticket._fields['priority'].selection).get(ticket.priority, ticket.priority)"/>
                                        <dt class="col-5">Ngày gửi</dt>
                                        <dd class="col-7" t-out="ticket.create_date and ticket.create_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <dt class="col-5">Người xử lý</dt>
                                        <dd class="col-7" t-out="ticket.assigned_user_id.name or '—'"/>
                                        <dt class="col-5">Ngày giải quyết</dt>
                                        <dd class="col-7" t-out="ticket.resolved_date and ticket.resolved_date.strftime('%d/%m/%Y') or '—'"/>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-2">
                        <a href="/portal/support" class="btn btn-secondary">
                            <i class="fa fa-arrow-left me-1" title="Back"/>Quay lại
                        </a>
                    </div>
                </div>
            </div>
            <!-- /desktop -->

            <!-- ===== Mobile (<992px) — Sprint 17, Figma Mobile_Ticket màn "Chi tiết ticket".
                 BlankShell .wujia-mpage. Bubble: khách = trái xám / Wujia Support = phải cyan.
                 Reply POST /portal/support/<id>/reply GIỮ NGUYÊN. -->
            <div class="d-lg-none wujia-mpage wujia-mticket">
                <a href="/portal/support" class="wujia-mticket-back">
                    <i class="feather icon-arrow-left"/> Chi tiết ticket
                </a>

                <!-- Header card: mã + badge + tiêu đề -->
                <div class="wujia-mdash-card">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="wujia-mdash-row-sub is-primary" t-out="ticket.name"/>
                        <t t-set="lbl" t-value="m_ticket_badges.get(ticket.state, (ticket.state, 'wujia-badge-muted'))"/>
                        <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                    </div>
                    <p class="wujia-mdash-row-title mb-0" style="white-space:normal;" t-out="ticket.title"/>
                </div>

                <!-- Meta grid -->
                <div class="wujia-mdash-card wujia-mdash-list">
                    <div class="wujia-mdash-row">
                        <span class="wujia-mdash-ico"><i class="feather icon-tag"/></span>
                        <span class="wujia-mdash-row-main">
                            <span class="wujia-mdash-row-sub">Nhóm</span>
                            <span class="wujia-mdash-row-sub is-strong" t-out="ticket.category_id.name or '—'"/>
                        </span>
                    </div>
                    <div class="wujia-mdash-row">
                        <span class="wujia-mdash-ico"><i class="feather icon-flag"/></span>
                        <span class="wujia-mdash-row-main">
                            <span class="wujia-mdash-row-sub">Ưu tiên</span>
                            <t t-set="prio" t-value="priority_labels.get(ticket.priority, (ticket.priority, ''))"/>
                            <span class="wujia-mdash-row-sub is-strong" t-out="prio[0]"/>
                        </span>
                    </div>
                    <div class="wujia-mdash-row">
                        <span class="wujia-mdash-ico"><i class="feather icon-user"/></span>
                        <span class="wujia-mdash-row-main">
                            <span class="wujia-mdash-row-sub">Người gửi</span>
                            <span class="wujia-mdash-row-sub is-strong" t-out="ticket.created_by_id.name or '—'"/>
                        </span>
                    </div>
                    <div class="wujia-mdash-row">
                        <span class="wujia-mdash-ico"><i class="feather icon-calendar"/></span>
                        <span class="wujia-mdash-row-main">
                            <span class="wujia-mdash-row-sub">Ngày tạo</span>
                            <span class="wujia-mdash-row-sub is-strong"
                                  t-out="ticket.create_date and ticket.create_date.strftime('%d/%m/%Y') or '—'"/>
                        </span>
                    </div>
                </div>

                <!-- Lịch sử trao đổi -->
                <t t-set="comments" t-value="ticket.message_ids.filtered(lambda m: m.message_type == 'comment').sorted('date')"/>
                <div class="wujia-mdash-card" style="padding:0;">
                    <div class="wujia-mdash-titlerow" style="padding:14px 14px 0;">
                        <h2 class="wujia-mdash-title" style="font-size:16px;">Lịch sử trao đổi</h2>
                        <span class="wujia-mdash-link" style="cursor:default;"><t t-out="len(comments)"/> phản hồi</span>
                    </div>
                    <div class="wujia-mticket-thread">
                        <div t-if="not comments" class="wj-empty-state--compact">Chưa có trao đổi nào.</div>
                        <t t-foreach="comments" t-as="msg">
                            <t t-set="is_customer" t-value="msg.author_id.id == ticket.created_by_id.partner_id.id"/>
                            <div t-attf-class="wujia-mticket-bubble #{'is-customer' if is_customer else 'is-hq'}"
                                 t-out="msg.body"/>
                            <div t-attf-class="wujia-mticket-bubble-meta #{'is-customer' if is_customer else 'is-hq'}">
                                <t t-out="msg.author_id.name or 'Wujia Support'"/> ·
                                <t t-out="msg.date and msg.date.strftime('%d/%m %H:%M') or ''"/>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Reply box (ẩn khi đóng / huỷ) -->
                <form t-if="ticket.state not in ('closed', 'cancelled')" method="post"
                      t-attf-action="/portal/support/#{ticket.id}/reply" class="wujia-mticket-reply">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <textarea name="body" class="wujia-mticket-reply-input mb-2"
                              placeholder="Nhập phản hồi thêm..." required="required"/>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="feather icon-send me-1"/>Gửi
                    </button>
                </form>
            </div>
            <!-- /mobile -->
        </t>
    </template>

</odoo>
