<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List ============== -->
    <template id="portal_knowledge_list" name="Wujia Portal — Knowledge List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Thư viện kiến thức</t>
            <!-- ===== Desktop (≥992px) — GIỮ NGUYÊN (Sprint 9.13b) ===== -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-book me-1"/>
                            <t t-if="current_category">
                                Kiến thức — <t t-out="current_category.name"/>
                            </t>
                            <t t-else="">Thư viện kiến thức</t>
                        </h2>
                    </div>
                </div>
                <div class="content-body">
                    <!-- Search bar -->
                    <div class="card mb-2">
                        <div class="card-body p-2">
                            <form method="get" action="/portal/knowledge" class="row g-2">
                                <div class="col-md-8 col-12">
                                    <input type="text" name="keyword" class="form-control form-control-sm"
                                           placeholder="Tìm bài viết..."
                                           t-att-value="keyword"/>
                                </div>
                                <div class="col-md-4 col-12 text-end">
                                    <button type="submit" class="btn btn-primary btn-sm me-1">
                                        <i class="fa fa-search"/>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Category nav -->
                        <div class="col-md-3 col-12 mb-2">
                            <div class="card">
                                <div class="card-header py-2"><h6 class="mb-0">Danh mục</h6></div>
                                <div class="list-group list-group-flush knowledge-cat-list">
                                    <a href="/portal/knowledge"
                                       t-attf-class="list-group-item list-group-item-action#{' active' if not category_id else ''}">
                                        <i class="fa fa-list me-1"/>Tất cả
                                    </a>
                                    <t t-foreach="categories" t-as="cat">
                                        <a t-attf-href="/portal/knowledge?category_id=#{cat.id}"
                                           t-attf-class="list-group-item list-group-item-action#{' active' if category_id == cat.id else ''}">
                                            <span t-out="cat.name"/>
                                            <span class="badge bg-light text-dark float-end" t-out="cat.article_count"/>
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Articles list — MẪU 04 Card danh sách + icon (Sprint 9.13b 2026-05-27) -->
                        <div class="col-md-9 col-12">
                            <div class="wujia-content-card">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-book"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">
                                        <t t-if="current_category" t-out="current_category.name"/>
                                        <t t-else="">Tài liệu mới cập nhật</t>
                                    </h4>
                                    <span t-if="articles" class="wujia-content-card-header-link">
                                        <t t-out="len(articles)"/> bài viết
                                    </span>
                                </div>
                                <div t-if="not articles" class="wujia-empty-state">
                                    <i class="feather icon-book"/>
                                    <p>Chưa có bài viết.</p>
                                </div>
                                <ul t-else="" class="wujia-content-card-body">
                                    <t t-foreach="articles" t-as="art">
                                        <t t-set="badge_cls" t-value="{'mandatory': 'wujia-badge-danger', 'important': 'wujia-badge-warning', 'new': 'wujia-badge-info'}.get(art.portal_badge, '')"/>
                                        <t t-set="badge_lbl" t-value="{'mandatory': 'Bắt buộc', 'important': 'Quan trọng', 'new': 'Mới'}.get(art.portal_badge, '')"/>
                                        <li class="wujia-content-card-row">
                                            <span class="wujia-content-card-row-bullet"/>
                                            <div class="wujia-content-card-row-content">
                                                <a t-attf-href="/portal/knowledge/#{art.slug}">
                                                    <t t-out="art.name"/>
                                                </a>
                                                <span t-if="art.category_id" class="wujia-badge wujia-badge-muted ms-1" t-out="art.category_id.name"/>
                                                <span t-if="badge_lbl" t-attf-class="wujia-badge #{badge_cls} ms-1" t-out="badge_lbl"/>
                                            </div>
                                            <span class="wujia-content-card-row-date">
                                                <t t-out="art.publish_date and art.publish_date.strftime('%d/%m/%Y') or ''"/>
                                                · <i class="fa fa-eye"/> <t t-out="art.view_count or 0"/>
                                            </span>
                                        </li>
                                    </t>
                                </ul>
                            </div>

                            <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="mt-3">
                                <ul class="pagination wujia-pagination justify-content-center mb-0">
                                    <li t-attf-class="page-item #{pager['page']['num'] == 1 and 'disabled' or ''}">
                                        <a class="page-link"
                                           t-attf-href="/portal/knowledge?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                                    </li>
                                    <t t-foreach="range(1, pager['page_count'] + 1)" t-as="pn">
                                        <li t-attf-class="page-item #{pn == pager['page']['num'] and 'active' or ''}">
                                            <a class="page-link"
                                               t-attf-href="/portal/knowledge?page=#{pn}&amp;#{pager.get('querystring','')}"
                                               t-out="pn"/>
                                        </li>
                                    </t>
                                    <li t-attf-class="page-item #{pager['page']['num'] == pager['page_count'] and 'disabled' or ''}">
                                        <a class="page-link"
                                           t-attf-href="/portal/knowledge?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
            <!-- /desktop -->

            <!-- ===== Mobile (<992px) — Sprint 15, Figma WJ_Knowledge_Mobile 4475:2 =====
                 Trang ĐẦU TIÊN dùng BlankShell .wujia-mpage (Sprint 14, BA 4447:11).
                 Đặt NGOÀI .content-wrapper: .wujia-mpage tự lo gutter (pad-x 16) —
                 lồng vào content-wrapper sẽ double padding ngang.
                 UI-only (chốt user 2026-06-12, wire backend sau):
                 - "N bài viết" = len(articles) trang hiện tại (TODO: search_count từ controller).
                 - "Bài nổi bật" = lọc portal_badge important/mandatory từ recordset đã fetch
                   (TODO: query controller riêng, không phụ thuộc trang/pagination).
                 - Icon bài viết: 1 icon chung icon-file-text (Figma vẽ icon riêng từng bài
                   — drift, chờ BA cấp field icon rồi đối chiếu). -->
            <div class="d-lg-none wujia-mpage wujia-mknow">
                <!-- Title row -->
                <div class="wujia-mknow-titlerow">
                    <h1 class="wujia-mknow-title">Kiến thức</h1>
                    <span class="wj-count-meta wj-count-meta--primary"><t t-out="len(articles)"/> bài viết</span>
                </div>

                <!-- Filter canonical 01-ChipSlide (Figma 4785:562) — keyword + category chips -->
                <form method="get" action="/portal/knowledge" class="wj-filter-card">
                    <div class="wj-filter-search">
                        <div class="wj-filter-search-field">
                            <i class="feather icon-search"/>
                            <input type="text" name="keyword" placeholder="Tìm kiếm bài viết..." t-att-value="keyword"/>
                        </div>
                        <button type="submit" class="wj-filter-search-btn"><i class="feather icon-search"/></button>
                    </div>
                    <div class="wj-filter-chips">
                        <a href="/portal/knowledge"
                           t-attf-class="wj-filter-chip#{'' if category_id else ' is-active'}">Tất cả</a>
                        <t t-foreach="categories" t-as="cat">
                            <a t-attf-href="/portal/knowledge?category_id=#{cat.id}"
                               t-attf-class="wj-filter-chip#{' is-active' if category_id == cat.id else ''}"
                               t-out="cat.name"/>
                        </t>
                    </div>
                </form>

                <div t-if="not articles" class="wj-empty-state wj-empty-state--rich">
                    <span class="wj-empty-state-icon"/>
                    <p class="wj-empty-state-title">Chưa có bài viết</p>
                    <p class="wj-empty-state-sub">Hiện chưa có bài viết nào để hiển thị.</p>
                    <p class="wj-empty-state-sub">Nội dung mới sẽ xuất hiện tại đây khi được cập nhật.</p>
                    <a t-if="keyword or category_id" href="/portal/knowledge" class="wj-empty-state-btn">Xóa lọc</a>
                    <button t-else="" type="button" class="wj-empty-state-btn" onclick="window.location.reload()">Tải lại</button>
                </div>
                <t t-else="">
                    <t t-set="m_featured" t-value="articles.filtered(lambda a: a.portal_badge in ('important', 'mandatory'))[:1]"/>
                    <t t-set="m_rest" t-value="articles - m_featured"/>
                    <!-- Badge map MOBILE — tách desktop (precedent MOBILE_STATE_BADGES S13):
                         important → danger (Figma đỏ hồng; desktop map warning — drift có
                         chủ đích, đối chiếu BA). -->
                    <t t-set="m_badge_cls" t-value="{'mandatory': 'wujia-badge-danger', 'important': 'wujia-badge-danger', 'new': 'wujia-badge-info'}"/>
                    <t t-set="m_badge_lbl" t-value="{'mandatory': 'Bắt buộc', 'important': 'Quan trọng', 'new': 'Mới'}"/>

                    <!-- Bài nổi bật -->
                    <t t-if="m_featured">
                        <div class="wujia-mknow-sechead">
                            <span class="wujia-mknow-sechead-title">Bài nổi bật</span>
                            <span class="wujia-mknow-sechead-sub">Ưu tiên đọc</span>
                        </div>
                        <t t-foreach="m_featured" t-as="art">
                            <a t-attf-href="/portal/knowledge/#{art.slug}" class="wujia-mknow-feat">
                                <span class="wujia-mknow-tile"><i class="feather icon-save"/></span>
                                <span class="wujia-mknow-feat-main">
                                    <span class="wujia-mknow-row-title" t-out="art.name"/>
                                    <span class="wujia-mknow-badges">
                                        <span t-if="m_badge_lbl.get(art.portal_badge)"
                                              t-attf-class="wujia-badge #{m_badge_cls.get(art.portal_badge)}"
                                              t-out="m_badge_lbl.get(art.portal_badge)"/>
                                        <span t-if="art.category_id" class="wujia-badge wujia-badge-info"
                                              t-out="art.category_id.name"/>
                                    </span>
                                    <span class="wujia-mknow-date">
                                        Cập nhật <t t-out="art.publish_date and art.publish_date.strftime('%d/%m/%Y') or ''"/>
                                    </span>
                                </span>
                            </a>
                        </t>
                    </t>

                    <!-- Mới cập nhật -->
                    <div class="wujia-mknow-sechead">
                        <span class="wujia-mknow-sechead-title">Mới cập nhật</span>
                        <span class="wujia-mknow-sechead-pill">Mới nhất</span>
                    </div>
                    <div class="wujia-mknow-list">
                        <t t-foreach="m_rest" t-as="art">
                            <a t-attf-href="/portal/knowledge/#{art.slug}" class="wujia-mknow-row">
                                <span class="wujia-mknow-tile"><i class="feather icon-file-text"/></span>
                                <span class="wujia-mknow-row-main">
                                    <span class="wujia-mknow-row-title" t-out="art.name"/>
                                    <span class="wujia-mknow-row-foot">
                                        <span class="wujia-mknow-badges">
                                            <span t-if="m_badge_lbl.get(art.portal_badge)"
                                                  t-attf-class="wujia-badge #{m_badge_cls.get(art.portal_badge)}"
                                                  t-out="m_badge_lbl.get(art.portal_badge)"/>
                                            <span t-if="art.category_id" class="wujia-badge wujia-badge-info"
                                                  t-out="art.category_id.name"/>
                                        </span>
                                        <span class="wujia-mknow-date">
                                            Cập nhật <t t-out="art.publish_date and art.publish_date.strftime('%d/%m/%Y') or ''"/>
                                        </span>
                                    </span>
                                </span>
                            </a>
                        </t>
                    </div>

                    <!-- Pager (alias style .wujia-mhist-pager — group selector) -->
                    <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="wujia-mknow-pager">
                        <a t-if="pager['page']['num'] &gt; 1"
                           t-attf-href="/portal/knowledge?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">‹</a>
                        <span>Trang <t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                        <a t-if="pager['page']['num'] &lt; pager['page_count']"
                           t-attf-href="/portal/knowledge?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">›</a>
                    </nav>
                </t>
            </div>
            <!-- /mobile -->
        </t>
    </template>

    <!-- ============== Detail ============== -->
    <template id="portal_knowledge_detail" name="Wujia Portal — Knowledge Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="article.name"/>
            <!-- ===== Desktop (≥992px) — GIỮ NGUYÊN ===== -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/knowledge">Kiến thức</a></li>
                            <li t-if="article.category_id" class="breadcrumb-item">
                                <a t-attf-href="/portal/knowledge?category_id=#{article.category_id.id}" t-out="article.category_id.name"/>
                            </li>
                            <li class="breadcrumb-item active" t-out="article.name"/>
                        </ol></nav>
                    </div>
                </div>

                <div class="content-body">
                    <div class="row">
                        <div class="col-lg-9 col-12">
                            <article class="card knowledge-detail">
                                <img t-if="article.cover_image"
                                     t-attf-src="/web/image/wujia.knowledge.article/#{article.id}/cover_image"
                                     class="card-img-top knowledge-detail-cover"
                                     t-att-alt="article.name"/>
                                <div class="card-body">
                                    <h1 class="article-title" t-out="article.name"/>
                                    <p class="text-muted small mb-3">
                                        <span t-if="article.author_id"><i class="fa fa-user me-1"/><t t-out="article.author_id.name"/></span>
                                        <span class="ms-3"><i class="fa fa-clock me-1"/><t t-out="article.publish_date and article.publish_date.strftime('%d/%m/%Y %H:%M') or ''"/></span>
                                        <span class="ms-3"><i class="fa fa-eye me-1"/><t t-out="article.view_count or 0"/> lượt xem</span>
                                    </p>
                                    <div class="article-content" t-out="article.content"/>
                                </div>
                            </article>
                        </div>

                        <div class="col-lg-3 col-12">
                            <div t-if="related" class="card">
                                <div class="card-header py-2"><h6 class="mb-0">Bài liên quan</h6></div>
                                <div class="list-group list-group-flush">
                                    <t t-foreach="related" t-as="r">
                                        <a t-attf-href="/portal/knowledge/#{r.slug}" class="list-group-item list-group-item-action py-2">
                                            <strong class="d-block small" t-out="r.name"/>
                                            <small class="text-muted" t-out="r.publish_date and r.publish_date.strftime('%d/%m/%Y') or ''"/>
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-2">
                        <a href="/portal/knowledge" class="btn btn-secondary">
                            <i class="fa fa-arrow-left me-1"/>Về thư viện
                        </a>
                    </div>
                </div>
            </div>
            <!-- /desktop -->

            <!-- ===== Mobile (<992px) — Sprint 15, Figma WJ_Knowledge_Mobile 4475:2 =====
                 Card xám "Các điểm cần nắm" / card cam "Lưu ý" trong mockup = NỘI DUNG
                 HTML mẫu admin soạn trong field content, KHÔNG phải field riêng. CSS
                 .wujia-mknow-body hỗ trợ sẵn: ul/li bullet cyan, blockquote → card xám,
                 div.wujia-note → card cam (admin thêm class trong editor HTML).
                 Related "Bài liên quan": Figma mobile KHÔNG có → chỉ desktop. -->
            <div class="d-lg-none wujia-mpage wujia-mknow">
                <div class="wujia-mknow-backrow">
                    <a href="/portal/knowledge" class="wujia-mknow-back" aria-label="Về thư viện">
                        <i class="feather icon-arrow-left"/>
                    </a>
                    <div class="wujia-mknow-backmeta">
                        <span class="wujia-mknow-eyebrow">Kiến thức</span>
                        <span class="wujia-mknow-crumb">
                            <t t-if="article.category_id"><t t-out="article.category_id.name"/> / </t>Bài viết
                        </span>
                    </div>
                </div>

                <article class="wujia-mknow-card wujia-mknow-article">
                    <h1 class="wujia-mknow-article-title" t-out="article.name"/>
                    <!-- Badge map mobile: important → danger (Figma đỏ; desktop warning — drift, đối chiếu BA) -->
                    <t t-set="m_badge_cls" t-value="{'mandatory': 'wujia-badge-danger', 'important': 'wujia-badge-danger', 'new': 'wujia-badge-info'}"/>
                    <t t-set="m_badge_lbl" t-value="{'mandatory': 'Bắt buộc', 'important': 'Quan trọng', 'new': 'Mới'}"/>
                    <div class="wujia-mknow-badges">
                        <span t-if="m_badge_lbl.get(article.portal_badge)"
                              t-attf-class="wujia-badge #{m_badge_cls.get(article.portal_badge)}"
                              t-out="m_badge_lbl.get(article.portal_badge)"/>
                        <span t-if="article.category_id" class="wujia-badge wujia-badge-info"
                              t-out="article.category_id.name"/>
                    </div>
                    <div class="wujia-mknow-meta">
                        <t t-if="article.author_id" t-out="article.author_id.name"/>
                        <t t-if="article.author_id and article.publish_date"> • </t>
                        <t t-if="article.publish_date">Cập nhật <t t-out="article.publish_date.strftime('%d/%m/%Y')"/></t>
                    </div>

                    <h2 class="wujia-mknow-h">Nội dung chính</h2>
                    <p t-if="article.summary" class="wujia-mknow-lead" t-out="article.summary"/>
                    <div class="wujia-mknow-body" t-out="article.content"/>

                    <t t-if="article.attachment_ids">
                        <h2 class="wujia-mknow-h">Tài liệu đính kèm</h2>
                        <t t-foreach="article.attachment_ids" t-as="att">
                            <t t-set="att_ext" t-value="att.name and '.' in att.name and att.name.rsplit('.', 1)[1].upper() or (att.mimetype or '').rsplit('/', 1)[-1].upper()"/>
                            <t t-set="att_size" t-value="att.file_size and (att.file_size &gt;= 1048576 and '%.1f MB' % (att.file_size / 1048576.0) or '%d KB' % max(1, att.file_size // 1024)) or ''"/>
                            <!-- Download THẬT (chốt user 2026-06-12) — route stream Sprint 15 -->
                            <a t-attf-href="/portal/knowledge/#{article.slug}/attachment/#{att.id}"
                               class="wujia-mknow-att">
                                <span class="wujia-mknow-tile"><i class="feather icon-file-text"/></span>
                                <span class="wujia-mknow-att-main">
                                    <span class="wujia-mknow-att-name" t-out="att.name"/>
                                    <span class="wujia-mknow-att-sub">
                                        <t t-out="att_ext"/><t t-if="att_size"> • <t t-out="att_size"/></t>
                                    </span>
                                </span>
                            </a>
                        </t>
                    </t>
                </article>
            </div>
            <!-- /mobile -->
        </t>
    </template>

</odoo>
