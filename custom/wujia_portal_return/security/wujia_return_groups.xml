<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_groups_privilege_return" model="res.groups.privilege">
        <field name="name">Wujia Return</field>
        <field name="category_id" ref="wujia_franchise.module_category_wujia"/>
        <field name="sequence">30</field>
    </record>

    <record id="group_return_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_return"/>
        <field name="comment">Xem yêu cầu bù hàng / đổi trả.</field>
    </record>

    <record id="group_return_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_return"/>
        <field name="implied_ids" eval="[(4, ref('group_return_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Duyệt/từ chối yêu cầu, cấu hình loại lỗi và sản phẩm bù.</field>
    </record>

</odoo>
