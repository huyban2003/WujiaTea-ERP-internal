<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_return_form" name="Wujia Portal — Return Form">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Tạo yêu cầu đổi trả</t>

            <!-- Desktop ≥992px — giữ nguyên, bọc d-none d-lg-block (S20) -->
            <div class="content-wrapper d-none d-lg-block">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'pc'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title">Tạo yêu cầu đổi trả</t>
                    <t t-set="ph_back_url" t-value="'/portal/return'"/>
                </t>

                <div class="content-body">
                    <form method="post" action="/portal/return/new" enctype="multipart/form-data" class="card">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-md-6 col-12">
                                    <label class="form-label">Cửa hàng</label>
                                    <select name="franchise_id" class="form-select" required="required">
                                        <t t-foreach="franchises" t-as="f">
                                            <option t-att-value="f.id" t-out="f.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6 col-12">
                                    <label class="form-label">Đơn hàng gốc</label>
                                    <select name="order_id" class="form-select">
                                        <option value="">— Không gắn đơn —</option>
                                        <t t-foreach="recent_orders" t-as="o">
                                            <option t-att-value="o.id">
                                                <t t-out="o.name"/> — <t t-out="o.date_order and o.date_order.strftime('%d/%m/%Y') or ''"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6 col-12">
                                    <label class="form-label">Loại lỗi</label>
                                    <select name="error_id" class="form-select" required="required">
                                        <option value="">— Chọn loại lỗi —</option>
                                        <t t-foreach="error_types" t-as="et">
                                            <option t-att-value="et.id" t-out="et.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6 col-12">
                                    <label class="form-label">Ngày giao dự kiến</label>
                                    <input type="date" name="expected_delivery_date" class="form-control"/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Mô tả / Ghi chú</label>
                                    <textarea name="note" rows="4" class="form-control"
                                              placeholder="Mô tả chi tiết tình trạng hàng cần đổi/trả..."/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Ảnh minh chứng (tối thiểu 3 ảnh)</label>
                                    <input type="file" name="images" class="form-control"
                                           accept="image/png,image/jpeg" multiple="multiple"/>
                                    <small class="text-muted">JPG/PNG, dung lượng &lt; 5MB/ảnh.</small>
                                    <div id="image-preview-grid" class="row g-2 mt-2"></div>
                                </div>
                            </div>

                            <hr class="my-3"/>
                            <h5>Sản phẩm cần đổi trả</h5>
                            <div class="table-responsive">
                                <table class="table" id="return-line-table">
                                    <thead>
                                        <tr><th>Sản phẩm</th><th class="text-end">Số lượng</th><th>Lý do dòng</th><th></th></tr>
                                    </thead>
                                    <tbody>
                                        <tr class="return-line-row">
                                            <td><input type="text" name="line_product_name[]" class="form-control" placeholder="Tên sản phẩm"/></td>
                                            <td><input type="number" name="line_qty[]" class="form-control text-end" min="1" value="1"/></td>
                                            <td><input type="text" name="line_reason[]" class="form-control"/></td>
                                            <td><button type="button" class="btn btn-sm btn-outline-danger btn-remove-line"><i class="fa fa-trash"/></button></td>
                                        </tr>
                                    </tbody>
                                </table>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="btn-add-line">
                                    <i class="fa fa-plus me-1"/>Thêm dòng
                                </button>
                            </div>
                        </div>
                        <div class="card-footer text-end">
                            <a href="/portal/return" class="btn btn-secondary me-2">Hủy</a>
                            <button type="submit" name="action" value="draft" class="btn btn-outline-primary me-2">Lưu nháp</button>
                            <button type="submit" name="action" value="send" class="btn btn-primary">
                                <i class="fa fa-paper-plane me-1"/>Gửi yêu cầu
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Mobile <992px — Figma 4449:203, BA FormScreen, single-product (S20) -->
            <div class="d-lg-none wujia-mpage wujia-mreturn">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'m'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title">Tạo yêu cầu đổi trả</t>
                    <t t-set="ph_back_url" t-value="'/portal/return'"/>
                </t>

                <div class="wujia-mreturn-banner">
                    <i class="feather icon-info"/>
                    <span>Mỗi yêu cầu chỉ áp dụng cho 1 sản phẩm trong đơn đặt.</span>
                </div>

                <p t-if="error" class="text-danger small mb-2" t-out="error"/>

                <form method="post" action="/portal/return/new" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <t t-if="franchises and len(franchises) == 1">
                        <input type="hidden" name="franchise_id" t-att-value="franchises[0].id"/>
                    </t>

                    <div class="wujia-mdash-card">
                        <p class="wujia-mdash-title mb-3">Thông tin đơn hàng</p>
                        <t t-if="franchises and len(franchises) &gt; 1">
                            <label class="wujia-mticket-label">Cửa hàng</label>
                            <select name="franchise_id" class="form-select mb-3" required="required">
                                <t t-foreach="franchises" t-as="f"><option t-att-value="f.id" t-out="f.name"/></t>
                            </select>
                        </t>
                        <label class="wujia-mticket-label">Đơn hàng gốc</label>
                        <select name="order_id" class="form-select mb-3">
                            <option value="">— Không gắn đơn —</option>
                            <t t-foreach="recent_orders" t-as="o">
                                <option t-att-value="o.id">
                                    <t t-out="o.name"/> — <t t-out="o.date_order and o.date_order.strftime('%d/%m/%Y') or ''"/>
                                </option>
                            </t>
                        </select>
                        <div class="wujia-mreturn-grid2">
                            <div>
                                <label class="wujia-mticket-label">Ngày yêu cầu</label>
                                <input type="text" class="form-control" disabled="disabled"
                                       t-att-value="today and today.strftime('%d/%m/%Y') or ''"/>
                            </div>
                            <div>
                                <label class="wujia-mticket-label">Giao dự kiến</label>
                                <input type="date" name="expected_delivery_date" class="form-control"/>
                            </div>
                        </div>
                    </div>

                    <div class="wujia-mdash-card">
                        <p class="wujia-mdash-title mb-3">Sản phẩm yêu cầu</p>
                        <label class="wujia-mticket-label">Sản phẩm</label>
                        <input type="text" name="line_product_name[]" class="form-control mb-3"
                               placeholder="Tên sản phẩm cần đổi / bù" required="required"/>
                        <input type="hidden" name="line_reason[]" value=""/>
                        <div class="wujia-mreturn-grid2">
                            <div>
                                <label class="wujia-mticket-label">SL yêu cầu</label>
                                <input type="number" name="line_qty[]" class="form-control"
                                       min="1" value="1" required="required"/>
                            </div>
                            <div>
                                <!-- UI-only: ĐVT chưa wire -->
                                <label class="wujia-mticket-label">Đơn vị</label>
                                <input type="text" class="form-control" placeholder="VD: Bịch"/>
                            </div>
                        </div>
                    </div>

                    <div class="wujia-mdash-card">
                        <p class="wujia-mdash-title mb-3">Nội dung lỗi</p>
                        <label class="wujia-mticket-label">Loại lỗi</label>
                        <select name="error_id" class="form-select mb-3" required="required">
                            <option value="">— Chọn loại lỗi —</option>
                            <t t-foreach="error_types" t-as="et"><option t-att-value="et.id" t-out="et.name"/></t>
                        </select>
                        <!-- UI-only: 2 ngày dưới chưa wire -->
                        <div class="wujia-mreturn-grid2">
                            <div>
                                <label class="wujia-mticket-label">Ngày đóng-mở hàng</label>
                                <input type="date" class="form-control"/>
                            </div>
                            <div>
                                <label class="wujia-mticket-label">Ngày sản xuất</label>
                                <input type="date" class="form-control"/>
                            </div>
                        </div>
                        <label class="wujia-mticket-label">Ghi chú</label>
                        <textarea name="note" rows="3" class="form-control"
                                  placeholder="Mô tả chi tiết tình trạng hàng…"/>
                    </div>

                    <div class="wujia-mdash-card">
                        <p class="wujia-mdash-title mb-1">Hình ảnh đính kèm</p>
                        <p class="wujia-mticket-hint">Tối thiểu 3 ảnh, chụp rõ bao bì &amp; lỗi sản phẩm.</p>
                        <input type="file" name="images" class="form-control"
                               accept="image/png,image/jpeg" multiple="multiple"/>
                    </div>

                    <div class="wujia-mdash-card">
                        <!-- UI-only: video chưa wire -->
                        <p class="wujia-mdash-title mb-1">Video đính kèm</p>
                        <p class="wujia-mticket-hint">MP4/MOV, tối đa 1 video.</p>
                        <input type="file" class="form-control" accept="video/mp4,video/quicktime"/>
                    </div>

                    <div class="wujia-mreturn-cta">
                        <a href="/portal/return" class="wujia-mreturn-btn-cancel">Hủy</a>
                        <button type="submit" name="action" value="send" class="wujia-mreturn-btn-submit">
                            Gửi yêu cầu
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>

</odoo>
