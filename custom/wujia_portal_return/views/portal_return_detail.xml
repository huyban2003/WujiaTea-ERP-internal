<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_return_detail" name="Wujia Portal — Return Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="rr.name"/>
            <div class="content-wrapper">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/return">Đổi trả</a></li>
                            <li class="breadcrumb-item active" t-out="rr.name"/>
                        </ol></nav>
                        <h2 class="content-header-title float-left mb-0 d-flex align-items-center">
                            <span class="me-2"><t t-out="rr.name"/></span>
                            <t t-set="lbl" t-value="state_labels.get(rr.state, (rr.state, 'state-draft'))"/>
                            <span t-attf-class="badge state-badge #{lbl[1]}" t-out="lbl[0]"/>
                        </h2>
                    </div>
                </div>

                <div class="content-body">
                    <div class="row">
                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Thông tin yêu cầu</h5></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-sm-5">Cửa hàng</dt>
                                        <dd class="col-sm-7" t-out="rr.franchise_id.name or '—'"/>
                                        <dt class="col-sm-5">Ngày yêu cầu</dt>
                                        <dd class="col-sm-7" t-out="rr.request_date and rr.request_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <dt class="col-sm-5">Đơn gốc</dt>
                                        <dd class="col-sm-7">
                                            <t t-if="rr.order_id">
                                                <a t-attf-href="/portal/purchase-history/#{rr.order_id.id}" t-out="rr.order_id.name"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </dd>
                                        <dt class="col-sm-5">Loại lỗi</dt>
                                        <dd class="col-sm-7" t-out="rr.error_id.name or '—'"/>
                                        <dt class="col-sm-5">Ngày giao dự kiến</dt>
                                        <dd class="col-sm-7" t-out="rr.expected_delivery_date and rr.expected_delivery_date.strftime('%d/%m/%Y') or '—'"/>
                                        <dt class="col-sm-5">Người tạo</dt>
                                        <dd class="col-sm-7" t-out="rr.created_by_user_id.name or '—'"/>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Ghi chú &amp; Phản hồi</h5></div>
                                <div class="card-body">
                                    <h6 class="text-muted">Ghi chú từ cửa hàng</h6>
                                    <p t-if="rr.note" t-out="rr.note"/>
                                    <p t-else="" class="text-muted fst-italic">Không có ghi chú.</p>
                                    <t t-if="rr.refuse_reason">
                                        <hr/>
                                        <h6 class="text-danger">Lý do từ chối</h6>
                                        <p t-out="rr.refuse_reason"/>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-2">
                        <div class="card-header"><h5 class="mb-0">Sản phẩm cần đổi trả</h5></div>
                        <div class="card-body p-0">
                            <table class="table mb-0">
                                <thead><tr><th>STT</th><th>Sản phẩm</th><th class="text-end">SL</th><th>ĐVT</th><th>Lý do</th></tr></thead>
                                <tbody>
                                    <tr t-foreach="rr.line_ids" t-as="line">
                                        <td t-out="line_index + 1"/>
                                        <td t-out="line.product_id.display_name"/>
                                        <td class="text-end" t-out="'{:,.0f}'.format(line.qty or 0)"/>
                                        <td t-out="line.uom_id.name or line.product_id.uom_id.name or ''"/>
                                        <td t-out="line.reason or '—'"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="card" t-if="rr.image_ids">
                        <div class="card-header"><h5 class="mb-0">Ảnh minh chứng</h5></div>
                        <div class="card-body">
                            <div class="row g-2">
                                <t t-foreach="rr.image_ids" t-as="img">
                                    <div class="col-6 col-sm-4 col-md-3">
                                        <a t-attf-href="/web/image/ir.attachment/#{img.id}/datas" target="_blank">
                                            <img loading="lazy"
                                                 t-attf-src="/web/image/ir.attachment/#{img.id}/datas"
                                                 class="img-fluid rounded return-image-thumb"
                                                 t-att-alt="img.name"/>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="mt-2">
                        <a href="/portal/return" class="btn btn-secondary">
                            <i class="fa fa-arrow-left me-1"/>Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
