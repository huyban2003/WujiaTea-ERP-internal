<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_return_detail" name="Wujia Portal — Return Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="rr.name"/>

            <!-- Desktop ≥992px -->
            <div class="content-wrapper d-none d-lg-block">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'pc'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title" t-value="rr.name"/>
                    <t t-set="ph_back_url" t-value="'/portal/return'"/>
                </t>
                <t t-set="lbl" t-value="state_labels.get(rr.state, (rr.state, 'state-draft'))"/>
                <div class="mb-2"><span t-attf-class="badge state-badge #{lbl[1]}" t-out="lbl[0]"/></div>

                <div class="content-body">
                    <div class="row">
                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Thông tin yêu cầu</h5></div>
                                <div class="card-body">
                                    <dl class="row mb-0 profile-dl">
                                        <dt class="col-sm-5">Cửa hàng</dt>
                                        <dd class="col-sm-7" t-out="rr.franchise_id.name or '—'"/>
                                        <dt class="col-sm-5">Ngày yêu cầu</dt>
                                        <dd class="col-sm-7" t-out="rr.request_date and rr.request_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <dt class="col-sm-5">Đơn gốc</dt>
                                        <dd class="col-sm-7">
                                            <t t-if="rr.sale_order_id">
                                                <a t-attf-href="/portal/purchase-history/#{rr.sale_order_id.id}" t-out="rr.sale_order_id.name"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </dd>
                                        <dt class="col-sm-5">Loại lỗi</dt>
                                        <dd class="col-sm-7" t-out="rr.issue_type_id.name or '—'"/>
                                        <dt class="col-sm-5">Thời gian mở hàng</dt>
                                        <dd class="col-sm-7" t-out="rr.opening_datetime and rr.opening_datetime.strftime('%d/%m/%Y %H:%M') or '—'"/>
                                        <dt class="col-sm-5">Ngày sản xuất</dt>
                                        <dd class="col-sm-7" t-out="rr.production_date and rr.production_date.strftime('%d/%m/%Y') or '—'"/>
                                        <dt class="col-sm-5">Người tạo</dt>
                                        <dd class="col-sm-7" t-out="rr.requester_user_id.name or '—'"/>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header"><h5 class="mb-0">Ghi chú &amp; Phản hồi</h5></div>
                                <div class="card-body">
                                    <h6 class="text-muted">Ghi chú từ cửa hàng</h6>
                                    <p t-if="rr.note" t-out="rr.note"/>
                                    <p t-else="" class="text-muted fst-italic">Không có ghi chú.</p>
                                    <t t-if="rr.reject_reason">
                                        <hr/>
                                        <h6 class="text-danger">Lý do từ chối</h6>
                                        <p t-out="rr.reject_reason"/>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-2">
                        <div class="card-header"><h5 class="mb-0">Sản phẩm yêu cầu</h5></div>
                        <div class="card-body p-0">
                            <table class="table mb-0">
                                <thead><tr><th>Sản phẩm</th><th class="text-end">SL yêu cầu</th><th>ĐVT</th></tr></thead>
                                <tbody>
                                    <tr>
                                        <td t-out="rr.product_id.display_name or '—'"/>
                                        <td class="text-end" t-out="'{:,.2f}'.format(rr.request_qty or 0)"/>
                                        <td t-out="rr.request_uom_id.name or ''"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="card" t-if="rr.image_attachment_ids">
                        <div class="card-header"><h5 class="mb-0">Ảnh minh chứng</h5></div>
                        <div class="card-body">
                            <div class="row g-2">
                                <t t-foreach="rr.image_attachment_ids" t-as="img">
                                    <div class="col-6 col-sm-4 col-md-3">
                                        <a t-attf-href="/portal/return/#{rr.id}/attachment/#{img.id}" target="_blank">
                                            <img loading="lazy"
                                                 t-attf-src="/portal/return/#{rr.id}/attachment/#{img.id}"
                                                 class="img-fluid rounded return-image-thumb"
                                                 t-att-alt="img.name"/>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="mt-2">
                        <a href="/portal/return" class="btn btn-secondary">
                            <i class="fa fa-arrow-left me-1"/>Quay lại
                        </a>
                    </div>
                </div>
            </div>

            <!-- Mobile <992px -->
            <div class="d-lg-none wujia-mpage wujia-mreturn">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'m'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title">Chi tiết yêu cầu</t>
                    <t t-set="ph_back_url" t-value="'/portal/return'"/>
                </t>

                <div class="wujia-mdash-card">
                    <div class="wujia-mreturn-row-head">
                        <span class="wujia-mreturn-row-code" t-out="rr.name"/>
                        <t t-set="lbl" t-value="state_labels.get(rr.state, (rr.state, 'wujia-badge-muted'))"/>
                        <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                    </div>
                    <div class="wujia-mreturn-summary-meta">
                        <span t-out="rr.sale_order_id.name or '—'"/>
                        <span t-out="rr.request_date and rr.request_date.strftime('%d/%m/%Y') or '—'"/>
                    </div>
                </div>

                <div class="wujia-mdash-card">
                    <div class="wujia-mhist-card-head">Thông tin đơn hàng</div>
                    <div class="wujia-mhist-kv">
                        <span class="wujia-mhist-kv-label">Ngày yêu cầu</span>
                        <span class="wujia-mhist-kv-value"
                              t-out="rr.request_date and rr.request_date.strftime('%d/%m/%Y') or '—'"/>
                    </div>
                    <div class="wujia-mhist-kv">
                        <span class="wujia-mhist-kv-label">Thời gian mở hàng</span>
                        <span class="wujia-mhist-kv-value"
                              t-out="rr.opening_datetime and rr.opening_datetime.strftime('%d/%m/%Y %H:%M') or '—'"/>
                    </div>
                    <div class="wujia-mhist-kv">
                        <span class="wujia-mhist-kv-label">Đơn gốc</span>
                        <span class="wujia-mhist-kv-value" t-out="rr.sale_order_id.name or '—'"/>
                    </div>
                </div>

                <div class="wujia-mdash-card">
                    <div class="wujia-mhist-card-head">Sản phẩm yêu cầu</div>
                    <div class="wujia-mhist-kv">
                        <span class="wujia-mhist-kv-label">Sản phẩm</span>
                        <span class="wujia-mhist-kv-value" t-out="rr.product_id.display_name or '—'"/>
                    </div>
                    <div class="wujia-mhist-kv">
                        <span class="wujia-mhist-kv-label">SL yêu cầu</span>
                        <span class="wujia-mhist-kv-value">
                            <t t-out="'{:,.2f}'.format(rr.request_qty or 0)"/> <t t-out="rr.request_uom_id.name or ''"/>
                        </span>
                    </div>
                </div>

                <div class="wujia-mdash-card">
                    <div class="wujia-mhist-card-head">Nội dung lỗi</div>
                    <div class="wujia-mhist-kv">
                        <span class="wujia-mhist-kv-label">Loại lỗi</span>
                        <span class="wujia-mhist-kv-value" t-out="rr.issue_type_id.name or '—'"/>
                    </div>
                    <p class="wujia-mhist-note" t-out="rr.note or 'Không có ghi chú.'"/>
                </div>

                <div t-if="rr.image_attachment_ids" class="wujia-mdash-card">
                    <div class="wujia-mhist-card-head"><t t-out="len(rr.image_attachment_ids)"/> ảnh đính kèm</div>
                    <div class="wujia-mreturn-thumbs">
                        <a t-foreach="rr.image_attachment_ids" t-as="img" target="_blank"
                           t-attf-href="/portal/return/#{rr.id}/attachment/#{img.id}">
                            <img loading="lazy" t-att-alt="img.name"
                                 t-attf-src="/portal/return/#{rr.id}/attachment/#{img.id}"/>
                        </a>
                    </div>
                </div>

                <div class="wujia-mdash-card wujia-mreturn-response">
                    <div class="wujia-mhist-card-head">Phản hồi của Ngô Gia</div>
                    <p t-if="rr.reject_reason" class="wujia-mreturn-resp-body" t-out="rr.reject_reason"/>
                    <p t-else="" class="wujia-mhist-note">Chưa có phản hồi từ Ngô Gia.</p>
                </div>
            </div>
        </t>
    </template>

</odoo>
