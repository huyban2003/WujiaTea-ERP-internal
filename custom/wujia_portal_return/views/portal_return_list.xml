<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_return_list" name="Wujia Portal — Return List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Yêu cầu đổi trả</t>

            <!-- Desktop ≥992px — giữ nguyên, bọc d-none d-lg-block (S20) -->
            <div class="content-wrapper d-none d-lg-block">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'pc'"/>
                    <t t-set="ph_variant" t-value="'create'"/>
                    <t t-set="ph_title">Yêu cầu đổi trả</t>
                    <t t-set="ph_create_url" t-value="'/portal/return/new'"/>
                    <t t-set="ph_can_create" t-value="True"/>
                </t>

                <div t-if="no_franchise" class="alert alert-warning m-3">
                    Bạn chưa được gán vào cửa hàng nào.
                </div>

                <div t-if="not no_franchise" class="content-body">
                    <!-- Filter -->
                    <div class="card mb-2">
                        <div class="card-body p-2">
                            <form method="get" action="/portal/return" class="row g-2 align-items-center">
                                <div class="col-md-3 col-12">
                                    <label class="small text-muted mb-1">Trạng thái</label>
                                    <select name="state" class="form-select form-select-sm">
                                        <option value="">— Tất cả —</option>
                                        <t t-foreach="state_labels.items()" t-as="kv">
                                            <option t-att-value="kv[0]"
                                                    t-att-selected="'selected' if state == kv[0] else None"
                                                    t-out="kv[1][0]"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-3 col-6">
                                    <label class="small text-muted mb-1">Từ ngày</label>
                                    <input type="date" name="date_from" class="form-control form-control-sm" t-att-value="date_from"/>
                                </div>
                                <div class="col-md-3 col-6">
                                    <label class="small text-muted mb-1">Đến ngày</label>
                                    <input type="date" name="date_to" class="form-control form-control-sm" t-att-value="date_to"/>
                                </div>
                                <div class="col-md-3 col-12 text-end">
                                    <label class="small text-muted mb-1 d-block">&#160;</label>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fa fa-search"/> Lọc
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Table (Sprint 9.13b 2026-05-27: MẪU 02 — wujia-content-card-table) -->
                    <div class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-refresh-cw"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Danh sách yêu cầu đổi trả</h4>
                            <span t-if="returns" class="wujia-content-card-header-link">
                                <t t-out="len(returns)"/> kết quả
                            </span>
                        </div>
                        <div t-if="not returns" class="wujia-empty-state">
                            <i class="feather icon-corner-up-left"/>
                            <p>Chưa có yêu cầu nào. <a href="/portal/return/new">Tạo yêu cầu đầu tiên</a>.</p>
                        </div>
                        <div t-else="" class="table-responsive">
                            <table class="wujia-content-card-table">
                                <thead>
                                    <tr>
                                        <th>Mã</th>
                                        <th>Ngày yêu cầu</th>
                                        <th>Cửa hàng</th>
                                        <th>Loại lỗi</th>
                                        <th>Đơn gốc</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="returns" t-as="rr">
                                        <td><a t-attf-href="/portal/return/#{rr.id}" t-out="rr.name"/></td>
                                        <td t-out="rr.request_date and rr.request_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <td t-out="rr.franchise_id.name or '—'"/>
                                        <td t-out="rr.error_id.name or '—'"/>
                                        <td t-out="rr.order_id.name or '—'"/>
                                        <td class="text-center">
                                            <t t-set="lbl" t-value="state_labels.get(rr.state, (rr.state, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-attf-href="/portal/return/#{rr.id}" class="btn btn-sm btn-outline-primary">
                                                <i class="fa fa-eye"/>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="mt-2">
                        <ul class="pagination wujia-pagination justify-content-center mb-0">
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/return?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                            </li>
                            <li class="page-item active">
                                <span class="page-link">
                                    Trang <t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/>
                                </span>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   t-attf-href="/portal/return?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>

            <!-- Mobile <992px — Figma 4449:88, BA ListScreen (S20) -->
            <div class="d-lg-none wujia-mpage wujia-mreturn">
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'m'"/>
                    <t t-set="ph_variant" t-value="'create'"/>
                    <t t-set="ph_title">Đổi trả hàng</t>
                    <t t-set="ph_create_url" t-value="'/portal/return/new'"/>
                    <t t-set="ph_can_create" t-value="True"/>
                </t>

                <div t-if="no_franchise" class="wj-empty-state wj-empty-state--card">
                    <i class="feather icon-alert-circle"/>
                    <p>Bạn chưa được gán vào cửa hàng nào.</p>
                </div>

                <t t-else="">
                    <!-- Filter canonical 02-KeywordDateRange (Figma 4785:660) — q + dates wired sẵn -->
                    <form method="get" action="/portal/return" class="wj-filter-card">
                        <div class="wj-filter-search">
                            <div class="wj-filter-search-field">
                                <i class="feather icon-search"/>
                                <input type="text" name="q" placeholder="Tìm mã YC / mã đơn" t-att-value="q or ''"/>
                            </div>
                            <button type="submit" class="wj-filter-search-btn"><i class="feather icon-search"/></button>
                        </div>
                        <div class="wj-filter-dates">
                            <label class="wj-filter-date">
                                <i class="feather icon-calendar"/>
                                <input type="date" name="date_from" t-att-value="date_from or ''"/>
                            </label>
                            <span class="wj-filter-date-sep">–</span>
                            <label class="wj-filter-date">
                                <i class="feather icon-calendar"/>
                                <input type="date" name="date_to" t-att-value="date_to or ''"/>
                            </label>
                        </div>
                    </form>

                    <!-- Empty: chưa có YC nào (no-data thật) -->
                    <t t-if="not returns and not q and not state and not date_from and not date_to">
                        <div class="wj-empty-state wj-empty-state--rich">
                            <span class="wj-empty-state-icon"/>
                            <p class="wj-empty-state-title">Không có yêu cầu</p>
                            <p class="wj-empty-state-sub">Cửa hàng chưa gửi yêu cầu đổi trả nào.</p>
                            <p class="wj-empty-state-sub">Yêu cầu mới sẽ xuất hiện tại đây khi được tạo.</p>
                            <a href="/portal/return/new" class="wj-empty-state-btn">
                                <i class="feather icon-plus"/> Tạo yêu cầu mới
                            </a>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="wujia-mhist-listhead">
                            <span class="wujia-mhist-listhead-title">Lịch sử yêu cầu</span>
                            <span class="wj-count-meta"><t t-out="len(returns)"/> yêu cầu</span>
                        </div>

                        <!-- Empty: tìm không ra (lọc rỗng → Xóa lọc) -->
                        <div t-if="not returns" class="wj-empty-state wj-empty-state--rich">
                            <span class="wj-empty-state-icon"/>
                            <p class="wj-empty-state-title">Không tìm thấy kết quả</p>
                            <p class="wj-empty-state-sub">Không có yêu cầu khớp bộ lọc hiện tại.</p>
                            <p class="wj-empty-state-sub">Thử đổi từ khóa hoặc xóa điều kiện tìm kiếm.</p>
                            <a href="/portal/return" class="wj-empty-state-btn">Xóa lọc</a>
                        </div>

                        <!-- Danh sách yêu cầu (ReturnCard) -->
                        <div t-else="" class="wujia-mreturn-list">
                            <a t-foreach="returns" t-as="rr" t-attf-href="/portal/return/#{rr.id}"
                               class="wujia-mreturn-row">
                                <t t-set="first_line" t-value="rr.line_ids[:1]"/>
                                <span class="wujia-mreturn-row-body">
                                    <span class="wujia-mreturn-row-head">
                                        <span class="wujia-mreturn-row-code" t-out="rr.name"/>
                                        <t t-set="lbl" t-value="state_labels.get(rr.state, (rr.state, 'wujia-badge-muted'))"/>
                                        <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                    </span>
                                    <span class="wujia-mreturn-row-product"
                                          t-out="first_line.product_id.display_name or first_line.product_name or rr.error_id.name or '—'"/>
                                    <span class="wujia-mreturn-row-divider"/>
                                    <span class="wujia-mreturn-row-meta">
                                        <span class="wujia-mreturn-row-metacell">
                                            <span class="lbl">Đơn gốc</span>
                                            <span class="val" t-out="rr.order_id.name or '—'"/>
                                        </span>
                                        <span class="wujia-mreturn-row-metacell">
                                            <span class="lbl">Ngày YC</span>
                                            <span class="val"
                                                  t-out="rr.request_date and rr.request_date.strftime('%d/%m') or '—'"/>
                                        </span>
                                    </span>
                                </span>
                                <i class="feather icon-chevron-right wujia-mreturn-row-chevron"/>
                            </a>
                        </div>

                        <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="wujia-mhist-pager">
                            <a t-attf-href="/portal/return?page=#{pager['page_previous']['num']}&amp;#{pager.get('querystring','')}">«</a>
                            <span>Trang <t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                            <a t-attf-href="/portal/return?page=#{pager['page_next']['num']}&amp;#{pager.get('querystring','')}">»</a>
                        </nav>
                    </t>
                </t>
            </div>
            <!-- /mobile -->
        </t>
    </template>

</odoo>
