<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wujia_franchise_member_list" model="ir.ui.view">
        <field name="name">wujia.franchise.member.list</field>
        <field name="model">wujia.franchise.member</field>
        <field name="arch" type="xml">
            <list string="Franchise Memberships" sample="1"
                  decoration-muted="not is_currently_valid"
                  decoration-bf="is_primary_owner">
                <field name="user_id"/>
                <field name="franchise_id"/>
                <field name="role"/>
                <field name="is_primary_owner"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="is_currently_valid"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_wujia_franchise_member_form" model="ir.ui.view">
        <field name="name">wujia.franchise.member.form</field>
        <field name="model">wujia.franchise.member</field>
        <field name="arch" type="xml">
            <form string="Franchise Membership">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="user_id" options="{'no_create': True}"/>
                            <field name="franchise_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="role"/>
                            <field name="is_primary_owner"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="is_currently_valid"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_wujia_franchise_member_search" model="ir.ui.view">
        <field name="name">wujia.franchise.member.search</field>
        <field name="model">wujia.franchise.member</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="franchise_id"/>
                <field name="role"/>
                <filter string="Đang hiệu lực" name="filter_currently_valid"
                        domain="[('is_currently_valid', '=', True)]"/>
                <filter string="Chủ tiệm" name="filter_owner"
                        domain="[('role', '=', 'owner')]"/>
                <filter string="Quản lý" name="filter_manager"
                        domain="[('role', '=', 'manager')]"/>
                <filter string="Nhân viên" name="filter_staff"
                        domain="[('role', '=', 'staff')]"/>
                <separator/>
                <filter string="Archived" name="filter_inactive"
                        domain="[('active', '=', False)]"/>
                <filter string="Cửa hàng" name="group_franchise"
                        context="{'group_by': 'franchise_id'}"/>
                <filter string="User" name="group_user"
                        context="{'group_by': 'user_id'}"/>
                <filter string="Role" name="group_role"
                        context="{'group_by': 'role'}"/>
            </search>
        </field>
    </record>

    <record id="action_wujia_franchise_member" model="ir.actions.act_window">
        <field name="name">Franchise Member</field>
        <field name="res_model">wujia.franchise.member</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_currently_valid': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo membership mới</p>
            <p>Mỗi membership gán một user portal vào một cửa hàng nhượng quyền với role cụ thể (Owner / Manager / Staff).</p>
        </field>
    </record>

</odoo>
