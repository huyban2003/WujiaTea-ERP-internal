<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Theo yêu cầu BA: KHÔNG nhúng tab editable membership vào form res.users gốc.
        Chỉ thêm 1 smart-button "Franchise Members" để admin click sang màn
        wujia.franchise.member (CRUD độc lập).
    -->
    <record id="view_users_form_franchise" model="ir.ui.view">
        <field name="name">res.users.form.franchise</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_franchise_members" type="object"
                        class="oe_stat_button" icon="fa-users">
                    <field name="member_count" widget="statinfo"
                           string="Franchise Members"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
