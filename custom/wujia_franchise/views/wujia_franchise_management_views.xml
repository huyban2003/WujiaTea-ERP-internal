<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_franchise_management_list" model="ir.ui.view">
        <field name="name">wujia.franchise.management.list</field>
        <field name="model">wujia.franchise.management</field>
        <field name="arch" type="xml">
            <list string="Cửa hàng nhượng quyền" sample="1"
                  decoration-danger="is_expired"
                  decoration-warning="status == 'locked'"
                  decoration-muted="status == 'closed'">
                <field name="code"/>
                <field name="name"/>
                <field name="area_id" optional="show"/>
                <field name="main_owner_member_id" optional="show"/>
                <field name="franchise_start_date" optional="hide"/>
                <field name="franchise_end_date"/>
                <field name="remaining_days"/>
                <field name="member_count"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-warning="status == 'locked'"
                       decoration-danger="status == 'expired'"
                       decoration-muted="status in ('draft', 'closed')"/>
                <field name="portal_locked" optional="hide"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_franchise_management_form" model="ir.ui.view">
        <field name="name">wujia.franchise.management.form</field>
        <field name="model">wujia.franchise.management</field>
        <field name="arch" type="xml">
            <form string="Cửa hàng nhượng quyền">
                <header>
                    <button name="action_set_active" type="object"
                            string="Kích hoạt" class="btn-primary"
                            invisible="status == 'active'"/>
                    <button name="action_lock_portal" type="object"
                            string="Khóa portal" class="btn-warning"
                            invisible="status in ('locked', 'closed')"/>
                    <button name="action_close" type="object"
                            string="Đóng cửa hàng" class="btn-danger"
                            invisible="status == 'closed'"
                            confirm="Đóng cửa hàng sẽ khóa toàn bộ truy cập portal. Tiếp tục?"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,active,locked,expired,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_members" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="member_count" widget="statinfo" string="Thành viên"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Hết hạn"
                            bg_color="text-bg-danger" invisible="not is_expired"/>
                    <widget name="web_ribbon" title="Khóa portal"
                            bg_color="text-bg-warning"
                            invisible="not portal_locked or is_expired"/>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Định danh">
                            <field name="code" placeholder="H010"/>
                            <field name="name" placeholder="Cửa hàng 219 Vĩnh Viễn"/>
                            <field name="partner_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="main_owner_member_id" readonly="1"/>
                        </group>
                        <group string="Hợp đồng">
                            <field name="franchise_start_date"/>
                            <field name="franchise_end_date"/>
                            <field name="remaining_days"/>
                            <field name="is_expired" invisible="1"/>
                            <field name="opening_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Khu vực &amp; Địa chỉ">
                            <field name="area_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="state_id"/>
                            <field name="address"/>
                        </group>
                        <group string="Liên hệ">
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                    </group>
                    <group>
                        <group string="Cờ điều khiển">
                            <field name="portal_locked"/>
                            <field name="invoiced"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thành viên" name="members">
                            <field name="member_ids" context="{'default_franchise_id': id}">
                                <list editable="bottom"
                                      decoration-muted="not is_currently_valid"
                                      decoration-bf="is_primary_owner">
                                    <field name="user_id" options="{'no_create': True}"/>
                                    <field name="role"/>
                                    <field name="is_primary_owner"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="is_currently_valid"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Mô tả vận hành" name="description">
                            <field name="description"
                                   placeholder="Lưu ý vận hành, giao hàng, cấm tải, cấm đỗ..."/>
                        </page>
                        <page string="Ghi chú nội bộ" name="note">
                            <field name="note" placeholder="Ghi chú nội bộ"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_franchise_management_kanban" model="ir.ui.view">
        <field name="name">wujia.franchise.management.kanban</field>
        <field name="model">wujia.franchise.management</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="code"/>
                <field name="name"/>
                <field name="area_name"/>
                <field name="status"/>
                <field name="is_expired"/>
                <field name="member_count"/>
                <field name="remaining_days"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="display_name"/>
                                    </strong>
                                    <small class="text-muted">
                                        <field name="area_name"/>
                                    </small>
                                </div>
                                <field name="status" widget="label_selection"/>
                            </div>
                            <ul>
                                <li>Còn lại: <field name="remaining_days"/> ngày</li>
                                <li>Thành viên: <field name="member_count"/></li>
                            </ul>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_franchise_management_search" model="ir.ui.view">
        <field name="name">wujia.franchise.management.search</field>
        <field name="model">wujia.franchise.management</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="area_id"/>
                <field name="main_owner_member_id"/>
                <separator/>
                <filter string="Đang hoạt động" name="filter_active"
                        domain="[('status', '=', 'active')]"/>
                <filter string="Đã hết hạn" name="filter_expired"
                        domain="[('is_expired', '=', True)]"/>
                <filter string="Đang khóa portal" name="filter_locked"
                        domain="[('portal_locked', '=', True)]"/>
                <separator/>
                <filter string="Sắp hết hạn (trong 30 ngày)" name="filter_expiring_soon"
                        domain="[('remaining_days', '&gt;=', 0), ('remaining_days', '&lt;=', 30)]"/>
                <separator/>
                <filter string="Archived" name="filter_inactive"
                        domain="[('active', '=', False)]"/>
                <filter string="Khu vực" name="group_area"
                        context="{'group_by': 'area_id'}"/>
                <filter string="Trạng thái" name="group_status"
                        context="{'group_by': 'status'}"/>
            </search>
        </field>
    </record>

    <record id="action_franchise_management" model="ir.actions.act_window">
        <field name="name">Franchise Management</field>
        <field name="res_model">wujia.franchise.management</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo hồ sơ cửa hàng nhượng quyền đầu tiên</p>
            <p>Hồ sơ cửa hàng quản lý hợp đồng nhượng quyền: ngày bắt đầu/kết thúc, khu vực, chủ chính, trạng thái...</p>
        </field>
    </record>

    <!-- Cron tự động set status='expired' mỗi ngày -->
    <record id="ir_cron_check_franchise_expired" model="ir.cron">
        <field name="name">Wujia: Auto-expire franchise contract</field>
        <field name="model_id" ref="model_wujia_franchise_management"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_expired()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>
