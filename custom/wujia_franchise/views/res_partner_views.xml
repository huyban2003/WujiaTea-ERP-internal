<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_franchise" model="ir.ui.view">
        <field name="name">res.partner.form.franchise</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_franchises" type="object"
                        class="oe_stat_button" icon="fa-building"
                        invisible="not is_franchise">
                    <field name="franchise_count" widget="statinfo" string="Cửa hàng"/>
                </button>
            </xpath>

            <xpath expr="//field[@name='vat']" position="after">
                <field name="is_franchise" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_res_partner_filter_franchise" model="ir.ui.view">
        <field name="name">res.partner.search.franchise</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Là cửa hàng nhượng quyền" name="filter_is_franchise"
                        domain="[('is_franchise', '=', True)]"/>
            </xpath>
        </field>
    </record>

</odoo>
