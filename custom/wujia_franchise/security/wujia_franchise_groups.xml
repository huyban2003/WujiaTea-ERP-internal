<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_wujia" model="ir.module.category">
        <field name="name">Wujia</field>
        <field name="description">Wujia ERP customizations</field>
        <field name="sequence">20</field>
    </record>

    <record id="res_groups_privilege_franchise" model="res.groups.privilege">
        <field name="name">Wujia Franchise</field>
        <field name="category_id" ref="module_category_wujia"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_franchise_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_franchise"/>
        <field name="comment">Xem dữ liệu chi nhánh và membership.</field>
    </record>

    <record id="group_franchise_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_franchise"/>
        <field name="implied_ids" eval="[(4, ref('group_franchise_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Quản lý chi nhánh, tạo/xóa membership.</field>
    </record>

</odoo>
