<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="rule_franchise_member_portal_own" model="ir.rule">
            <field name="name">Franchise Member: portal user reads only own</field>
            <field name="model_id" ref="model_wujia_franchise_member"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_franchise_member_internal_all" model="ir.rule">
            <field name="name">Franchise Member: internal users see all</field>
            <field name="model_id" ref="model_wujia_franchise_member"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_franchise_user'))]"/>
        </record>

    </data>
</odoo>
