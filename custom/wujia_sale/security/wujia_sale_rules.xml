<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="rule_sale_order_portal_franchise" model="ir.rule">
            <field name="name">Sale Order: portal users see only own franchises</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">
                ['|',
                    ('portal_requester_user_id', '=', user.id),
                    ('franchise_id', 'in',
                     user._get_accessible_franchise_ids())]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_sale_order_line_portal_franchise" model="ir.rule">
            <field name="name">Sale Order Line: portal users see only own franchise lines</field>
            <field name="model_id" ref="sale.model_sale_order_line"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">
                ['|',
                    ('order_id.portal_requester_user_id', '=', user.id),
                    ('order_id.franchise_id', 'in',
                     user._get_accessible_franchise_ids())]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_product_template_portal_public" model="ir.rule">
            <field name="name">Product Template: portal sees only public website products</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('is_public_website', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_product_product_portal_public" model="ir.rule">
            <field name="name">Product: portal sees only public website products</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('product_tmpl_id.is_public_website', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
