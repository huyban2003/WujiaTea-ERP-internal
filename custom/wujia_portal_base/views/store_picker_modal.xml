<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Modal store picker — render SSR (không cần JS để show ban đầu).
         Khi must_pick=True: thêm class "show d-block" + backdrop ngay từ HTML
         → modal hiện ngay khi browser render trang, KHÔNG phụ thuộc JS/Bootstrap. -->
    <template id="store_picker_modal" name="Wujia Portal — Store Picker Modal">
        <!-- Modal: nếu must_pick → hiện ngay (class show + style display:block). -->
        <div t-attf-class="modal fade#{' show' if _wujia_must_pick else ''}"
             t-attf-style="#{'display: block !important; padding-right: 0;' if _wujia_must_pick else ''}"
             id="wujiaStorePickerModal" tabindex="-1"
             role="dialog" aria-labelledby="wujiaStorePickerLabel"
             data-backdrop="static" data-keyboard="false"
             data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header" style="background-color: #1f4180; color: #fff;">
                        <h5 class="modal-title" id="wujiaStorePickerLabel">
                            <i class="fa fa-building me-1"/>Chọn cửa hàng đang thao tác
                        </h5>
                    </div>
                    <form action="/portal/franchise/switch" method="POST" id="wujiaStorePickerForm">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="redirect" t-att-value="request.httprequest.full_path or '/portal'"/>
                        <div class="modal-body">
                            <p class="text-muted mb-3">
                                Bạn thuộc nhiều cửa hàng. Vui lòng chọn cửa hàng đang thao tác để
                                hệ thống chỉ hiển thị dữ liệu liên quan (đơn hàng, đổi trả, thông báo).
                            </p>
                            <div class="list-group store-picker-list">
                                <t t-foreach="all_accessible_franchises" t-as="f">
                                    <label t-attf-class="list-group-item list-group-item-action store-picker-item#{' active' if f.id == active_franchise_id else ''}">
                                        <input type="radio" name="franchise_id"
                                               t-att-value="f.id"
                                               t-att-checked="'checked' if f.id == active_franchise_id else None"
                                               required="required"
                                               class="store-picker-radio"/>
                                        <span class="store-picker-name">
                                            <strong t-out="f.name"/>
                                            <small t-if="f.code" class="text-muted ms-1">
                                                (<t t-out="f.code"/>)
                                            </small>
                                        </span>
                                        <small t-if="f.address" class="d-block text-muted store-picker-addr"
                                               t-out="f.address"/>
                                    </label>
                                </t>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-check me-1"/>Xác nhận
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Backdrop SSR: render khi must_pick để chặn click ra ngoài. -->
        <div t-if="_wujia_must_pick"
             class="modal-backdrop fade show wujia-store-picker-backdrop"
             style="z-index: 1040;"/>
    </template>

</odoo>
