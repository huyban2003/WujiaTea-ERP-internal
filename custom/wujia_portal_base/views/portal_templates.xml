<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_my_home_franchise"
              inherit_id="portal.portal_my_home" priority="20"
              name="Portal My Home — Franchises Card">
        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Cửa hàng nhượng quyền</t>
                <t t-set="text">Quản lý cửa hàng nhượng quyền của bạn</t>
                <t t-set="url" t-value="'/my/franchises'"/>
                <t t-set="placeholder_count" t-value="'franchise_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_breadcrumbs_franchise"
              inherit_id="portal.portal_breadcrumbs" priority="20"
              name="Portal Breadcrumbs — Franchises">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'franchises'" class="breadcrumb-item active">Cửa hàng</li>
            <li t-if="page_name == 'franchise_detail'" class="breadcrumb-item">
                <a href="/my/franchises">Cửa hàng</a>
            </li>
            <li t-if="page_name == 'franchise_detail'" class="breadcrumb-item active">
                <t t-out="franchise.display_name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_franchises" name="My Franchises">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Cửa hàng nhượng quyền của tôi</t>
            </t>

            <div t-if="not memberships" class="alert alert-info mt-3">
                Bạn chưa được gán vào cửa hàng nào. Liên hệ admin để được gán quyền.
            </div>

            <table t-if="memberships" class="table table-hover o_portal_my_doc_table mt-3">
                <thead>
                    <tr class="active">
                        <th>Cửa hàng</th>
                        <th>Mã</th>
                        <th>Vai trò</th>
                        <th>Hiệu lực</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="memberships" t-as="m">
                        <t t-set="role_color"
                           t-value="{'owner': 'primary', 'manager': 'info', 'staff': 'secondary'}.get(m.role, 'secondary')"/>
                        <td>
                            <a t-attf-href="/my/franchises/#{m.franchise_id.id}">
                                <t t-out="m.franchise_id.name"/>
                            </a>
                        </td>
                        <td><t t-out="m.franchise_id.code or '—'"/></td>
                        <td>
                            <span t-attf-class="badge text-bg-#{role_color}">
                                <t t-out="role_labels.get(m.role, m.role)"/>
                            </span>
                            <span t-if="m.is_primary_owner"
                                  class="badge text-bg-warning ms-1">Chủ chính</span>
                        </td>
                        <td>
                            <t t-out="m.date_from"/>
                            —
                            <t t-out="m.date_to or 'Không giới hạn'"/>
                        </td>
                        <td class="text-end">
                            <a t-attf-href="/my/franchises/#{m.franchise_id.id}"
                               class="btn btn-sm btn-primary">Vào cửa hàng</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </t>
    </template>

    <template id="portal_my_franchise_detail" name="Franchise Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <div class="row mt-3">
                <div class="col-12">
                    <h3>
                        <t t-out="franchise.name"/>
                        <small class="text-muted ms-2">
                            (<t t-out="franchise.code or '—'"/>)
                        </small>
                    </h3>
                    <p>
                        Bạn đang là
                        <strong>
                            <t t-out="role_labels.get(membership.role, membership.role)"/>
                        </strong>
                        tại cửa hàng này.
                    </p>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Thành viên cửa hàng</h5>
                    <span id="o_wujia_realtime_indicator"
                          class="badge text-bg-success d-none">Đã cập nhật</span>
                </div>
                <div class="card-body p-0">
                    <table id="o_wujia_franchise_members"
                           t-att-data-franchise-id="franchise.id"
                           class="table mb-0">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Vai trò</th>
                                <th>Hiệu lực</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="members" t-as="member">
                                <t t-set="role_color"
                                   t-value="{'owner': 'primary', 'manager': 'info', 'staff': 'secondary'}.get(member.role, 'secondary')"/>
                                <td>
                                    <t t-out="member.user_id.name"/>
                                    <span t-if="member.is_primary_owner"
                                          class="badge text-bg-warning ms-1">Chủ chính</span>
                                </td>
                                <td>
                                    <span t-attf-class="badge text-bg-#{role_color}">
                                        <t t-out="role_labels.get(member.role, member.role)"/>
                                    </span>
                                </td>
                                <td>
                                    <t t-out="member.date_from"/>
                                    —
                                    <t t-out="member.date_to or '—'"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

</odoo>
