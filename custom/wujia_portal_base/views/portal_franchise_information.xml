<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- /portal/franchise-information — readonly snapshot, BA Section A -->
    <template id="portal_franchise_information"
              name="Wujia Portal — Franchise Information">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="franchise.name"/>
            <div class="content-wrapper">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-info-circle me-1"/>
                            Thông tin nhượng quyền — <t t-out="franchise.name"/>
                        </h2>
                        <p class="text-muted mb-0">
                            Trang chỉ đọc. Để yêu cầu cập nhật thông tin, dùng
                            <a href="/portal/info-request">Yêu cầu cập nhật thông tin</a>.
                        </p>
                    </div>
                </div>

                <div class="content-body">
                    <div class="row">
                        <!-- Store details -->
                        <div class="col-lg-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header">
                                    <h4 class="card-title mb-0">Cửa hàng</h4>
                                </div>
                                <div class="card-body">
                                    <dl class="row mb-0">
                                        <dt class="col-sm-5">Mã cửa hàng</dt>
                                        <dd class="col-sm-7" t-out="franchise.code or '—'"/>
                                        <dt class="col-sm-5">Tên cửa hàng</dt>
                                        <dd class="col-sm-7" t-out="franchise.name or '—'"/>
                                        <dt class="col-sm-5">Trạng thái</dt>
                                        <dd class="col-sm-7">
                                            <span class="wujia-badge wujia-badge-success"
                                                  t-out="dict(franchise._fields['status'].selection).get(franchise.status, franchise.status)"/>
                                        </dd>
                                        <dt class="col-sm-5">Ngày khai trương</dt>
                                        <dd class="col-sm-7" t-out="franchise.opening_date and franchise.opening_date.strftime('%d/%m/%Y') or '—'"/>
                                        <dt class="col-sm-5">Khu vực</dt>
                                        <dd class="col-sm-7" t-out="franchise.area_id.name or '—'"/>
                                        <dt class="col-sm-5">Tỉnh / Thành</dt>
                                        <dd class="col-sm-7" t-out="franchise.state_id.name or '—'"/>
                                        <dt class="col-sm-5">Địa chỉ</dt>
                                        <dd class="col-sm-7" t-out="franchise.address or '—'"/>
                                        <dt class="col-sm-5">SĐT</dt>
                                        <dd class="col-sm-7" t-out="franchise.phone or '—'"/>
                                        <dt class="col-sm-5">Email</dt>
                                        <dd class="col-sm-7" t-out="franchise.email or '—'"/>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <!-- Franchise contract -->
                        <div class="col-lg-6 col-12 mb-2">
                            <div class="card h-100">
                                <div class="card-header">
                                    <h4 class="card-title mb-0">Hợp đồng nhượng quyền</h4>
                                </div>
                                <div class="card-body">
                                    <dl class="row mb-0">
                                        <dt class="col-sm-5">Ngày bắt đầu</dt>
                                        <dd class="col-sm-7" t-out="franchise.franchise_start_date and franchise.franchise_start_date.strftime('%d/%m/%Y') or '—'"/>
                                        <dt class="col-sm-5">Ngày kết thúc</dt>
                                        <dd class="col-sm-7" t-out="franchise.franchise_end_date and franchise.franchise_end_date.strftime('%d/%m/%Y') or '—'"/>
                                        <dt class="col-sm-5">Số ngày còn lại</dt>
                                        <dd class="col-sm-7">
                                            <span t-if="franchise.is_expired" class="wujia-badge wujia-badge-danger">Đã hết hạn</span>
                                            <t t-else=""><t t-out="franchise.remaining_days"/> ngày</t>
                                        </dd>
                                        <dt class="col-sm-5">Tình trạng hóa đơn</dt>
                                        <dd class="col-sm-7">
                                            <span t-if="franchise.invoiced" class="wujia-badge wujia-badge-success">Đã xuất</span>
                                            <span t-else="" class="wujia-badge wujia-badge-warning">Chưa xuất</span>
                                        </dd>
                                        <dt class="col-sm-5">Trạng thái portal</dt>
                                        <dd class="col-sm-7">
                                            <span t-if="franchise.portal_locked" class="wujia-badge wujia-badge-danger">Đã khóa</span>
                                            <span t-else="" class="wujia-badge wujia-badge-success">Mở</span>
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <!-- User tab -->
                        <div class="col-12 mb-2">
                            <div class="card">
                                <div class="card-header">
                                    <h4 class="card-title mb-0">Thành viên cửa hàng</h4>
                                </div>
                                <div class="card-body p-0">
                                    <div t-if="not members" class="wujia-empty-state">
                                        <i class="fa fa-users"/>
                                        <p>Chưa có thành viên active.</p>
                                    </div>
                                    <table t-else="" class="table mb-0">
                                        <thead>
                                            <tr>
                                                <th>Vai trò</th>
                                                <th>Login</th>
                                                <th>Họ tên</th>
                                                <th>SĐT</th>
                                                <th>Email</th>
                                                <th>Trạng thái</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="members" t-as="m">
                                                <td>
                                                    <span class="wujia-badge wujia-badge-info"
                                                          t-out="role_labels.get(m.role, m.role)"/>
                                                </td>
                                                <td t-out="m.user_id.login or '—'"/>
                                                <td t-out="m.user_id.name or '—'"/>
                                                <td t-out="m.user_id.partner_id.phone or '—'"/>
                                                <td t-out="m.user_id.partner_id.email or '—'"/>
                                                <td>
                                                    <span t-if="m.active" class="wujia-badge wujia-badge-success">Active</span>
                                                    <span t-else="" class="wujia-badge wujia-badge-muted">Inactive</span>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Locked / inactive franchise — friendly block page -->
    <template id="portal_franchise_information_locked"
              name="Wujia Portal — Franchise Locked">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="'Cửa hàng tạm khóa'"/>
            <div class="content-wrapper">
                <div class="content-body">
                    <div class="card mt-5">
                        <div class="card-body wujia-empty-state">
                            <i class="fa fa-lock"/>
                            <h4>Cửa hàng <t t-out="franchise.name"/> đang không truy cập được.</h4>
                            <p class="text-muted">
                                Vui lòng liên hệ HQ Wujia để biết thêm chi tiết.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Inject menu link into sidenav -->
    <template id="sidenav_franchise_information"
              inherit_id="wujia_portal_layout.layout_sidenav" priority="20">
        <xpath expr="//li[@id='nav_item_home']" position="after">
            <li class="nav-item" id="nav_item_franchise_information">
                <a href="/portal/franchise-information" class="text-black">
                    <i class="feather icon-info" aria-hidden="true"/>
                    <span class="menu-title">Thông tin nhượng quyền</span>
                </a>
            </li>
        </xpath>
    </template>

</odoo>
