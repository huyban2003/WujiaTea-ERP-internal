<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard /portal — 4 stat card + 4 list block (BA spec) -->
    <template id="portal_home_page" name="Wujia Portal — Dashboard">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Trang chủ</t>
            <div class="content-wrapper">
                <!-- ======== DESKTOP (≥992px) — home cũ giữ NGUYÊN 100% (regression-safe) ======== -->
                <div class="d-none d-lg-block">
                <div class="content-header row">
                    <div class="content-header-left col-12">
                        <h2 class="content-header-title float-left mb-0">Tổng quan cửa hàng</h2>
                        <p class="text-muted">Chào mừng <strong t-out="request.env.user.name"/>! Đây là tóm tắt hoạt động cửa hàng nhượng quyền của bạn.</p>
                    </div>
                </div>

                <div t-if="not franchise_ids" class="alert alert-warning m-3" role="alert">
                    Bạn chưa được gán vào cửa hàng nào. Vui lòng liên hệ quản trị viên để được cấp quyền.
                </div>

                <div t-if="franchise_ids" class="content-body">
                    <!-- ============ 4 KPI cards (UI-11, Sprint 9.12) ============ -->
                    <section id="dashboard-stats">
                        <div class="row">
                            <div class="col-lg-3 col-12">
                                <a href="/portal/notification" class="wujia-kpi-card-link">
                                    <div class="wujia-kpi-card">
                                        <div class="wujia-kpi-icon wujia-kpi-icon-primary">
                                            <i class="fa fa-bell"/>
                                        </div>
                                        <div class="wujia-kpi-separator"/>
                                        <div class="wujia-kpi-content">
                                            <p class="wujia-kpi-label">Thông báo chưa đọc</p>
                                            <div class="wujia-kpi-value" t-out="unread_count or 0"/>
                                            <small class="wujia-kpi-desc">
                                                <t t-if="unread_count">Bạn có <t t-out="unread_count"/> thông báo mới</t>
                                                <t t-else="">Chưa có thông báo mới</t>
                                            </small>
                                        </div>
                                        <i class="feather icon-chevron-right wujia-kpi-arrow"/>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-3 col-12">
                                <a href="/portal/purchase-history" class="wujia-kpi-card-link">
                                    <div class="wujia-kpi-card">
                                        <div class="wujia-kpi-icon wujia-kpi-icon-info">
                                            <i class="fa fa-shopping-cart"/>
                                        </div>
                                        <div class="wujia-kpi-separator"/>
                                        <div class="wujia-kpi-content">
                                            <p class="wujia-kpi-label">Đơn hàng (30 ngày)</p>
                                            <div class="wujia-kpi-value" t-out="recent_orders_count or 0"/>
                                            <small class="wujia-kpi-desc">
                                                <t t-if="recent_orders_count"><t t-out="recent_orders_count"/> đơn trong 30 ngày</t>
                                                <t t-else="">Chưa có đơn hàng mới</t>
                                            </small>
                                        </div>
                                        <i class="feather icon-chevron-right wujia-kpi-arrow"/>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-3 col-12">
                                <a href="/portal/purchase-history" class="wujia-kpi-card-link">
                                    <div class="wujia-kpi-card">
                                        <div class="wujia-kpi-icon wujia-kpi-icon-warning">
                                            <i class="fa fa-clock-o"/>
                                        </div>
                                        <div class="wujia-kpi-separator"/>
                                        <div class="wujia-kpi-content">
                                            <p class="wujia-kpi-label">Đơn chờ xử lý</p>
                                            <div class="wujia-kpi-value" t-out="waiting_orders_count or 0"/>
                                            <small class="wujia-kpi-desc">
                                                <t t-if="waiting_orders_count">Có <t t-out="waiting_orders_count"/> đơn cần xử lý</t>
                                                <t t-else="">Tất cả đã xử lý</t>
                                            </small>
                                        </div>
                                        <i class="feather icon-chevron-right wujia-kpi-arrow"/>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-3 col-12">
                                <a href="/portal/return" class="wujia-kpi-card-link">
                                    <div class="wujia-kpi-card">
                                        <div class="wujia-kpi-icon wujia-kpi-icon-danger">
                                            <i class="fa fa-undo"/>
                                        </div>
                                        <div class="wujia-kpi-separator"/>
                                        <div class="wujia-kpi-content">
                                            <p class="wujia-kpi-label">Đổi trả đang mở</p>
                                            <div class="wujia-kpi-value" t-out="return_requests_count or 0"/>
                                            <small class="wujia-kpi-desc">
                                                <t t-if="return_requests_count"><t t-out="return_requests_count"/> yêu cầu đang mở</t>
                                                <t t-else="">Chưa có yêu cầu</t>
                                            </small>
                                        </div>
                                        <i class="feather icon-chevron-right wujia-kpi-arrow"/>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </section>

                    <!-- ============ 4 list blocks ============ -->
                    <div class="row">
                        <!-- Latest notifications (UI-12, Sprint 9.13) -->
                        <div class="col-lg-6 col-12 mb-2">
                            <div class="wujia-content-card">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-bell"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">Thông báo mới nhất</h4>
                                    <a href="/portal/notification" class="wujia-content-card-header-link">
                                        Xem tất cả
                                        <i class="feather icon-chevron-right"/>
                                    </a>
                                </div>
                                <div t-if="not latest_notifications" class="wujia-content-card-empty">Chưa có thông báo nào.</div>
                                <ul t-else="" class="wujia-content-card-body">
                                    <li t-foreach="latest_notifications" t-as="noti" class="wujia-content-card-row">
                                        <span class="wujia-content-card-row-bullet"/>
                                        <div class="wujia-content-card-row-content">
                                            <a t-attf-href="/portal/notification/#{noti.id}" t-out="noti.name"/>
                                        </div>
                                        <span class="wujia-content-card-row-date" t-out="noti.date and noti.date.strftime('%H:%M %d/%m/%Y') or ''"/>
                                        <t t-set="noti_badge_cls" t-value="{'URG': 'wujia-badge-danger', 'GEN': 'wujia-badge-info', 'PROMO': 'wujia-badge-warning', 'SYS': 'wujia-badge-muted', 'OTH': 'wujia-badge-success'}.get(noti.type_id.code, 'wujia-badge-muted')"/>
                                        <span t-if="noti.type_id" t-attf-class="wujia-badge #{noti_badge_cls}" t-out="noti.type_id.name"/>
                                        <span t-else=""/>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Recent orders (UI-12, Sprint 9.13) -->
                        <div class="col-lg-6 col-12 mb-2">
                            <div class="wujia-content-card">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-shopping-cart"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">Đơn hàng gần đây</h4>
                                    <a href="/portal/purchase-history" class="wujia-content-card-header-link">
                                        Xem tất cả
                                        <i class="feather icon-chevron-right"/>
                                    </a>
                                </div>
                                <div t-if="not recent_orders" class="wujia-content-card-empty">Chưa có đơn hàng nào.</div>
                                <ul t-else="" class="wujia-content-card-body">
                                    <li t-foreach="recent_orders" t-as="order" class="wujia-content-card-row">
                                        <span class="wujia-content-card-row-bullet"/>
                                        <div class="wujia-content-card-row-content">
                                            <a t-attf-href="/portal/purchase-history/#{order.id}">
                                                Đơn hàng <t t-out="order.name"/>
                                            </a>
                                        </div>
                                        <span class="wujia-content-card-row-date" t-out="order.date_order and order.date_order.strftime('%H:%M %d/%m/%Y') or ''"/>
                                        <t t-set="order_badge_cls" t-value="{'draft': 'wujia-badge-muted', 'sent': 'wujia-badge-info', 'sale': 'wujia-badge-success', 'done': 'wujia-badge-success', 'cancel': 'wujia-badge-danger'}.get(order.state, 'wujia-badge-muted')"/>
                                        <t t-set="order_state_label" t-value="{'draft': 'Nháp', 'sent': 'Đã gửi', 'sale': 'Đã xác nhận', 'done': 'Hoàn thành', 'cancel': 'Đã huỷ'}.get(order.state, order.state)"/>
                                        <span t-attf-class="wujia-badge #{order_badge_cls}" t-out="order_state_label"/>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Latest return requests (UI-12, Sprint 9.13) -->
                        <div class="col-lg-6 col-12 mb-2">
                            <div class="wujia-content-card">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-corner-up-left"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">Yêu cầu đổi trả gần đây</h4>
                                    <a href="/portal/return" class="wujia-content-card-header-link">
                                        Xem tất cả
                                        <i class="feather icon-chevron-right"/>
                                    </a>
                                </div>
                                <div t-if="not latest_returns" class="wujia-content-card-empty">Chưa có yêu cầu nào.</div>
                                <ul t-else="" class="wujia-content-card-body">
                                    <li t-foreach="latest_returns" t-as="rr" class="wujia-content-card-row">
                                        <span class="wujia-content-card-row-bullet"/>
                                        <div class="wujia-content-card-row-content">
                                            <a t-attf-href="/portal/return/#{rr.id}">
                                                Đổi trả <t t-out="rr.name or '—'"/>
                                            </a>
                                        </div>
                                        <span class="wujia-content-card-row-date" t-out="rr.request_date and rr.request_date.strftime('%H:%M %d/%m/%Y') or ''"/>
                                        <t t-set="rr_badge_cls" t-value="{'draft': 'wujia-badge-muted', 'sent': 'wujia-badge-info', 'approved': 'wujia-badge-success', 'rejected': 'wujia-badge-danger', 'done': 'wujia-badge-success'}.get(rr.state, 'wujia-badge-muted')"/>
                                        <t t-set="rr_state_label" t-value="{'draft': 'Nháp', 'sent': 'Đã gửi', 'approved': 'Đã duyệt', 'rejected': 'Từ chối', 'done': 'Hoàn thành'}.get(rr.state, rr.state)"/>
                                        <span t-attf-class="wujia-badge #{rr_badge_cls}" t-out="rr_state_label"/>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Top products (UI-17, Sprint 9.16 2026-06-02): chuẩn theo
                             content-card listing như đặt hàng / lịch sử đặt hàng -->
                        <div class="col-lg-6 col-12 mb-2">
                            <div class="wujia-content-card">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-trending-up"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">Sản phẩm mua nhiều nhất</h4>
                                </div>
                                <div t-if="not top_products" class="wujia-content-card-empty">Chưa có dữ liệu.</div>
                                <table t-else="" class="wujia-content-card-table">
                                    <thead>
                                        <tr>
                                            <th>Sản phẩm</th>
                                            <th class="text-end">SL</th>
                                            <th>ĐVT</th>
                                            <th class="text-end">Tổng</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="top_products" t-as="p">
                                            <td t-out="p['name']"/>
                                            <td class="text-end" t-out="'{:,.0f}'.format(p['qty']).replace(',', '.')"/>
                                            <td t-out="p['uom']"/>
                                            <td class="text-end" t-out="'{:,.0f}'.format(p['total']).replace(',', '.') + ' ₫'"/>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
                <!-- /desktop wrapper -->

                <!-- ======== MOBILE (<992px) — Figma BA Sprint 10 (frame 2474:2) ======== -->
                <div class="wujia-mhome d-lg-none">
                    <div t-if="not franchise_ids" class="alert alert-warning" role="alert">
                        Bạn chưa được gán vào cửa hàng nào. Vui lòng liên hệ quản trị viên.
                    </div>
                    <t t-else="">
                        <!-- Hero: TỔNG QUAN CỬA HÀNG (nền tối) -->
                        <section class="wujia-mhome-hero">
                            <!-- 2 cột: trái = cửa hàng, phải = Vai trò + badge (Figma) -->
                            <div class="wujia-mhome-hero-top">
                                <div class="wujia-mhome-hero-left">
                                    <p class="wujia-mhome-hero-label">TỔNG QUAN CỬA HÀNG</p>
                                    <p class="wujia-mhome-hero-store" t-out="active_franchise.display_name or request.env.user.name"/>
                                    <p t-if="active_franchise.address" class="wujia-mhome-hero-addr" t-out="active_franchise.address"/>
                                    <p t-if="active_franchise.area_name" class="wujia-mhome-hero-area" t-out="active_franchise.area_name"/>
                                </div>
                                <div t-if="active_role" class="wujia-mhome-hero-right">
                                    <p class="wujia-mhome-hero-label">Vai trò</p>
                                    <span class="wujia-mhome-role-badge">
                                        <t t-if="active_role == 'manager'">Manager</t>
                                        <t t-elif="active_role == 'owner'">Owner</t>
                                        <t t-elif="active_role == 'staff'">Staff</t>
                                    </span>
                                </div>
                            </div>
                            <!-- 4 KPI nhúng (Đơn hàng / Thông báo / Đổi trả / Công nợ) -->
                            <div class="wujia-mhome-hero-kpis">
                                <a href="/portal/purchase-history" class="wujia-mhome-kpi">
                                    <span class="wujia-mhome-kpi-label">Đơn hàng</span>
                                    <span class="wujia-mhome-kpi-value" t-out="recent_orders_count or 0"/>
                                </a>
                                <a href="/portal/notification" class="wujia-mhome-kpi">
                                    <span class="wujia-mhome-kpi-label">Thông báo</span>
                                    <span class="wujia-mhome-kpi-value" t-out="unread_count or 0"/>
                                </a>
                                <a href="/portal/return" class="wujia-mhome-kpi">
                                    <span class="wujia-mhome-kpi-label">Đổi trả</span>
                                    <span class="wujia-mhome-kpi-value" t-out="return_requests_count or 0"/>
                                </a>
                                <!-- CÔNG NỢ: Sprint 17 — chưa build (account.move = Phase 2).
                                     Tile inert UI-only "0 ₫" (KHÔNG link — module /portal/debt đã xoá).
                                     Dựng section + wire khi cần. -->
                                <div class="wujia-mhome-kpi">
                                    <span class="wujia-mhome-kpi-label">Công nợ</span>
                                    <span class="wujia-mhome-kpi-value">0 ₫</span>
                                </div>
                            </div>
                        </section>

                        <!-- Card: KHUNG GIỜ ĐẶT HÀNG (3 trạng thái) -->
                        <section class="wujia-mhome-window">
                            <div class="wujia-mhome-window-head">
                                <h3 class="wujia-mhome-window-title">Khung giờ đặt hàng</h3>
                                <span t-if="order_window['state'] == 'open'" class="wujia-mhome-window-status is-open">
                                    Đang mở <small>· còn <t t-out="order_window['remaining_hhmm']"/></small>
                                </span>
                                <span t-elif="order_window['state'] == 'closed'" class="wujia-mhome-window-status is-closed">Đã đóng</span>
                                <span t-else="" class="wujia-mhome-window-status is-always">Đặt hàng 24/7</span>
                            </div>
                            <div t-if="order_window['state'] == 'open'" class="wujia-mhome-window-progress">
                                <div class="wujia-mhome-window-progress-bar" t-attf-style="width: #{order_window['progress_pct']}%"/>
                            </div>
                            <p t-if="order_window['state'] == 'open'" class="wujia-mhome-window-caption">
                                Có thể đặt hàng đến <t t-out="order_window['to_hhmm']"/> hôm nay
                            </p>
                            <p t-elif="order_window['state'] == 'closed'" class="wujia-mhome-window-caption">
                                Mở lại lúc <t t-out="order_window['from_hhmm']"/>
                            </p>
                            <p t-else="" class="wujia-mhome-window-caption">Đặt hàng mọi lúc trong ngày</p>
                        </section>

                        <!-- Grid: Hành động nhanh (6 nút) -->
                        <section class="wujia-mhome-actions">
                            <h3 class="wujia-mhome-section-title">Hành động nhanh</h3>
                            <div class="wujia-mhome-actions-grid">
                                <a href="/portal/order" class="wujia-mhome-action">
                                    <i class="feather icon-shopping-cart"/>
                                    <span class="wujia-mhome-action-label">Đặt hàng</span>
                                </a>
                                <a href="/portal/purchase-history" class="wujia-mhome-action">
                                    <i class="feather icon-clock"/>
                                    <span class="wujia-mhome-action-label">Lịch sử đặt hàng</span>
                                </a>
                                <a href="/portal/delivery" class="wujia-mhome-action">
                                    <i class="feather icon-truck"/>
                                    <span class="wujia-mhome-action-label">Giao hàng</span>
                                </a>
                                <a href="/portal/return" class="wujia-mhome-action">
                                    <i class="feather icon-corner-up-left"/>
                                    <span class="wujia-mhome-action-label">Đổi trả</span>
                                </a>
                                <a href="/portal/knowledge" class="wujia-mhome-action">
                                    <i class="feather icon-book"/>
                                    <span class="wujia-mhome-action-label">Kiến thức</span>
                                </a>
                                <a href="/portal/support" class="wujia-mhome-action">
                                    <i class="feather icon-life-buoy"/>
                                    <span class="wujia-mhome-action-label">Hỗ trợ</span>
                                </a>
                            </div>
                        </section>

                        <!-- Thông báo nổi bật -->
                        <section class="wujia-mhome-noti">
                            <div class="wujia-mhome-noti-head">
                                <h3 class="wujia-mhome-section-title">Thông báo nổi bật</h3>
                                <a href="/portal/notification" class="wujia-mhome-noti-link">Xem tất cả ›</a>
                            </div>
                            <div t-if="not latest_notifications" class="wujia-empty-state">
                                <i class="feather icon-bell"/>
                                <p>Chưa có thông báo nào.</p>
                            </div>
                            <div t-else="" class="wujia-mhome-noti-list">
                                <t t-foreach="latest_notifications" t-as="noti">
                                    <t t-set="noti_badge_cls" t-value="{'URG': 'wujia-badge-danger', 'GEN': 'wujia-badge-info', 'PROMO': 'wujia-badge-warning', 'SYS': 'wujia-badge-muted', 'OTH': 'wujia-badge-success'}.get(noti.type_id.code, 'wujia-badge-muted')"/>
                                    <t t-set="noti_accent_cls" t-value="{'URG': 'is-danger', 'GEN': 'is-info', 'PROMO': 'is-warning', 'SYS': 'is-muted', 'OTH': 'is-success'}.get(noti.type_id.code, 'is-muted')"/>
                                    <a t-attf-href="/portal/notification/#{noti.id}" t-attf-class="wujia-mhome-noti-row #{noti_accent_cls}">
                                        <div class="wujia-mhome-noti-main">
                                            <p class="wujia-mhome-noti-title" t-out="noti.name"/>
                                            <p class="wujia-mhome-noti-date" t-out="noti.date and noti.date.strftime('%H:%M %d/%m/%Y') or ''"/>
                                        </div>
                                        <span t-if="noti.type_id" t-attf-class="wujia-badge #{noti_badge_cls}" t-out="noti.type_id.name"/>
                                    </a>
                                </t>
                            </div>
                        </section>

                        <!-- ============================================================
                             Sprint 16 dashboard merged to Home — BA reviewing, may change.
                             3 màn dashboard (Figma mobile_dashboard 2474:2) gộp về Home
                             (dedupe: "Đơn hàng gần đây"/"Giao hàng sắp tới" mỗi mục 1 lần).
                             Reuse class .wujia-mdash-* (wujia_portal_layout). Công nợ BỎ
                             đợt này (build sau). ============================================ -->

                        <!-- Đơn hàng gần đây -->
                        <section class="wujia-mdash-sec">
                            <div class="wujia-mdash-titlerow">
                                <h2 class="wujia-mdash-title">Đơn hàng gần đây</h2>
                                <a href="/portal/purchase-history" class="wujia-mdash-link">Xem tất cả ›</a>
                            </div>
                            <div class="wujia-mdash-card wujia-mdash-list">
                                <div t-if="not recent_orders" class="wj-empty-state--compact">Chưa có đơn hàng.</div>
                                <t t-foreach="recent_orders" t-as="o">
                                    <a t-attf-href="/portal/purchase-history/#{o.id}" class="wujia-mdash-row">
                                        <span class="wujia-mdash-tile"><i class="feather icon-file-text"/></span>
                                        <span class="wujia-mdash-row-main">
                                            <span class="wujia-mdash-row-title is-lg" t-out="o.name"/>
                                            <span class="wujia-mdash-row-sub"
                                                  t-out="o.date_order and o.date_order.strftime('%H:%M %d/%m/%Y') or ''"/>
                                        </span>
                                        <span class="wujia-mdash-amount"
                                              t-out="'{:,.0f}'.format(o.amount_total).replace(',', '.') + ' đ'"/>
                                        <t t-set="lbl" t-value="m_order_badges.get(o.state, (o.state, 'wujia-badge-muted'))"/>
                                        <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        <i class="feather icon-chevron-right wujia-mdash-chev"/>
                                    </a>
                                </t>
                            </div>
                        </section>

                        <!-- Giao hàng sắp tới -->
                        <section class="wujia-mdash-sec">
                            <div class="wujia-mdash-titlerow">
                                <h2 class="wujia-mdash-title">Giao hàng sắp tới</h2>
                                <a href="/portal/delivery" class="wujia-mdash-link">Xem tất cả ›</a>
                            </div>
                            <div class="wujia-mdash-stack">
                                <div t-if="not m_upcoming_batches" class="wujia-mdash-card wj-empty-state--compact">Chưa có chuyến giao sắp tới.</div>
                                <t t-foreach="m_upcoming_batches" t-as="it">
                                    <a t-attf-href="/portal/delivery/#{it['batch'].id}" class="wujia-mdash-card wujia-mdash-item">
                                        <span class="wujia-mdash-tile"><i class="feather icon-truck"/></span>
                                        <span class="wujia-mdash-row-main">
                                            <span class="wujia-mdash-row-title" t-out="it['batch'].name"/>
                                            <span class="wujia-mdash-row-sub is-strong" t-out="it['when']"/>
                                            <span class="wujia-mdash-row-sub">Tổng đơn: <t t-out="it['order_count']"/> đơn</span>
                                            <span class="wujia-mdash-row-sub is-strong">
                                                Tổng tiền: <t t-out="'{:,.0f}'.format(it['total']).replace(',', '.') + ' đ'"/>
                                            </span>
                                        </span>
                                        <span t-attf-class="wujia-badge #{it['badge'][1]}" t-out="it['badge'][0]"/>
                                    </a>
                                </t>
                            </div>
                        </section>

                        <!-- Yêu cầu đổi trả gần đây -->
                        <section class="wujia-mdash-sec">
                            <div class="wujia-mdash-titlerow">
                                <h2 class="wujia-mdash-title">Yêu cầu đổi trả gần đây</h2>
                                <a href="/portal/return" class="wujia-mdash-link">Xem tất cả ›</a>
                            </div>
                            <div class="wujia-mdash-stack">
                                <div t-if="not latest_returns" class="wujia-mdash-card wj-empty-state--compact">Chưa có yêu cầu đổi trả.</div>
                                <t t-foreach="latest_returns" t-as="r">
                                    <a t-attf-href="/portal/return/#{r.id}" class="wujia-mdash-card wujia-mdash-item">
                                        <span class="wujia-mdash-row-main">
                                            <span class="wujia-mdash-row-title" t-out="r.name"/>
                                            <span class="wujia-mdash-row-sub">
                                                Ngày yêu cầu: <t t-out="r.request_date and r.request_date.strftime('%d/%m/%Y') or '—'"/>
                                            </span>
                                            <span class="wujia-mdash-row-sub is-strong">
                                                Lý do: <t t-out="r.error_id.name or '—'"/>
                                            </span>
                                            <!-- UI-only: model chưa có field tổng tiền (NOTE BA) -->
                                            <span class="wujia-mdash-row-sub is-strong is-xs">Tổng tiền: —</span>
                                        </span>
                                        <t t-set="lbl" t-value="m_return_badges.get(r.state, (r.state, 'wujia-badge-muted'))"/>
                                        <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                    </a>
                                </t>
                            </div>
                        </section>

                        <!-- Bài viết / Kiến thức mới -->
                        <section class="wujia-mdash-sec">
                            <div class="wujia-mdash-titlerow">
                                <h2 class="wujia-mdash-title">Bài viết / Kiến thức mới</h2>
                                <a href="/portal/knowledge" class="wujia-mdash-link">Xem tất cả ›</a>
                            </div>
                            <div class="wujia-mdash-card wujia-mdash-list">
                                <div t-if="not articles" class="wj-empty-state--compact">Chưa có bài viết.</div>
                                <t t-foreach="articles" t-as="art">
                                    <a t-attf-href="/portal/knowledge/#{art.slug}" class="wujia-mdash-row">
                                        <span class="wujia-mdash-tile"><i class="feather icon-file-text"/></span>
                                        <span class="wujia-mdash-row-main">
                                            <span class="wujia-mdash-row-title is-sm" t-out="art.name"/>
                                            <span class="wujia-mdash-row-sub is-xs"
                                                  t-out="art.publish_date and art.publish_date.strftime('%d/%m/%Y') or ''"/>
                                        </span>
                                        <i class="feather icon-chevron-right wujia-mdash-chev"/>
                                    </a>
                                </t>
                            </div>
                        </section>

                        <!-- Hỗ trợ nhanh (Chat UI-only href # — chưa có channel) -->
                        <section class="wujia-mdash-sec">
                            <div class="wujia-mdash-titlerow">
                                <h2 class="wujia-mdash-title">Hỗ trợ nhanh</h2>
                            </div>
                            <div class="wujia-mdash-card wujia-mdash-list">
                                <a href="/portal/support/new" class="wujia-mdash-row">
                                    <span class="wujia-mdash-tile"><i class="feather icon-headphones"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-title is-sm">Tạo yêu cầu hỗ trợ</span>
                                        <span class="wujia-mdash-row-sub">Gửi yêu cầu và theo dõi phản hồi</span>
                                    </span>
                                    <i class="feather icon-chevron-right wujia-mdash-chev"/>
                                </a>
                                <a t-attf-href="tel:#{m_hotline or ''}" class="wujia-mdash-row">
                                    <span class="wujia-mdash-tile"><i class="feather icon-phone-call"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-title is-sm">Gọi hotline</span>
                                        <span class="wujia-mdash-row-sub is-primary" t-out="m_hotline or '—'"/>
                                    </span>
                                    <i class="feather icon-chevron-right wujia-mdash-chev"/>
                                </a>
                                <a href="#" class="wujia-mdash-row">
                                    <span class="wujia-mdash-tile"><i class="feather icon-message-circle"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-title is-sm">Chat với chúng tôi</span>
                                        <span class="wujia-mdash-row-sub is-primary">Thời gian: 8:00 - 17:30</span>
                                    </span>
                                    <i class="feather icon-chevron-right wujia-mdash-chev"/>
                                </a>
                            </div>
                        </section>

                        <!-- Thông tin cửa hàng -->
                        <section class="wujia-mdash-sec">
                            <div class="wujia-mdash-titlerow">
                                <h2 class="wujia-mdash-title">Thông tin cửa hàng</h2>
                            </div>
                            <div class="wujia-mdash-card wujia-mdash-list">
                                <div class="wujia-mdash-row">
                                    <span class="wujia-mdash-ico"><i class="feather icon-map-pin"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-sub">Địa chỉ</span>
                                        <span class="wujia-mdash-row-sub is-strong" t-out="active_franchise.address or '—'"/>
                                    </span>
                                </div>
                                <div class="wujia-mdash-row">
                                    <span class="wujia-mdash-ico"><i class="feather icon-phone"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-sub">Điện thoại</span>
                                        <span class="wujia-mdash-row-sub is-strong" t-out="active_franchise.phone or '—'"/>
                                    </span>
                                </div>
                                <div class="wujia-mdash-row">
                                    <span class="wujia-mdash-ico"><i class="feather icon-user"/></span>
                                    <span class="wujia-mdash-row-main">
                                        <span class="wujia-mdash-row-sub">Người phụ trách</span>
                                        <span class="wujia-mdash-row-sub is-strong"
                                              t-out="active_franchise.main_owner_member_id.user_id.name or '—'"/>
                                    </span>
                                </div>
                            </div>
                        </section>
                    </t>
                </div>
                <!-- Bottom-nav moved to shared wujia_portal_layout.mobile_bottomnav
                     (Sprint 11, item 10.1 — promoted portal-wide via app_layout).
                     Bottom spacing now handled globally in _components.css. -->
            </div>
        </t>
    </template>

</odoo>
