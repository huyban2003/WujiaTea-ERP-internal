<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit `wujia_portal_layout.app_layout` để:
         1. Set context vars cho active franchise (đọc cookie + browse 1 lần / page).
         2. Chèn modal store picker vào cuối body (template store_picker_modal).
         3. Chèn data attribute body[data-must-pick-franchise] để JS biết có mở modal không. -->
    <template id="app_layout_inherit_store_picker"
              inherit_id="wujia_portal_layout.app_layout"
              priority="20"
              name="Wujia App Layout — Store Picker Wrap">
        <!-- Insert TRƯỚC top navbar để badge top navbar đọc được biến.
             1 query browse + 1 ormcached lookup / page. -->
        <xpath expr="//t[@t-call='wujia_portal_layout.layout_top_navbar']" position="before">
            <t t-set="_wujia_accessible_ids"
               t-value="request.env.user._get_accessible_franchise_ids()"/>
            <t t-set="_wujia_active_fid_raw"
               t-value="request.httprequest.cookies.get('wujia_active_franchise_id')"/>
            <t t-set="_wujia_active_fid"
               t-value="int(_wujia_active_fid_raw) if (_wujia_active_fid_raw and _wujia_active_fid_raw.isdigit() and int(_wujia_active_fid_raw) in _wujia_accessible_ids) else (_wujia_accessible_ids[0] if len(_wujia_accessible_ids) == 1 else False)"/>
            <t t-set="_wujia_active_franchise"
               t-value="request.env['wujia.franchise.management'].sudo().browse(_wujia_active_fid) if _wujia_active_fid else None"/>
            <t t-set="_wujia_must_pick"
               t-value="len(_wujia_accessible_ids) &gt; 1 and not (_wujia_active_fid_raw and _wujia_active_fid_raw.isdigit() and int(_wujia_active_fid_raw) in _wujia_accessible_ids)"/>
            <t t-set="all_accessible_franchises"
               t-value="request.env['wujia.franchise.management'].sudo().browse(list(_wujia_accessible_ids))"/>
            <t t-set="active_franchise_id" t-value="_wujia_active_fid"/>
            <t t-set="_wujia_active_membership"
               t-value="request.env['wujia.franchise.member'].sudo().find_active_membership(request.env.user.id, _wujia_active_fid) if _wujia_active_fid else False"/>
            <t t-set="_wujia_active_role"
               t-value="_wujia_active_membership.role if _wujia_active_membership else False"/>
        </xpath>
        <!-- Modal đặt sau cùng + flag body để JS biết phải mở -->
        <xpath expr="//div[hasclass('drag-target')]" position="after">
            <t t-call="wujia_portal_base.store_picker_modal"/>
            <script>
                document.body.dataset.mustPickFranchise =
                    "<t t-out="'1' if _wujia_must_pick else '0'"/>";
            </script>
        </xpath>
    </template>

    <!-- Inherit top navbar — chèn badge "Đang tại: <tên>" vào SÁT BÊN TRÁI header
         (UI-03 mockup image28: pill Current Store nằm cụm trái, không phải phải). -->
    <template id="layout_top_navbar_inherit_store_badge"
              inherit_id="wujia_portal_layout.layout_top_navbar"
              priority="20"
              name="Wujia Top Navbar — Active Store Badge">
        <xpath expr="//div[hasclass('bookmark-wrapper')]/ul[hasclass('navbar-nav')]" position="inside">
            <li class="nav-item d-none d-md-flex align-items-center"
                t-if="_wujia_active_franchise">
                <a href="#" data-action="open-store-picker"
                   class="wujia-active-store-badge"
                   t-att-title="_wujia_active_franchise.display_name">
                    <span class="wujia-store-badge-text">
                        <span class="wujia-store-badge-label">Cửa hàng hiện tại</span>
                        <strong class="wujia-store-badge-name" t-out="_wujia_active_franchise.display_name"/>
                    </span>
                </a>
            </li>
            <li class="nav-item d-none d-md-flex align-items-center"
                t-if="_wujia_active_role">
                <span t-attf-class="wujia-store-role-badge wujia-store-role-badge-#{_wujia_active_role}">
                    <t t-if="_wujia_active_role == 'manager'">Manager</t>
                    <t t-elif="_wujia_active_role == 'owner'">Owner</t>
                    <t t-elif="_wujia_active_role == 'staff'">Staff</t>
                </span>
            </li>
        </xpath>
    </template>

</odoo>
