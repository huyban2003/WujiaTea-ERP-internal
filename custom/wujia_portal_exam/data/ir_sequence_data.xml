<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_wujia_exam_registration" model="ir.sequence">
        <field name="name">Wujia Exam Registration</field>
        <field name="code">wujia.exam.registration</field>
        <field name="prefix">WJ-EXR/%(y)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_wujia_exam_course" model="ir.sequence">
        <field name="name">Wujia Exam Course</field>
        <field name="code">wujia.exam.course</field>
        <field name="prefix">WJ-CRS/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_wujia_exam_session" model="ir.sequence">
        <field name="name">Wujia Exam Session</field>
        <field name="code">wujia.exam.session</field>
        <field name="prefix">WJ-EXS/%(y)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
