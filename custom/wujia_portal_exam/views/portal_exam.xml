<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== Lịch thi ============== -->
    <template id="portal_exam_schedule" name="Wujia Portal — Exam Schedule">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Lịch thi</t>
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-calendar me-1"/>Lịch thi sắp tới
                        </h2>
                    </div>
                </div>
                <div class="content-body">
                    <div t-if="not upcoming" class="alert alert-info">
                        Hiện không có kỳ thi nào sắp tới. Vui lòng quay lại sau.
                    </div>
                    <div t-else="" class="row g-2">
                        <t t-foreach="upcoming" t-as="exam">
                            <div class="col-md-6 col-lg-4 col-12">
                                <div class="card exam-card h-100">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="card-title mb-0" t-out="exam.name"/>
                                            <t t-set="lbl" t-value="schedule_labels.get(exam.state, (exam.state, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </div>
                                        <p class="text-muted small mb-2">
                                            <i class="fa fa-clock me-1"/>
                                            <strong t-out="exam.exam_date.strftime('%d/%m/%Y %H:%M')"/>
                                            <br/>
                                            <i class="fa fa-map-marker-alt me-1"/>
                                            <span t-out="exam.location or 'Online'"/>
                                        </p>
                                        <p t-if="exam.description" t-out="exam.description" class="exam-card-desc"/>
                                        <p class="small text-muted mb-2">
                                            <span t-out="exam.registration_count"/>
                                            <t t-if="exam.max_participants">/<t t-out="exam.max_participants"/></t>
                                            người đã đăng ký
                                        </p>
                                        <t t-if="exam.id in my_reg_schedule_ids">
                                            <button type="button" class="btn btn-success btn-sm w-100" disabled="disabled">
                                                <i class="fa fa-check me-1"/>Đã đăng ký
                                            </button>
                                        </t>
                                        <t t-else="">
                                            <button type="button"
                                                    class="btn btn-primary btn-sm w-100 btn-register-exam"
                                                    t-att-data-schedule-id="exam.id">
                                                <i class="fa fa-user-plus me-1"/>Đăng ký
                                            </button>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Mobile <992px — Figma s0 "Đăng ký thi" (S26, #4755:2) -->
            <div class="d-lg-none wujia-mpage wujia-mexam">
                <div class="wujia-mexam-head-list">
                    <h1 class="wujia-mexam-title">Đăng ký thi</h1>
                    <p class="wujia-mexam-subtitle">
                        <t t-out="len(m_exam_items)"/> đăng ký trong cửa hàng hiện tại
                    </p>
                </div>

                <!-- Filter canonical 04-DateRangeOnly (Figma 4785:862) — demo UI-only (Phase 2 wire) -->
                <div class="wj-filter-card">
                    <div class="wj-filter-dates wj-filter-dates--compact">
                        <label class="wj-filter-date">
                            <i class="feather icon-calendar"/>
                            <input type="date"/>
                        </label>
                        <span class="wj-filter-date-sep">–</span>
                        <label class="wj-filter-date">
                            <i class="feather icon-calendar"/>
                            <input type="date"/>
                        </label>
                        <button type="button" class="wj-filter-search-btn"><i class="feather icon-search"/></button>
                    </div>
                </div>

                <!-- Empty: chưa có đăng ký (no-data chung Figma 4788:974) -->
                <div t-if="not m_exam_items" class="wj-empty-state wj-empty-state--rich">
                    <span class="wj-empty-state-icon"/>
                    <p class="wj-empty-state-title">Chưa có đăng ký thi</p>
                    <p class="wj-empty-state-sub">Hiện chưa có đăng ký nào để hiển thị.</p>
                    <p class="wj-empty-state-sub">Tạo đăng ký mới để bắt đầu.</p>
                    <a href="/portal/exam/register" class="wj-empty-state-btn">
                        <i class="feather icon-plus"/> Đăng ký mới
                    </a>
                </div>
                <div t-else="" class="wujia-mexam-list">
                    <a t-foreach="m_exam_items" t-as="item" t-att-href="item['link']"
                       class="wujia-mexam-card">
                        <div class="wujia-mexam-card-top">
                            <h3 class="wujia-mexam-card-title" t-out="item['title']"/>
                            <span t-attf-class="wujia-badge #{item['badge']} wujia-mexam-card-badge"
                                  t-out="item['status']"/>
                        </div>
                        <p class="wujia-mexam-card-line">
                            <i class="feather icon-calendar"/>
                            <span t-out="item['date_label']"/>
                        </p>
                        <p class="wujia-mexam-card-line">
                            <i class="feather icon-user"/>
                            <span t-out="item['meta']"/>
                        </p>
                    </a>
                </div>

                <a href="/portal/exam/register" class="wujia-mexam-fab">
                    <i class="feather icon-plus"/>
                    <span>Đăng ký mới</span>
                </a>
            </div>
        </t>
    </template>

    <!-- ============== Đăng ký của tôi ============== -->
    <template id="portal_exam_my" name="Wujia Portal — My Exam Registrations">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Đăng ký của tôi</t>
            <div class="content-wrapper">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-user-check me-1"/>Đăng ký dự thi của tôi
                        </h2>
                    </div>
                </div>
                <div class="content-body">
                    <div t-if="not my_regs" class="alert alert-info">
                        Bạn chưa đăng ký kỳ thi nào. <a href="/portal/exam">Xem lịch thi sắp tới</a>.
                    </div>
                    <div t-else="" class="wujia-content-card">
                        <div class="wujia-content-card-header">
                            <div class="wujia-content-card-header-icon">
                                <i class="feather icon-user-check"/>
                            </div>
                            <h4 class="wujia-content-card-header-title">Đăng ký dự thi</h4>
                            <span class="wujia-content-card-header-link">
                                <t t-out="len(my_regs)"/> đăng ký
                            </span>
                        </div>
                        <div class="table-responsive">
                            <table class="wujia-content-card-table">
                                <thead><tr>
                                    <th>Mã</th><th>Kỳ thi</th><th>Ngày thi</th><th>Cửa hàng</th><th class="text-center">Trạng thái</th>
                                </tr></thead>
                                <tbody>
                                    <tr t-foreach="my_regs" t-as="r">
                                        <td t-out="r.name"/>
                                        <td t-out="r.schedule_id.name"/>
                                        <td t-out="r.schedule_id.exam_date and r.schedule_id.exam_date.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <td t-out="r.franchise_id.name or '—'"/>
                                        <td class="text-center">
                                            <t t-set="lbl" t-value="reg_labels.get(r.state, (r.state, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{lbl[1]}" t-out="lbl[0]"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============== Chi tiết kỳ thi ============== -->
    <template id="portal_exam_schedule_detail" name="Wujia Portal — Exam Schedule Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Chi tiết kỳ thi</t>
            <div class="content-wrapper">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav><ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/portal/exam">Lịch thi</a></li>
                            <li class="breadcrumb-item active" t-out="schedule.name"/>
                        </ol></nav>
                    </div>
                </div>
                <div class="content-body">
                    <div class="card">
                        <div class="card-body">
                            <h3 t-out="schedule.name"/>
                            <t t-set="lbl" t-value="schedule_labels.get(schedule.state, (schedule.state, 'wujia-badge-muted'))"/>
                            <span t-attf-class="wujia-badge #{lbl[1]} mb-2" t-out="lbl[0]"/>
                            <p class="text-muted">
                                <i class="fa fa-clock me-1"/>
                                <strong t-out="schedule.exam_date and schedule.exam_date.strftime('%d/%m/%Y %H:%M') or '—'"/><br/>
                                <i class="fa fa-map-marker-alt me-1"/>
                                <span t-out="schedule.location or 'Online'"/>
                            </p>
                            <p t-if="schedule.description" t-out="schedule.description"/>
                            <p>
                                Đã đăng ký: <strong t-out="schedule.registration_count"/>
                                <t t-if="schedule.max_participants">/ <t t-out="schedule.max_participants"/></t>
                            </p>

                            <div class="mt-3">
                                <t t-if="my_reg">
                                    <button type="button"
                                            class="btn btn-outline-danger btn-exam-cancel"
                                            t-att-data-reg-id="my_reg.id">
                                        <i class="fa fa-times me-1"/>Huỷ đăng ký
                                    </button>
                                </t>
                                <t t-elif="schedule.state == 'open'">
                                    <button type="button"
                                            class="btn btn-primary btn-register-exam"
                                            t-att-data-schedule-id="schedule.id">
                                        <i class="fa fa-user-plus me-1"/>Đăng ký
                                    </button>
                                </t>
                                <t t-else="">
                                    <p class="text-muted">Lịch thi không còn nhận đăng ký.</p>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============== Kết quả ============== -->
    <template id="portal_exam_result" name="Wujia Portal — Exam Results">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Kết quả thi</t>
            <div class="content-wrapper">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-chart-bar me-1"/>Kết quả thi
                        </h2>
                    </div>
                </div>
                <div class="content-body">
                    <div t-if="not results" class="wujia-empty-state">
                        <i class="feather icon-award"/>
                        <p>Bạn chưa có kết quả thi nào.</p>
                    </div>
                    <div t-else="" class="row g-2">
                        <t t-foreach="results" t-as="res">
                            <div class="col-md-6 col-lg-4 col-12">
                                <div class="card exam-result-card h-100">
                                    <div class="card-body text-center">
                                        <h5 class="card-title" t-out="res.schedule_id.name"/>
                                        <p class="text-muted small" t-out="res.schedule_id.exam_date and res.schedule_id.exam_date.strftime('%d/%m/%Y') or ''"/>
                                        <div class="exam-score-wrap mb-2">
                                            <span class="exam-score" t-out="'{:.1f}'.format(res.score or 0)"/>
                                            <span class="exam-score-max">/10</span>
                                        </div>
                                        <span t-if="res.passed" class="wujia-badge wujia-badge-success">
                                            <i class="fa fa-check-circle me-1"/>Đạt
                                        </span>
                                        <span t-else="" class="wujia-badge wujia-badge-danger">
                                            <i class="fa fa-times-circle me-1"/>Chưa đạt
                                        </span>
                                        <p t-if="res.note" class="small text-muted mt-2 mb-0" t-out="res.note"/>
                                        <a t-if="res.certificate_url"
                                           t-att-href="res.certificate_url" target="_blank"
                                           class="btn btn-sm btn-outline-primary mt-2">
                                            <i class="fa fa-certificate me-1"/>Tải chứng nhận
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============== Đăng ký mới — wizard s1→s5 (mobile, UI-only) ============== -->
    <template id="portal_exam_register" name="Wujia Portal — Exam Register (mobile wizard)">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Đăng ký thi</t>

            <!-- Desktop: tối ưu cho mobile -->
            <div class="content-wrapper d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title mb-0">Đăng ký thi</h2>
                    </div>
                </div>
                <div class="content-body">
                    <div class="alert alert-info">
                        Luồng đăng ký thi được tối ưu cho thiết bị di động.
                        <a href="/portal/exam">← Quay lại danh sách</a>
                    </div>
                </div>
            </div>

            <!-- Mobile <992px — Figma s1→s5 (S26, #4755:2) -->
            <div class="d-lg-none wujia-mpage wujia-mexam-wizard">

                <!-- STEP 1: Chọn khóa thi -->
                <section data-exam-step="1" class="wujia-mexam-panel">
                    <div class="wujia-mexam-head">
                        <a href="/portal/exam" class="wujia-mexam-back">
                            <i class="feather icon-chevron-left"/>
                        </a>
                        <div class="wujia-mexam-head-main">
                            <h1 class="wujia-mexam-h1">Chọn khóa thi</h1>
                            <p class="wujia-mexam-sub">Chọn khóa còn lịch để tiếp tục</p>
                        </div>
                        <span class="wujia-mexam-stepbadge">Bước 1/4</span>
                    </div>
                    <div class="wj-filter-chips wujia-mexam-chips">
                        <a href="#" class="wj-filter-chip wj-filter-chip--soft is-active"
                           data-exam-cfilter="all">Tất cả</a>
                        <a href="#" class="wj-filter-chip wj-filter-chip--soft"
                           data-exam-cfilter="open">Còn lịch</a>
                        <a href="#" class="wj-filter-chip wj-filter-chip--soft"
                           data-exam-cfilter="closed">Đã đóng</a>
                    </div>
                    <div class="wujia-mexam-courselist">
                        <t t-foreach="courses" t-as="c">
                            <div t-attf-class="wujia-mexam-course #{c['closed'] and 'is-closed' or ''}"
                                 t-att-data-exam-closed="c['closed'] and '1' or '0'">
                                <div class="wujia-mexam-course-main">
                                    <h3 class="wujia-mexam-course-title" t-out="c['title']"/>
                                    <p class="wujia-mexam-course-meta" t-out="c['meta']"/>
                                    <span t-attf-class="wujia-badge #{c['badge']} wujia-mexam-course-badge"
                                          t-out="c['status']"/>
                                </div>
                                <a t-if="not c['closed']" href="#"
                                   class="wujia-mexam-course-choose" data-exam-goto="2">Chọn</a>
                            </div>
                        </t>
                    </div>
                </section>

                <!-- STEP 2: Chọn lịch thi (calendar + popup khung giờ) -->
                <section data-exam-step="2" class="wujia-mexam-panel" hidden="hidden">
                    <div class="wujia-mexam-head">
                        <a href="#" class="wujia-mexam-back" data-exam-goto="1">
                            <i class="feather icon-chevron-left"/>
                        </a>
                        <div class="wujia-mexam-head-main">
                            <h1 class="wujia-mexam-h1">Chọn lịch thi</h1>
                            <p class="wujia-mexam-sub">Chọn ngày có lịch trong 60 ngày tiếp theo</p>
                        </div>
                        <span class="wujia-mexam-stepbadge">Bước 2/4</span>
                    </div>

                    <div class="wujia-mexam-selcard">
                        <div class="wujia-mexam-selcard-main">
                            <h3 class="wujia-mexam-selcard-title" t-out="selected_course['title']"/>
                            <p class="wujia-mexam-selcard-meta" t-out="selected_course['meta']"/>
                        </div>
                        <span class="wujia-mexam-selcard-badge">Đã chọn</span>
                    </div>

                    <div class="wujia-mexam-cal">
                        <div class="wujia-mexam-cal-legend">
                            <span class="wujia-mexam-leg is-on"><i class="wujia-mexam-leg-dot"/>Còn chỗ</span>
                            <span class="wujia-mexam-leg is-off"><i class="wujia-mexam-leg-dot"/>Hết chỗ</span>
                            <span class="wujia-mexam-leg is-off"><i class="wujia-mexam-leg-dot"/>Không lịch</span>
                        </div>
                        <div class="wujia-mexam-cal-nav">
                            <button type="button" class="wujia-mexam-cal-navbtn">
                                <i class="feather icon-chevron-left"/>
                            </button>
                            <span class="wujia-mexam-cal-month" t-out="calendar['label']"/>
                            <button type="button" class="wujia-mexam-cal-navbtn">
                                <i class="feather icon-chevron-right"/>
                            </button>
                        </div>
                        <div class="wujia-mexam-cal-grid">
                            <span class="wujia-mexam-cal-wd">T2</span>
                            <span class="wujia-mexam-cal-wd">T3</span>
                            <span class="wujia-mexam-cal-wd">T4</span>
                            <span class="wujia-mexam-cal-wd">T5</span>
                            <span class="wujia-mexam-cal-wd">T6</span>
                            <span class="wujia-mexam-cal-wd">T7</span>
                            <span class="wujia-mexam-cal-wd">CN</span>
                            <t t-foreach="calendar['weeks']" t-as="week">
                                <t t-foreach="week" t-as="d">
                                    <span t-if="not d['in_month']"
                                          class="wujia-mexam-cal-day is-out" t-out="d['day']"/>
                                    <button t-elif="d['state'] == 'available'" type="button"
                                            class="wujia-mexam-cal-day is-available"
                                            t-att-data-exam-date="d['date_label']"
                                            data-exam-open-slots="1">
                                        <span class="wujia-mexam-cal-daynum" t-out="d['day']"/>
                                        <span class="wujia-mexam-cal-daydot"/>
                                    </button>
                                    <span t-else="" class="wujia-mexam-cal-day is-none" t-out="d['day']"/>
                                </t>
                            </t>
                        </div>
                        <div class="wujia-mexam-cal-note">
                            <i class="feather icon-info"/>
                            <span>Chọn ngày còn chỗ để xem khung giờ thi.</span>
                        </div>
                    </div>
                </section>

                <!-- STEP 3: Nhập nhân sự -->
                <section data-exam-step="3" class="wujia-mexam-panel" hidden="hidden">
                    <div class="wujia-mexam-head">
                        <a href="#" class="wujia-mexam-back" data-exam-goto="2">
                            <i class="feather icon-chevron-left"/>
                        </a>
                        <div class="wujia-mexam-head-main">
                            <h1 class="wujia-mexam-h1">Nhập nhân sự</h1>
                            <p class="wujia-mexam-sub">Điền thông tin người tham gia thi</p>
                        </div>
                        <span class="wujia-mexam-stepbadge">Bước 3/4</span>
                    </div>

                    <div class="wujia-mexam-selcard">
                        <div class="wujia-mexam-selcard-main">
                            <h3 class="wujia-mexam-selcard-title" t-out="selected_course['title']"/>
                            <p class="wujia-mexam-selcard-meta" data-exam-sched-line="1">Thứ 5, 02/07/2026 • 08:20</p>
                        </div>
                        <span class="wujia-mexam-selcard-badge">Đã chọn</span>
                    </div>

                    <h2 class="wujia-mexam-sectitle">Danh sách nhân sự</h2>
                    <div class="wujia-mexam-personlist" data-exam-personlist="1">
                        <div class="wujia-mexam-person is-open" data-exam-person="1">
                            <div class="wujia-mexam-person-head">
                                <span class="wujia-mexam-person-name">Nhân sự 1</span>
                                <span class="wujia-mexam-person-req">Bắt buộc</span>
                            </div>
                            <div class="wujia-mexam-person-body">
                                <input class="wujia-mexam-field" placeholder="Họ và tên"/>
                                <input class="wujia-mexam-field" placeholder="Số điện thoại"/>
                                <div class="wujia-mexam-field-row">
                                    <input class="wujia-mexam-field" placeholder="Năm sinh"/>
                                    <input class="wujia-mexam-field" placeholder="Chức vụ"/>
                                </div>
                                <p class="wujia-mexam-person-hint">Thông tin dùng để ghi nhận kết quả thi.</p>
                            </div>
                        </div>
                        <div class="wujia-mexam-person" data-exam-person="2">
                            <div class="wujia-mexam-person-head">
                                <span class="wujia-mexam-person-name">Nhân sự 2</span>
                                <span class="wujia-mexam-person-tools">
                                    <a href="#" class="wujia-mexam-person-toggle" data-exam-person-toggle="1">Nhập thông tin</a>
                                    <button type="button" class="wujia-mexam-person-del" data-exam-person-del="1">
                                        <i class="feather icon-trash-2"/>
                                    </button>
                                </span>
                            </div>
                            <div class="wujia-mexam-person-body" hidden="hidden">
                                <input class="wujia-mexam-field" placeholder="Họ và tên"/>
                                <input class="wujia-mexam-field" placeholder="Số điện thoại"/>
                                <div class="wujia-mexam-field-row">
                                    <input class="wujia-mexam-field" placeholder="Năm sinh"/>
                                    <input class="wujia-mexam-field" placeholder="Chức vụ"/>
                                </div>
                                <p class="wujia-mexam-person-hint">Thông tin dùng để ghi nhận kết quả thi.</p>
                            </div>
                        </div>
                        <div class="wujia-mexam-person" data-exam-person="3">
                            <div class="wujia-mexam-person-head">
                                <span class="wujia-mexam-person-name">Nhân sự 3</span>
                                <span class="wujia-mexam-person-tools">
                                    <a href="#" class="wujia-mexam-person-toggle" data-exam-person-toggle="1">Nhập thông tin</a>
                                    <button type="button" class="wujia-mexam-person-del" data-exam-person-del="1">
                                        <i class="feather icon-trash-2"/>
                                    </button>
                                </span>
                            </div>
                            <div class="wujia-mexam-person-body" hidden="hidden">
                                <input class="wujia-mexam-field" placeholder="Họ và tên"/>
                                <input class="wujia-mexam-field" placeholder="Số điện thoại"/>
                                <div class="wujia-mexam-field-row">
                                    <input class="wujia-mexam-field" placeholder="Năm sinh"/>
                                    <input class="wujia-mexam-field" placeholder="Chức vụ"/>
                                </div>
                                <p class="wujia-mexam-person-hint">Thông tin dùng để ghi nhận kết quả thi.</p>
                            </div>
                        </div>
                    </div>

                    <div class="wujia-mexam-wfooter">
                        <button type="button" class="wujia-mexam-btn wujia-mexam-btn-outline" data-exam-add-person="1">
                            <i class="feather icon-plus"/><span>Thêm người</span>
                        </button>
                        <button type="button" class="wujia-mexam-btn wujia-mexam-btn-primary" data-exam-goto="4">Tiếp tục</button>
                    </div>
                </section>

                <!-- STEP 4: Xác nhận đăng ký -->
                <section data-exam-step="4" class="wujia-mexam-panel" hidden="hidden">
                    <div class="wujia-mexam-head">
                        <a href="#" class="wujia-mexam-back" data-exam-goto="3">
                            <i class="feather icon-chevron-left"/>
                        </a>
                        <div class="wujia-mexam-head-main">
                            <h1 class="wujia-mexam-h1">Xác nhận đăng ký</h1>
                            <p class="wujia-mexam-sub">Kiểm tra trước khi gửi yêu cầu</p>
                        </div>
                        <span class="wujia-mexam-stepbadge">Bước 4/4</span>
                    </div>

                    <div class="wujia-mexam-cfcard">
                        <h2 class="wujia-mexam-cftitle">Thông tin lịch thi</h2>
                        <div class="wujia-mexam-kv">
                            <span class="wujia-mexam-kv-k">Khóa thi</span>
                            <span class="wujia-mexam-kv-v" t-out="selected_course['title']"/>
                        </div>
                        <div class="wujia-mexam-kv">
                            <span class="wujia-mexam-kv-k">Ngày thi</span>
                            <span class="wujia-mexam-kv-v" data-exam-cf-date="1">Thứ 5, 02/07/2026</span>
                        </div>
                        <div class="wujia-mexam-kv">
                            <span class="wujia-mexam-kv-k">Khung giờ</span>
                            <span class="wujia-mexam-kv-v" data-exam-cf-slot="1">08:20</span>
                        </div>
                        <div class="wujia-mexam-kv">
                            <span class="wujia-mexam-kv-k">Địa điểm</span>
                            <span class="wujia-mexam-kv-v">Trung tâm đào tạo Ngô Gia</span>
                        </div>
                    </div>

                    <div class="wujia-mexam-cfcard">
                        <h2 class="wujia-mexam-cftitle">Nhân sự tham gia</h2>
                        <div class="wujia-mexam-cfpeople">
                            <t t-foreach="people" t-as="p">
                                <div class="wujia-mexam-cfperson">
                                    <span class="wujia-mexam-cfperson-name" t-out="p['name']"/>
                                    <span class="wujia-mexam-cfperson-meta"><t t-out="p['role']"/> • <t t-out="p['phone']"/></span>
                                </div>
                            </t>
                        </div>
                    </div>

                    <div class="wujia-mexam-wfooter">
                        <button type="button" class="wujia-mexam-btn wujia-mexam-btn-outline" data-exam-goto="3">Quay lại</button>
                        <button type="button" class="wujia-mexam-btn wujia-mexam-btn-primary" data-exam-submit="1">Xác nhận đăng ký</button>
                    </div>
                </section>

                <!-- Popup Chọn khung giờ (bottom-sheet) -->
                <div class="wujia-mexam-sheet-backdrop" data-exam-slot-close="1"/>
                <div class="wujia-mexam-sheet" role="dialog" aria-modal="true">
                    <div class="wujia-mexam-sheet-handle"/>
                    <h2 class="wujia-mexam-sheet-title">Chọn khung giờ</h2>
                    <p class="wujia-mexam-sheet-sub" data-exam-slot-sub="1">Thứ 5, 02/07/2026 • Đăng ký thi lại</p>
                    <div class="wujia-mexam-slotlist">
                        <t t-foreach="slots" t-as="s">
                            <button type="button"
                                    t-attf-class="wujia-mexam-slot #{not s['available'] and 'is-disabled' or ''}"
                                    t-att-disabled="(not s['available']) and 'disabled' or None"
                                    t-att-data-exam-slot="s['available'] and s['time'] or None">
                                <i class="feather icon-clock wujia-mexam-slot-ico"/>
                                <span class="wujia-mexam-slot-time" t-out="s['time']"/>
                                <span class="wujia-mexam-slot-status" t-out="s['status']"/>
                                <span class="wujia-mexam-slot-radio"><i class="feather icon-check"/></span>
                            </button>
                        </t>
                    </div>
                    <div class="wujia-mexam-sheet-actions">
                        <button type="button" class="wujia-mexam-btn wujia-mexam-btn-outline" data-exam-slot-close="1">Đóng</button>
                        <button type="button" class="wujia-mexam-btn wujia-mexam-btn-primary" data-exam-slot-confirm="1" disabled="disabled">Xác nhận khung giờ</button>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============== Kết quả đăng ký — s6 (mobile, UI-only) ============== -->
    <template id="portal_exam_registration_detail" name="Wujia Portal — Exam Registration Result (mobile)">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Kết quả đăng ký</t>

            <div class="content-wrapper d-none d-lg-block">
                <div class="content-body">
                    <div class="alert alert-info mt-3">
                        Kết quả đăng ký được tối ưu cho thiết bị di động.
                        <a href="/portal/exam">← Quay lại danh sách</a>
                    </div>
                </div>
            </div>

            <!-- Mobile <992px — Figma s6 -->
            <div class="d-lg-none wujia-mpage wujia-mexam-result">
                <div class="wujia-mexam-head">
                    <a href="/portal/exam" class="wujia-mexam-back">
                        <i class="feather icon-chevron-left"/>
                    </a>
                    <div class="wujia-mexam-head-main">
                        <h1 class="wujia-mexam-h1">Kết quả đăng ký</h1>
                        <p class="wujia-mexam-sub">Kết quả theo lịch thi đã đăng ký</p>
                    </div>
                </div>

                <div class="wujia-mexam-rsum">
                    <div class="wujia-mexam-card-top">
                        <h3 class="wujia-mexam-rsum-title" t-out="result['title']"/>
                        <span class="wujia-badge wujia-badge-success wujia-mexam-card-badge">Có kết quả</span>
                    </div>
                    <p class="wujia-mexam-card-line">
                        <i class="feather icon-calendar"/><span t-out="result['date_label']"/>
                    </p>
                    <p class="wujia-mexam-card-line">
                        <i class="feather icon-user"/><span t-out="result['summary']"/>
                    </p>
                    <p class="wujia-mexam-rsum-loc" t-out="result['location']"/>
                </div>

                <h2 class="wujia-mexam-sectitle">Danh sách kết quả</h2>
                <div class="wujia-mexam-rlist">
                    <t t-foreach="result['people']" t-as="p">
                        <div class="wujia-mexam-rrow">
                            <span t-attf-class="wujia-mexam-rrow-ico #{p['passed'] and 'is-pass' or 'is-fail'}">
                                <i t-attf-class="feather #{p['passed'] and 'icon-check' or 'icon-x'}"/>
                            </span>
                            <div class="wujia-mexam-rrow-main">
                                <span class="wujia-mexam-rrow-name" t-out="p['name']"/>
                                <span class="wujia-mexam-rrow-meta"><t t-out="p['role']"/> • <t t-out="p['score']"/></span>
                            </div>
                            <span t-attf-class="wujia-badge #{p['passed'] and 'wujia-badge-success' or 'wujia-badge-danger'} wujia-mexam-rrow-badge"
                                  t-out="p['passed'] and 'Đạt' or 'Không đạt'"/>
                        </div>
                    </t>
                </div>

                <div class="wujia-mexam-cal-note wujia-mexam-rnote">
                    <i class="feather icon-info"/>
                    <span>Người không đạt có thể đăng ký thi lại khi có lịch mở.</span>
                </div>

                <a href="/portal/exam/register" class="wujia-mexam-btn wujia-mexam-btn-primary wujia-mexam-rcta">Đăng ký thi lại</a>
            </div>
        </t>
    </template>

</odoo>
