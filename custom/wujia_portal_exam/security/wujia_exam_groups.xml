<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_groups_privilege_exam" model="res.groups.privilege">
        <field name="name">Wujia Exam</field>
        <field name="category_id" ref="wujia_franchise.module_category_wujia"/>
        <field name="sequence">40</field>
    </record>

    <record id="group_exam_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_exam"/>
        <field name="comment">Xem kỳ thi và phiếu đăng ký.</field>
    </record>

    <record id="group_exam_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_exam"/>
        <field name="implied_ids" eval="[(4, ref('group_exam_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Tạo/duyệt phiếu, cấu hình khóa thi và ca thi, công bố kết quả.</field>
    </record>

</odoo>
