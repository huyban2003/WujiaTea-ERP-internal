<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="layout_sidenav_order"
              inherit_id="wujia_portal_layout.layout_sidenav"
              priority="20"
              name="Wujia Sidenav — Đặt hàng">
        <xpath expr="//ul[@id='main-menu-navigation']" position="inside">
            <li class="nav-item" id="nav_item_order">
                <a href="/portal/order" class="text-black">
                    <i class="feather icon-shopping-cart" aria-hidden="true"/>
                    <span class="menu-title">Đặt hàng</span>
                </a>
            </li>
        </xpath>
    </template>

</odoo>
