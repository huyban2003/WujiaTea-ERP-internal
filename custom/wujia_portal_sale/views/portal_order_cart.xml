<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_order_cart" name="Wujia Portal — Cart">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Giỏ hàng</t>
            <div class="content-wrapper">
                <!-- ===== DESKTOP (≥992px) — GIỮ NGUYÊN ===== -->
                <div class="d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <nav>
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/portal/order">Đặt hàng</a></li>
                                <li class="breadcrumb-item active">Giỏ hàng</li>
                            </ol>
                        </nav>
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-shopping-basket me-1"/>Giỏ hàng
                        </h2>
                    </div>
                </div>

                <div class="content-body">
                    <div t-if="error" class="alert alert-danger" role="alert">
                        <t t-esc="error"/>
                    </div>
                    <div t-if="message" class="alert alert-success" role="status">
                        <t t-esc="message"/>
                    </div>

                    <div t-if="not cart_lines" class="card">
                        <div class="card-body text-center py-5">
                            <i class="fa fa-shopping-basket fa-3x opacity-25 mb-3"/>
                            <p class="text-muted mb-3">Giỏ hàng trống</p>
                            <a href="/portal/order" class="btn btn-primary">
                                <i class="fa fa-arrow-left me-1"/>Tiếp tục mua hàng
                            </a>
                        </div>
                    </div>

                    <form t-if="cart_lines" method="POST" action="/portal/order/submit"
                          class="card">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <div class="card-body p-0">
                            <table class="table mb-0 cart-table">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th class="text-end" style="width:140px">Đơn giá</th>
                                        <th class="text-center" style="width:160px">Số lượng</th>
                                        <th class="text-end" style="width:160px">Thành tiền</th>
                                        <th style="width:50px"/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="cart_lines" t-as="line"
                                        t-att-data-line-id="line.id" class="cart-row">
                                        <td>
                                            <strong t-out="line.product_id.name"/>
                                            <div class="text-muted small">
                                                <t t-out="line.product_id.uom_id.name or '—'"/>
                                            </div>
                                        </td>
                                        <td class="text-end" t-out="'{:,.0f}'.format(line.price_unit or 0).replace(',', '.') + ' ₫'"/>
                                        <td class="text-center">
                                            <input type="number" min="1" t-att-max="9999"
                                                   class="form-control form-control-sm cart-qty-input mx-auto"
                                                   style="width: 100px;"
                                                   t-att-value="int(line.product_uom_qty)"
                                                   t-att-data-line-id="line.id"/>
                                        </td>
                                        <td class="text-end cart-line-subtotal"
                                            t-out="'{:,.0f}'.format(line.price_subtotal or 0).replace(',', '.') + ' ₫'"/>
                                        <td class="text-center">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger btn-cart-remove"
                                                    t-att-data-line-id="line.id">
                                                <i class="fa fa-times"/>
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                        <td class="text-end fw-bold cart-grand-total"
                                            t-out="'{:,.0f}'.format(cart.amount_total or 0).replace(',', '.') + ' ₫'"/>
                                        <td/>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="card-body border-top">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label">Số điện thoại liên hệ</label>
                                    <input type="text" name="portal_delivery_phone"
                                           class="form-control"
                                           t-att-value="cart.portal_delivery_phone or request.env.user.partner_id.phone or ''"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Địa chỉ giao</label>
                                    <input type="text" name="portal_delivery_street"
                                           class="form-control"
                                           t-att-value="cart.portal_delivery_street or ''"/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Ghi chú đơn</label>
                                    <textarea name="portal_note" class="form-control" rows="2"
                                              t-out="cart.portal_note or ''"/>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer text-end">
                            <a href="/portal/order" class="btn btn-outline-secondary me-2">
                                <i class="fa fa-arrow-left me-1"/>Tiếp tục mua
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fa fa-check me-1"/>Xác nhận đặt hàng
                            </button>
                        </div>
                    </form>
                </div>
                </div>
                <!-- /desktop wrapper -->

                <!-- ===== MOBILE (<992px) — BA UI Registry v3 + Figma 2480:2 ===== -->
                <div class="d-lg-none wujia-mcart">
                    <div t-if="error" class="alert alert-danger" role="alert">
                        <t t-esc="error"/>
                    </div>
                    <div t-if="message" class="alert alert-success" role="status">
                        <t t-esc="message"/>
                    </div>

                    <!-- Empty -->
                    <div t-if="not cart_lines" class="wujia-empty-state">
                        <i class="feather icon-shopping-cart"/>
                        <p>Giỏ hàng trống.</p>
                        <a href="/portal/order" class="wujia-mcart-back mt-2">
                            <i class="feather icon-arrow-left"/> Tiếp tục chọn sản phẩm
                        </a>
                    </div>

                    <t t-else="">
                        <h2 class="wujia-mcart-title">Giỏ hàng</h2>
                        <p class="wujia-mcart-subtitle"><t t-out="len(cart_lines)"/> sản phẩm đã chọn</p>

                        <!-- Back secondary button -->
                        <a href="/portal/order" class="wujia-mcart-back">
                            <i class="feather icon-arrow-left"/> Tiếp tục chọn sản phẩm
                        </a>

                        <!-- TODO(BE): order warning bar khung giờ — chờ controller
                             portal_order_cart_view truyền order_window_* (defer theo
                             chỉ đạo: BE submit/context xử lý sau). -->

                        <!-- List header -->
                        <div class="wujia-mcart-listhead">
                            <span>Sản phẩm trong giỏ</span>
                            <span><t t-out="len(cart_lines)"/> sản phẩm</span>
                        </div>

                        <!-- Cart scroll container — render TẤT CẢ (no see-more) -->
                        <div class="wujia-mcart-scroll">
                            <t t-foreach="cart_lines" t-as="line">
                                <div class="wujia-mcart-row" t-att-data-line-id="line.id"
                                     t-att-data-unit-price="int(line.price_unit or 0)">
                                    <span class="wujia-mcart-row-thumb">
                                        <i class="feather icon-package"/>
                                    </span>
                                    <div class="wujia-mcart-row-main">
                                        <span class="wujia-mcart-row-name" t-out="line.product_id.name"/>
                                        <span class="wujia-mcart-row-meta">
                                            <t t-out="line.product_id.uom_id.name or '—'"/> • Đơn giá
                                            <t t-out="'{:,.0f}'.format(line.price_unit or 0).replace(',', '.')"/> đ
                                        </span>
                                        <div class="wujia-mcart-row-controls">
                                            <div class="wujia-mcart-stepper">
                                                <button type="button"
                                                        class="wujia-mcart-step wujia-mcart-step-minus"
                                                        t-att-data-line-id="line.id">−</button>
                                                <span class="wujia-mcart-step-qty"
                                                      t-att-data-line-id="line.id"
                                                      t-out="int(line.product_uom_qty)"/>
                                                <button type="button"
                                                        class="wujia-mcart-step wujia-mcart-step-plus"
                                                        t-att-data-line-id="line.id">+</button>
                                            </div>
                                            <div class="wujia-mcart-row-amount">
                                                <span class="wujia-mcart-row-amount-label">Thành tiền</span>
                                                <span class="wujia-mcart-row-amount-value"
                                                      t-att-data-line-id="line.id"
                                                      t-out="'{:,.0f}'.format(line.price_subtotal or 0).replace(',', '.') + ' đ'"/>
                                            </div>
                                        </div>
                                    </div>
                                    <button type="button" class="wujia-mcart-del"
                                            t-att-data-line-id="line.id">
                                        <i class="feather icon-trash-2"/>
                                    </button>
                                </div>
                            </t>
                        </div>

                        <!-- Sticky summary CTA — submit thẳng (BA, no delivery fields) -->
                        <form method="POST" action="/portal/order/submit" class="wujia-mcart-summary">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="wujia-mcart-summary-rows">
                                <div class="wujia-mcart-summary-line">
                                    <span>Tạm tính</span>
                                    <strong class="wujia-mcart-grand"
                                            t-out="'{:,.0f}'.format(cart.amount_total or 0).replace(',', '.') + ' đ'"/>
                                </div>
                                <div class="wujia-mcart-summary-line muted">
                                    <span>Số lượng</span>
                                    <span><t t-out="len(cart_lines)"/> sản phẩm</span>
                                </div>
                            </div>
                            <button type="submit" class="wujia-mcart-submit">Gửi đơn đặt hàng</button>
                        </form>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
