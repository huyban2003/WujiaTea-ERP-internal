<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_order_product_detail" name="Wujia Portal — Product Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Chi tiết sản phẩm</t>
            <div class="content-wrapper">
                <!-- Realtime cart sync root — header cart badge realtime (Sprint 31). -->
                <div id="wj-cart-sync" class="d-none" t-att-data-franchise-id="active_franchise_id"/>
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'pc'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title" t-value="product.name"/>
                    <t t-set="ph_back_url" t-value="'/portal/order'"/>
                </t>
                <t t-call="wujia_portal_layout.wj_page_header">
                    <t t-set="ph_platform" t-value="'m'"/>
                    <t t-set="ph_variant" t-value="'back'"/>
                    <t t-set="ph_title" t-value="product.name"/>
                    <t t-set="ph_back_url" t-value="'/portal/order'"/>
                </t>
                <div class="content-body">
                    <div class="card">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <img class="img-fluid rounded"
                                         t-attf-src="/web/image/product.product/#{product.id}/image_1024"
                                         t-att-alt="product.name"/>
                                </div>
                                <div class="col-md-7">
                                    <h3 t-out="product.name"/>
                                    <p t-if="product.name_chinese" class="text-muted mb-1"
                                       t-out="product.name_chinese"/>
                                    <p class="text-muted">
                                        <span t-if="product.public_categ_id">
                                            Nhóm: <t t-out="product.public_categ_id.name"/>
                                        </span>
                                        <span t-if="product.description_ecommerce">
                                            • Quy cách: <t t-out="product.description_ecommerce"/>
                                        </span>
                                    </p>
                                    <p class="text-primary fs-4 fw-bold">
                                        <t t-out="'{:,.0f}'.format(price_map.get(product.id) or 0).replace(',', '.')"/> ₫
                                        <small class="text-muted fs-6"> / <t t-out="product.uom_id.name or '—'"/></small>
                                    </p>
                                    <p t-if="product.description_sale" t-out="product.description_sale"/>
                                    <p class="text-muted small">
                                        Tối thiểu: <t t-out="product.min_qty or 1"/>
                                        <span t-if="product.max_qty"> • Tối đa: <t t-out="product.max_qty"/></span>
                                        • Bước đặt: <t t-out="product.min_qty or 1"/>
                                    </p>

                                    <div class="d-flex align-items-center gap-2 mt-3">
                                        <label class="form-label mb-0">Số lượng</label>
                                        <input type="number" id="product-detail-qty"
                                               class="form-control"
                                               style="width: 100px;"
                                               t-att-min="product.min_qty or 1"
                                               t-att-max="product.max_qty or None"
                                               t-att-step="product.min_qty or 1"
                                               t-att-value="product.min_qty or 1"/>
                                        <button type="button"
                                                class="btn btn-primary btn-add-cart-detail"
                                                t-att-data-product-id="product.id"
                                                t-att-data-min-qty="product.min_qty or 1"
                                                t-att-data-max-qty="str(product.max_qty or 0)">
                                            <i class="fa fa-cart-plus me-1"/>Thêm vào giỏ
                                        </button>
                                        <a href="/portal/order/cart" class="btn btn-outline-secondary">
                                            <i class="fa fa-shopping-basket me-1"/>Xem giỏ
                                        </a>
                                    </div>
                                    <div id="product-detail-msg" class="mt-2"></div>
                                </div>
                            </div>

                            <div t-if="related" class="mt-4">
                                <h5>Sản phẩm liên quan</h5>
                                <div class="row g-2">
                                    <t t-foreach="related" t-as="rel">
                                        <div class="col-6 col-md-2">
                                            <a t-attf-href="/portal/order/product/#{rel.id}"
                                               class="text-decoration-none">
                                                <div class="card h-100">
                                                    <img class="card-img-top"
                                                         t-attf-src="/web/image/product.product/#{rel.id}/image_256"/>
                                                    <div class="card-body p-2">
                                                        <small t-out="rel.name"/>
                                                    </div>
                                                </div>
                                            </a>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
