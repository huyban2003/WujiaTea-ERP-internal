<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_order_catalog" name="Wujia Portal — Order Catalog">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Đặt hàng</t>
            <div class="content-wrapper">
                <!-- ===== DESKTOP (≥992px) — GIỮ NGUYÊN ===== -->
                <div class="d-none d-lg-block">
                <div class="content-header row mt-3">
                    <div class="content-header-left col-12 mb-1">
                        <h2 class="content-header-title float-left mb-0">
                            <i class="fa fa-shopping-cart me-1"/>Sản phẩm
                        </h2>
                    </div>
                </div>

                <div t-if="no_franchise" class="alert alert-warning m-3">
                    Bạn chưa được gán vào cửa hàng nào — không thể đặt hàng.
                </div>

                <div t-if="not no_franchise" class="content-body">
                    <!-- ============ Search + filter row ============ -->
                    <div class="card">
                        <div class="card-body p-2">
                            <form method="get" action="/portal/order" class="row g-2 align-items-center">
                                <div class="col-md-4 col-12">
                                    <div class="input-group">
                                        <input type="text" name="keyword" class="form-control"
                                               placeholder="Nhập tên sản phẩm cần tìm"
                                               t-att-value="keyword"/>
                                        <button class="btn btn-primary" type="submit">
                                            <i class="fa fa-search me-1"/>Tìm kiếm
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-3 col-12">
                                    <select name="category_id" class="form-select" onchange="this.form.submit()">
                                        <option value="">— Tất cả nhóm —</option>
                                        <t t-foreach="categories" t-as="cat">
                                            <option t-att-value="cat.id"
                                                    t-att-selected="'selected' if category_id == cat.id else None"
                                                    t-out="cat.complete_name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-5 col-12 text-end">
                                    <small class="text-muted">
                                        Khung giờ đặt hàng: <strong t-out="order_time_from"/> — <strong t-out="order_time_to"/>
                                    </small>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="row mt-2">
                        <!-- ============ Product list (left) — MẪU 02 Card bảng (Sprint 9.13b 2026-05-27) ============ -->
                        <div class="col-12 col-lg-8">
                            <div class="wujia-content-card">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-package"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">Danh sách sản phẩm</h4>
                                    <span t-if="products" class="wujia-content-card-header-link">
                                        <t t-out="len(products)"/> sản phẩm
                                    </span>
                                </div>
                                <div t-if="not products" class="wujia-empty-state">
                                    <i class="feather icon-package"/>
                                    <p>Không có sản phẩm phù hợp.</p>
                                </div>
                                <table t-else="" class="wujia-content-card-table">
                                    <thead>
                                        <tr>
                                            <th>Sản phẩm</th>
                                            <th>ĐVT</th>
                                            <th class="text-end">Đơn giá</th>
                                            <th class="text-end">Số lượng</th>
                                            <th class="text-end"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="products" t-as="product">
                                            <td>
                                                <a t-attf-href="/portal/order/product/#{product.id}" class="text-decoration-none">
                                                    <strong t-out="product.name"/>
                                                </a>
                                            </td>
                                            <td t-out="product.uom_id.name or '—'"/>
                                            <td class="text-end fw-bold" t-out="'{:,.0f}'.format(product.list_price or 0).replace(',', '.') + ' ₫'"/>
                                            <td class="text-end">
                                                <input type="number" class="form-control form-control-sm product-qty-input ms-auto"
                                                       t-att-min="product.min_qty or 1"
                                                       t-att-max="product.max_qty or None"
                                                       t-att-value="product.min_qty or 1"
                                                       style="width: 80px; display: inline-block;"/>
                                            </td>
                                            <td class="text-end">
                                                <button type="button"
                                                        class="btn btn-sm btn-primary btn-add-cart"
                                                        t-att-data-product-id="product.id">
                                                    <i class="fa fa-cart-plus"/>
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pager -->
                            <nav t-if="pager and pager.get('page_count', 0) &gt; 1" aria-label="pagination" class="mt-2">
                                <ul class="pagination wujia-pagination justify-content-center mb-0">
                                    <li class="page-item">
                                        <a class="page-link" t-att-href="pager['page_previous']['url']">«</a>
                                    </li>
                                    <li class="page-item active">
                                        <span class="page-link">
                                            Trang <t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/>
                                        </span>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" t-att-href="pager['page_next']['url']">»</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>

                        <!-- ============ Cart side panel (right) — MẪU 02 Card bảng ============ -->
                        <div class="col-12 col-lg-4">
                            <div class="wujia-content-card cart-panel sticky-top" style="top: 20px;">
                                <div class="wujia-content-card-header">
                                    <div class="wujia-content-card-header-icon">
                                        <i class="feather icon-shopping-cart"/>
                                    </div>
                                    <h4 class="wujia-content-card-header-title">Giỏ hàng</h4>
                                    <span class="wujia-content-card-header-link">
                                        <t t-out="len(cart_lines)"/> dòng
                                    </span>
                                </div>
                                <div t-if="not cart_lines" class="wujia-content-card-empty">
                                    <i class="fa fa-shopping-basket fa-2x mb-2 opacity-25 d-block"/>
                                    Giỏ hàng trống
                                </div>
                                <t t-else="">
                                    <table class="wujia-content-card-table">
                                        <thead>
                                            <tr>
                                                <th>Sản phẩm</th>
                                                <th class="text-end">SL</th>
                                                <th class="text-end">Đơn giá</th>
                                                <th class="text-end"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="cart_lines" t-as="line">
                                                <td>
                                                    <strong t-out="line.product_id.name" class="d-block"/>
                                                </td>
                                                <td class="text-end" t-out="'{:,.0f}'.format(line.product_uom_qty or 0)"/>
                                                <td class="text-end" t-out="'{:,.0f}'.format(line.price_unit or 0).replace(',', '.') + ' ₫'"/>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-outline-danger btn-remove-line"
                                                            t-att-data-line-id="line.id">
                                                        <i class="fa fa-times"/>
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="d-grid mt-2">
                                        <button type="button" class="btn btn-success btn-submit-order">
                                            <i class="fa fa-check me-1"/>Đặt hàng
                                        </button>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
                <!-- /desktop wrapper -->

                <!-- ===== MOBILE (<992px) — BA UI Registry v3 + Figma 2480:2 ===== -->
                <div class="d-lg-none wujia-morder">
                    <div t-if="no_franchise" class="alert alert-warning" role="alert">
                        Bạn chưa được gán vào cửa hàng nào — không thể đặt hàng.
                    </div>
                    <t t-else="">
                        <h2 class="wujia-morder-title">Sản phẩm</h2>

                        <!-- Order warning bar (khung giờ) -->
                        <div t-if="order_window_enabled" class="wujia-morder-warnbar">
                            <i class="feather icon-alert-circle"/>
                            <span>Khung giờ đặt hàng: <t t-out="order_time_from"/> - <t t-out="order_time_to"/></span>
                        </div>

                        <!-- Search + filter -->
                        <form method="get" action="/portal/order" class="wujia-morder-search">
                            <div class="wujia-morder-search-input">
                                <i class="feather icon-search"/>
                                <input type="text" name="keyword" placeholder="Tìm sản phẩm"
                                       t-att-value="keyword"/>
                            </div>
                            <select name="category_id" class="wujia-morder-search-select"
                                    onchange="this.form.submit()">
                                <option value="">Tất cả</option>
                                <t t-foreach="categories" t-as="cat">
                                    <option t-att-value="cat.id"
                                            t-att-selected="'selected' if category_id == cat.id else None"
                                            t-out="cat.complete_name"/>
                                </t>
                            </select>
                        </form>

                        <!-- List header -->
                        <div class="wujia-morder-listhead">
                            <span class="wujia-morder-listhead-title">Danh sách sản phẩm</span>
                            <span t-if="products" class="wujia-morder-listhead-count">
                                <t t-out="len(products)"/> SP
                            </span>
                        </div>

                        <!-- Empty -->
                        <div t-if="not products" class="wujia-empty-state">
                            <i class="feather icon-package"/>
                            <p>Không có sản phẩm phù hợp.</p>
                        </div>

                        <!-- Product compact rows -->
                        <t t-else="">
                            <t t-set="cart_qty_map"
                               t-value="{cl.product_id.product_tmpl_id.id: int(cl.product_uom_qty) for cl in cart_lines}"/>
                            <div class="wujia-morder-list">
                                <t t-foreach="products" t-as="product">
                                    <t t-set="in_cart" t-value="cart_qty_map.get(product.id, 0)"/>
                                    <div class="wujia-morder-row">
                                        <span class="wujia-morder-row-thumb">
                                            <i class="feather icon-package"/>
                                        </span>
                                        <a t-attf-href="/portal/order/product/#{product.id}"
                                           class="wujia-morder-row-info">
                                            <span class="wujia-morder-row-name" t-out="product.name"/>
                                            <span class="wujia-morder-row-spec" t-out="product.uom_id.name or '—'"/>
                                        </a>
                                        <span class="wujia-morder-row-price"
                                              t-out="'{:,.0f}'.format(product.list_price or 0).replace(',', '.') + ' đ'"/>
                                        <button type="button" class="wujia-morder-row-add btn-add-cart"
                                                t-att-data-product-id="product.id"
                                                t-att-data-price="int(product.list_price or 0)">
                                            <i class="feather icon-shopping-cart"/>
                                            <span t-attf-class="wujia-morder-row-qty #{'' if in_cart else 'd-none'}"
                                                  t-out="in_cart"/>
                                        </button>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <!-- Floating cart bar -->
                        <t t-if="cart_lines">
                            <t t-set="cart_total" t-value="sum(cl.price_subtotal for cl in cart_lines)"/>
                            <a href="/portal/order/cart" class="wujia-morder-floatbar"
                               t-att-data-cart-total="int(cart_total)">
                                <span class="wujia-morder-floatbar-icon">
                                    <i class="feather icon-shopping-cart"/>
                                </span>
                                <span class="wujia-morder-floatbar-info">
                                    <span class="wujia-morder-floatbar-title">Giỏ hàng</span>
                                    <span class="wujia-morder-floatbar-sub">
                                        <span class="wujia-morder-floatbar-count" t-out="len(cart_lines)"/> sản phẩm •
                                        <span class="wujia-morder-floatbar-total"
                                              t-out="'{:,.0f}'.format(cart_total).replace(',', '.')"/> đ
                                    </span>
                                </span>
                                <span class="wujia-morder-floatbar-btn">Xem giỏ</span>
                            </a>
                        </t>
                    </t>
                </div>
            </div>
        </t>
    </template>

</odoo>
