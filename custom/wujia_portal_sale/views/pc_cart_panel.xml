<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sprint PC-1 — shared PC cart panel (Figma PC_Product_Cart 4600:2).
         Used by /portal/order (right column) + /portal/order/cart (standalone).
         Context vars: cart, cart_lines, order_window_enabled, order_time_from/to. -->
    <template id="pc_cart_panel" name="Wujia PC — Cart panel (shared)">
        <div class="wj-pc-cart">
            <div class="wj-pc-cart-head">
                <h3 class="wj-pc-cart-title">Giỏ hàng</h3>
                <span class="wj-pc-cart-count wj-count-meta wj-count-meta--bold">
                    <t t-out="len(cart_lines)"/> sản phẩm
                </span>
            </div>

            <!-- Warning bar khung giờ (data sẵn từ controller) -->
            <div t-if="order_window_enabled" class="wj-pc-cart-warnbar">
                <i class="feather icon-alert-circle"/>
                <span>Đặt hàng trong khung giờ — Từ <t t-out="order_time_from"/> đến <t t-out="order_time_to"/></span>
            </div>

            <!-- Empty -->
            <div t-if="not cart_lines" class="wj-pc-cart-empty">
                <span class="wj-pc-cart-empty-icon"><i class="feather icon-shopping-cart"/></span>
                <p class="wj-pc-cart-empty-text">Giỏ hàng trống</p>
                <a href="/portal/order" class="wj-pc-btn wj-pc-btn--secondary">Tiếp tục mua hàng</a>
            </div>

            <t t-else="">
                <!-- Cart rows (AJAX stepper/remove — wj-pc-cart-* hooks) -->
                <div class="wj-pc-cart-table-wrap">
                    <table class="wj-pc-cart-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                                <th/>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="cart_lines" t-as="line" class="wj-pc-cart-row"
                                t-att-data-line-id="line.id"
                                t-att-data-unit-price="int(line.price_unit or 0)"
                                t-att-data-product-tmpl-id="line.product_id.product_tmpl_id.id">
                                <td class="wj-pc-cart-prod">
                                    <span class="wj-pc-cart-prod-name" t-out="line.product_id.name"/>
                                    <span class="wj-pc-cart-prod-uom" t-out="line.product_id.uom_id.name or '—'"/>
                                </td>
                                <td class="text-end wj-pc-cart-unit"
                                    t-out="'{:,.0f}'.format(line.price_unit or 0).replace(',', '.') + ' đ'"/>
                                <td class="text-center">
                                    <div class="wj-pc-stepper">
                                        <button type="button" class="wj-pc-cart-step" data-action="dec"
                                                t-att-data-line-id="line.id" aria-label="Giảm">−</button>
                                        <span class="wj-pc-cart-qty" t-out="int(line.product_uom_qty)"/>
                                        <button type="button" class="wj-pc-cart-step" data-action="inc"
                                                t-att-data-line-id="line.id" aria-label="Tăng">+</button>
                                    </div>
                                </td>
                                <td class="text-end wj-pc-cart-subtotal"
                                    t-out="'{:,.0f}'.format(line.price_subtotal or 0).replace(',', '.') + ' đ'"/>
                                <td class="text-center">
                                    <button type="button" class="wj-pc-cart-del"
                                            t-att-data-line-id="line.id" aria-label="Xoá">
                                        <i class="feather icon-trash-2"/>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Note + totals + submit (only note submitted; address dropped per Figma) -->
                <form method="POST" action="/portal/order/submit" class="wj-pc-cart-foot">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <label class="wj-pc-cart-note-label">Ghi chú đơn hàng</label>
                    <textarea name="portal_note" class="wj-pc-cart-note" rows="2"
                              placeholder="Nhập ghi chú cho Ngô Gia nếu cần"
                              t-out="cart.portal_note or '' if cart else ''"/>
                    <div class="wj-pc-cart-totals">
                        <div class="wj-pc-cart-total-line">
                            <span class="wj-pc-cart-total-label">Số lượng</span>
                            <span class="wj-pc-cart-total-qty"><t t-out="len(cart_lines)"/> sản phẩm</span>
                        </div>
                        <div class="wj-pc-cart-total-line">
                            <span class="wj-pc-cart-total-label wj-pc-cart-total-label--grand">Tổng tiền</span>
                            <span class="wj-pc-cart-grand"
                                  t-out="'{:,.0f}'.format((cart.amount_total if cart else 0) or 0).replace(',', '.') + ' đ'"/>
                        </div>
                    </div>
                    <button type="submit" class="wj-pc-cart-submit">
                        <i class="feather icon-shopping-cart"/> Gửi đơn đặt hàng
                    </button>
                </form>
            </t>
        </div>
    </template>

</odoo>
