<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sprint PC-1 — shared PC cart panel (Figma PC_Product_Cart 4600:2).
         Sprint 30: đọc từ cart_state (dict controller — giỏ chung theo store,
         giá tính lại từ pricelist mỗi render).
         Context vars: cart_state, order_window_enabled, order_time_from/to, window_label. -->
    <template id="pc_cart_panel" name="Wujia PC — Cart panel (shared)">
        <t t-set="cs_lines" t-value="cart_state['lines'] if cart_state else []"/>
        <div class="wj-pc-cart">
            <div class="wj-pc-cart-head">
                <h3 class="wj-pc-cart-title">Giỏ hàng</h3>
                <!-- WJ-ORD-022: header = số MẶT HÀNG (SKU), phân biệt tổng số lượng dưới -->
                <span class="wj-pc-cart-count wj-count-meta wj-count-meta--bold">
                    <t t-out="len(cs_lines)"/> mặt hàng
                </span>
            </div>

            <!-- Warning bar khung giờ — WJ-ORD-006: màu + nội dung theo order_window_open
                 (server tính theo store tz); WJ-ORD-015: label khung qua đêm + UTC+7. -->
            <div t-if="order_window_enabled"
                 t-attf-class="wj-pc-cart-warnbar #{'wj-pc-cart-warnbar--open' if order_window_open else 'wj-pc-cart-warnbar--closed'}">
                <i t-attf-class="feather #{'icon-check-circle' if order_window_open else 'icon-alert-circle'}"/>
                <span t-if="order_window_open">Đang trong khung giờ đặt hàng: <t t-out="order_window_label"/></span>
                <span t-else="">Ngoài khung giờ — mở lại lúc <t t-out="order_window_reopen"/>. Khung: <t t-out="order_window_label"/></span>
            </div>

            <!-- Empty -->
            <div t-if="not cs_lines" class="wj-pc-cart-empty">
                <span class="wj-pc-cart-empty-icon"><i class="feather icon-shopping-cart"/></span>
                <p class="wj-pc-cart-empty-text">Giỏ hàng trống</p>
                <a href="/portal/order" class="wj-pc-btn wj-pc-btn--secondary">Tiếp tục mua hàng</a>
            </div>

            <t t-else="">
                <!-- Cart rows (AJAX stepper/remove — wj-pc-cart-* hooks) -->
                <div class="wj-pc-cart-table-wrap">
                    <table class="wj-pc-cart-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                                <th/>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="cs_lines" t-as="line" class="wj-pc-cart-row"
                                t-att-data-line-id="line['line_id']"
                                t-att-data-unit-price="int(line['unit_price'] or 0)"
                                t-att-data-min-qty="line['min_qty'] or 1"
                                t-att-data-max-qty="str(line['max_qty'] or 0)"
                                t-att-data-product-id="line['product_id']">
                                <td class="wj-pc-cart-prod">
                                    <span class="wj-pc-cart-prod-name" t-out="line['name']"/>
                                    <span class="wj-pc-cart-prod-uom" t-out="line['uom']"/>
                                    <span t-if="line['invalid_reason']"
                                          class="wj-pc-cart-prod-warn text-danger"
                                          t-out="line['invalid_message']"/>
                                </td>
                                <td class="text-end wj-pc-cart-unit"
                                    t-out="'{:,.0f}'.format(line['unit_price'] or 0).replace(',', '.') + ' đ'"/>
                                <td class="text-center">
                                    <div class="wj-pc-stepper">
                                        <button type="button" class="wj-pc-cart-step" data-action="dec"
                                                t-att-data-line-id="line['line_id']" aria-label="Giảm">−</button>
                                        <span class="wj-pc-cart-qty" t-out="line['qty']"/>
                                        <button type="button" class="wj-pc-cart-step" data-action="inc"
                                                t-att-data-line-id="line['line_id']" aria-label="Tăng">+</button>
                                    </div>
                                </td>
                                <td class="text-end wj-pc-cart-subtotal"
                                    t-out="'{:,.0f}'.format(line['subtotal'] or 0).replace(',', '.') + ' đ'"/>
                                <td class="text-center">
                                    <button type="button" class="wj-pc-cart-del"
                                            t-att-data-line-id="line['line_id']" aria-label="Xoá">
                                        <i class="feather icon-trash-2"/>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Note + totals + submit (only note submitted; address dropped per Figma) -->
                <form method="POST" action="/portal/order/submit" class="wj-pc-cart-foot">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <label class="wj-pc-cart-note-label" for="wj-pc-cart-note">Ghi chú đơn hàng</label>
                    <!-- Note chung của giỏ (mọi user cùng store) — autosave qua /cart/note.
                         wj-cart-note = hook chung PC/mobile: autosave + guard swap khi đang gõ. -->
                    <textarea id="wj-pc-cart-note" name="portal_note" class="wj-pc-cart-note wj-cart-note" rows="2"
                              placeholder="Nhập ghi chú cho Ngô Gia nếu cần"
                              t-out="cart_state['note'] if cart_state else ''"/>
                    <div class="wj-pc-cart-totals">
                        <div class="wj-pc-cart-total-line">
                            <!-- WJ-ORD-022: total_qty = TỔNG SỐ LƯỢNG (đơn vị), nhãn tường minh -->
                            <span class="wj-pc-cart-total-label">Tổng số lượng</span>
                            <span class="wj-pc-cart-total-qty"><t t-out="cart_state['total_qty'] if cart_state else 0"/></span>
                        </div>
                        <div class="wj-pc-cart-total-line">
                            <span class="wj-pc-cart-total-label wj-pc-cart-total-label--grand">Tổng tiền</span>
                            <span class="wj-pc-cart-grand"
                                  t-out="'{:,.0f}'.format((cart_state['total_amount'] if cart_state else 0) or 0).replace(',', '.') + ' đ'"/>
                        </div>
                    </div>
                    <!-- WJ-ORD-006: ngoài giờ → disable submit + nêu rõ (server vẫn chặn
                         ORDER_TIME_CLOSED; disable = phản hồi sớm, giỏ vẫn sửa được). -->
                    <button type="submit" class="wj-pc-cart-submit"
                            t-att-disabled="'disabled' if (order_window_enabled and not order_window_open) else None">
                        <i class="feather icon-shopping-cart"/> Gửi đơn đặt hàng
                    </button>
                    <p t-if="order_window_enabled and not order_window_open" class="wj-pc-cart-submit-hint">
                        Ngoài khung giờ — vẫn sửa được giỏ, gửi lại lúc <t t-out="order_window_reopen"/>.
                    </p>
                </form>
            </t>
        </div>
    </template>

</odoo>
