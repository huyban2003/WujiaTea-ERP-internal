<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wujia_fleet_type_list" model="ir.ui.view">
        <field name="name">wujia.fleet.type.list</field>
        <field name="model">wujia.fleet.type</field>
        <field name="arch" type="xml">
            <list string="Loại xe" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="vehicle_category"/>
                <field name="payload_capacity_ton"/>
                <field name="max_payload_kg" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_wujia_fleet_type_form" model="ir.ui.view">
        <field name="name">wujia.fleet.type.form</field>
        <field name="model">wujia.fleet.type</field>
        <field name="arch" type="xml">
            <form string="Loại xe">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Xe tải 3.5T"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="vehicle_category"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="payload_capacity_ton"/>
                            <field name="max_payload_kg"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Mô tả loại xe..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wujia_fleet_type" model="ir.actions.act_window">
        <field name="name">Fleet Types</field>
        <field name="res_model">wujia.fleet.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
