<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wujia_fleet_pricelist_list" model="ir.ui.view">
        <field name="name">wujia.fleet.pricelist.list</field>
        <field name="model">wujia.fleet.pricelist</field>
        <field name="arch" type="xml">
            <list string="Bảng giá vận chuyển" sample="1"
                  decoration-success="state == 'active'"
                  decoration-muted="state in ('expired', 'archived')">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="fleet_type_id"/>
                <field name="provider_id" optional="show"/>
                <field name="trip_scope" optional="show"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'expired'"
                       decoration-muted="state == 'archived'"/>
            </list>
        </field>
    </record>

    <record id="view_wujia_fleet_pricelist_form" model="ir.ui.view">
        <field name="name">wujia.fleet.pricelist.form</field>
        <field name="model">wujia.fleet.pricelist</field>
        <field name="arch" type="xml">
            <form string="Bảng giá vận chuyển">
                <header>
                    <button name="action_activate" type="object"
                            string="Kích hoạt" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_set_draft" type="object"
                            string="Về nháp"
                            invisible="state not in ('expired', 'archived')"/>
                    <button name="action_archive_pricelist" type="object"
                            string="Lưu trữ"
                            invisible="state == 'archived'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expired,archived"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Cước phí xe tải đông lạnh 1T9 đi tỉnh"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="fleet_type_id"/>
                            <field name="provider_id"/>
                            <field name="trip_scope"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="default_drop_fee"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dòng giá theo khu vực" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="area_ids" widget="many2many_tags"
                                           options="{'no_create_edit': True}"/>
                                    <field name="price"/>
                                    <field name="drop_fee"/>
                                    <field name="currency_id" column_invisible="True"/>
                                    <field name="note" optional="hide"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú" name="note">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_wujia_fleet_pricelist_search" model="ir.ui.view">
        <field name="name">wujia.fleet.pricelist.search</field>
        <field name="model">wujia.fleet.pricelist</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="fleet_type_id"/>
                <field name="provider_id"/>
                <separator/>
                <filter string="Đang áp dụng" name="filter_active_state"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Hết hạn" name="filter_expired"
                        domain="[('state', '=', 'expired')]"/>
                <separator/>
                <filter string="Archived" name="filter_inactive"
                        domain="[('active', '=', False)]"/>
                <filter string="Loại xe" name="group_fleet_type"
                        context="{'group_by': 'fleet_type_id'}"/>
                <filter string="Đội xe" name="group_provider"
                        context="{'group_by': 'provider_id'}"/>
                <filter string="Trạng thái" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_wujia_fleet_pricelist" model="ir.actions.act_window">
        <field name="name">Pricelists</field>
        <field name="res_model">wujia.fleet.pricelist</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active_state': 1}</field>
    </record>

</odoo>
