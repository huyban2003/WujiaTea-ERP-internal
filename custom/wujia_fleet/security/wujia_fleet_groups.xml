<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_groups_privilege_fleet" model="res.groups.privilege">
        <field name="name">Wujia Fleet</field>
        <field name="category_id" ref="wujia_franchise.module_category_wujia"/>
        <field name="sequence">20</field>
    </record>

    <record id="group_fleet_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_fleet"/>
        <field name="comment">Xem master data đội xe, xe và bảng giá vận chuyển.</field>
    </record>

    <record id="group_fleet_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_fleet"/>
        <field name="implied_ids" eval="[(4, ref('group_fleet_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Tạo/sửa/xóa đội xe, xe, bảng giá vận chuyển.</field>
    </record>

</odoo>
