<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============== List page ============== -->
    <template id="portal_history_list" name="Wujia Portal — Purchase History List">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title">Lịch sử đặt hàng</t>
            <div class="content-wrapper">

                <!-- ============================================================
                     DESKTOP (≥992px) — GIỮ NGUYÊN 100% (Sprint 13: chỉ bọc, không sửa)
                     ============================================================ -->
                <div class="d-none d-lg-block">
                    <div class="content-header row mt-3">
                        <div class="content-header-left col-12 mb-1">
                            <h2 class="content-header-title float-left mb-0">
                                <i class="fa fa-history me-1"/>Lịch sử đặt hàng
                            </h2>
                        </div>
                    </div>

                    <div t-if="no_franchise" class="alert alert-warning m-3">
                        Bạn chưa được gán vào cửa hàng nào.
                    </div>

                    <div t-if="not no_franchise" class="content-body">
                        <!-- Search/Filter bar -->
                        <div class="card mb-2">
                            <div class="card-body p-2">
                                <form method="get" action="/portal/purchase-history" class="row g-2 align-items-center">
                                    <div class="col-md-3 col-6">
                                        <label class="small text-muted mb-1">Từ ngày</label>
                                        <input type="date" name="date_from" class="form-control form-control-sm" t-att-value="date_from"/>
                                    </div>
                                    <div class="col-md-3 col-6">
                                        <label class="small text-muted mb-1">Đến ngày</label>
                                        <input type="date" name="date_to" class="form-control form-control-sm" t-att-value="date_to"/>
                                    </div>
                                    <div class="col-md-3 col-12">
                                        <label class="small text-muted mb-1">Trạng thái</label>
                                        <select name="state" class="form-select form-select-sm">
                                            <option value="">— Tất cả —</option>
                                            <t t-foreach="state_badges.items()" t-as="kv">
                                                <option t-att-value="kv[0]"
                                                        t-att-selected="'selected' if state == kv[0] else None"
                                                        t-out="kv[1][0]"/>
                                            </t>
                                        </select>
                                    </div>
                                    <div class="col-md-3 col-12 text-end">
                                        <label class="small text-muted mb-1 d-block">&#160;</label>
                                        <button type="submit" class="btn btn-primary btn-sm me-1">
                                            <i class="fa fa-search"/> Tìm kiếm
                                        </button>
                                        <a href="/portal/purchase-history?preset=this_month" class="btn btn-outline-success btn-sm me-1">Tháng này</a>
                                        <a href="/portal/purchase-history?preset=last_month" class="btn btn-outline-secondary btn-sm">Tháng trước</a>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- Table — MẪU 02 Card bảng (Sprint 9.13b 2026-05-27) -->
                        <div class="wujia-content-card">
                            <div class="wujia-content-card-header">
                                <div class="wujia-content-card-header-icon">
                                    <i class="feather icon-shopping-cart"/>
                                </div>
                                <h4 class="wujia-content-card-header-title">Đơn hàng gần đây</h4>
                                <span t-if="orders" class="wujia-content-card-header-link">
                                    <t t-out="len(orders)"/> kết quả
                                </span>
                            </div>
                            <div t-if="not orders" class="wujia-empty-state">
                                <i class="feather icon-inbox"/>
                                <p>Chưa có đơn hàng nào.</p>
                            </div>
                            <table t-else="" class="wujia-content-card-table">
                                <thead>
                                    <tr>
                                        <th>Ngày đặt</th>
                                        <th>Mã đơn</th>
                                        <th>Cửa hàng</th>
                                        <th class="text-end">Tổng tiền</th>
                                        <th class="text-end">KL (kg)</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th class="text-end"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="orders" t-as="o">
                                        <td t-out="o.date_order and o.date_order.strftime('%d/%m/%Y %H:%M') or ''"/>
                                        <td><a t-attf-href="/portal/purchase-history/#{o.id}" t-out="o.name"/></td>
                                        <td t-out="o.franchise_id.name or '—'"/>
                                        <td class="text-end" t-out="'{:,.0f}'.format(o.amount_total or 0).replace(',', '.') + ' ₫'"/>
                                        <td class="text-end" t-out="'{:,.2f}'.format(o.total_planned_weight or 0)"/>
                                        <td class="text-center">
                                            <t t-set="badge" t-value="state_badges.get(o.state, (o.state, 'wujia-badge-muted'))"/>
                                            <span t-attf-class="wujia-badge #{badge[1]}" t-out="badge[0]"/>
                                        </td>
                                        <td class="text-end">
                                            <a t-attf-href="/portal/purchase-history/#{o.id}" class="btn btn-sm btn-primary">
                                                <i class="fa fa-eye"/>
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pager -->
                        <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="mt-2">
                            <ul class="pagination wujia-pagination justify-content-center mb-0">
                                <li class="page-item">
                                    <a class="page-link"
                                       t-attf-href="/portal/purchase-history?page=#{pager['page_previous']['num']}&amp;#{pager['querystring'] or ''}">«</a>
                                </li>
                                <li class="page-item active">
                                    <span class="page-link">
                                        Trang <t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/>
                                    </span>
                                </li>
                                <li class="page-item">
                                    <a class="page-link"
                                       t-attf-href="/portal/purchase-history?page=#{pager['page_next']['num']}&amp;#{pager['querystring'] or ''}">»</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
                <!-- /desktop -->

                <!-- ============================================================
                     MOBILE (<992px) — Figma 4445:4 (Sprint 13). Shell shared (header
                     cyan + store strip + bottom-nav) do app_layout lo. Palette mobile.
                     ============================================================ -->
                <div class="d-lg-none wujia-mhist">
                    <div class="wujia-mhist-titlerow">
                        <h1 class="wujia-mhist-title">Lịch sử đặt hàng</h1>
                        <span t-if="orders" class="wj-count-meta wj-count-meta--bold">
                            <t t-out="len(orders)"/> đơn
                        </span>
                    </div>

                    <div t-if="no_franchise" class="wj-empty-state wj-empty-state--card">
                        <i class="feather icon-alert-circle"/>
                        <p>Bạn chưa được gán vào cửa hàng nào.</p>
                    </div>

                    <t t-else="">
                        <!-- Card tìm kiếm -->
                        <form method="get" action="/portal/purchase-history" class="wujia-mhist-search">
                            <div class="wujia-mhist-search-row">
                                <div class="wujia-mhist-search-box">
                                    <i class="feather icon-search"/>
                                    <input type="text" name="q" t-att-value="q"
                                           placeholder="Mã đơn, ví dụ S003160"
                                           class="wujia-mhist-search-input"/>
                                </div>
                                <button type="submit" class="wujia-mhist-search-btn">Tìm kiếm</button>
                            </div>
                            <div class="wujia-mhist-search-row">
                                <label class="wujia-mhist-search-label">Từ</label>
                                <input type="date" name="date_from" t-att-value="date_from" class="wujia-mhist-date"/>
                                <label class="wujia-mhist-search-label">Đến</label>
                                <input type="date" name="date_to" t-att-value="date_to" class="wujia-mhist-date"/>
                            </div>
                            <div class="wj-filter-chips wj-filter-chips--wrap">
                                <a href="/portal/purchase-history?preset=this_month"
                                   t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if preset == 'this_month' else ''}">Tháng này</a>
                                <a href="/portal/purchase-history?preset=last_month"
                                   t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if preset == 'last_month' else ''}">Tháng trước</a>
                                <a href="/portal/purchase-history?state=sale"
                                   t-attf-class="wj-filter-chip wj-filter-chip--soft #{'is-active' if state == 'sale' else ''}">Đã xử lý</a>
                                <a href="/portal/purchase-history" class="wj-filter-chip wj-filter-chip--clear">Xóa lọc</a>
                            </div>
                        </form>

                        <!-- Header danh sách -->
                        <div class="wujia-mhist-listhead">
                            <span class="wujia-mhist-listhead-title">Danh sách đơn</span>
                            <span class="wj-count-meta"><t t-out="len(orders)"/> đơn gần nhất</span>
                        </div>

                        <!-- Danh sách đơn -->
                        <div t-if="not orders" class="wj-empty-state wj-empty-state--card">
                            <i class="feather icon-inbox"/>
                            <p>Chưa có đơn hàng nào.</p>
                        </div>
                        <div t-else="" class="wujia-mhist-list">
                            <a t-foreach="orders" t-as="o" t-attf-href="/portal/purchase-history/#{o.id}"
                               class="wujia-mhist-row">
                                <span class="wujia-mhist-row-main">
                                    <span class="wujia-mhist-row-code" t-out="o.name"/>
                                    <span class="wujia-mhist-row-date"
                                          t-out="o.date_order and o.date_order.strftime('%H:%M · %d/%m/%Y') or ''"/>
                                </span>
                                <span class="wujia-mhist-row-side">
                                    <t t-set="mb" t-value="mobile_state_badges.get(o.state, (o.state, 'wujia-badge-muted'))"/>
                                    <span t-attf-class="wujia-badge #{mb[1]}" t-out="mb[0]"/>
                                    <span class="wujia-mhist-row-amount"
                                          t-out="'{:,.0f}'.format(o.amount_total or 0).replace(',', '.') + ' đ'"/>
                                </span>
                            </a>
                        </div>

                        <!-- Pager -->
                        <nav t-if="pager and pager.get('page_count', 0) &gt; 1" class="wujia-mhist-pager">
                            <a t-attf-href="/portal/purchase-history?page=#{pager['page_previous']['num']}&amp;#{pager['querystring'] or ''}">«</a>
                            <span>Trang <t t-out="pager['page']['num']"/> / <t t-out="pager['page_count']"/></span>
                            <a t-attf-href="/portal/purchase-history?page=#{pager['page_next']['num']}&amp;#{pager['querystring'] or ''}">»</a>
                        </nav>
                    </t>
                </div>
                <!-- /mobile -->

            </div>
        </t>
    </template>

    <!-- ============== Detail page ============== -->
    <template id="portal_history_detail" name="Wujia Portal — Purchase History Detail">
        <t t-call="wujia_portal_layout.app_layout">
            <t t-set="title" t-value="order.name"/>
            <div class="content-wrapper">

                <!-- ============================================================
                     DESKTOP (≥992px) — GIỮ NGUYÊN 100% (Sprint 13: chỉ bọc, không sửa)
                     ============================================================ -->
                <div class="d-none d-lg-block">
                    <div class="content-header row mt-3">
                        <div class="content-header-left col-12 mb-1">
                            <nav style="--bs-breadcrumb-divider: '>';">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="/portal/purchase-history">Lịch sử đặt hàng</a></li>
                                    <li class="breadcrumb-item active" t-out="order.name"/>
                                </ol>
                            </nav>
                            <h2 class="content-header-title float-left mb-0">
                                <i class="fa fa-file-text-o me-1"/>Đơn hàng <t t-out="order.name"/>
                            </h2>
                        </div>
                    </div>

                    <div class="content-body">
                        <!-- State progress badges (4 levels) -->
                        <div class="card mb-2">
                            <div class="card-body py-3">
                                <div class="row text-center">
                                    <t t-set="states_seq" t-value="['draft', 'sent', 'sale', 'done']"/>
                                    <t t-foreach="states_seq" t-as="s">
                                        <t t-set="badge" t-value="state_badges.get(s, (s, 'wujia-badge-muted'))"/>
                                        <t t-set="passed" t-value="states_seq.index(order.state) &gt;= s_index if order.state in states_seq else False"/>
                                        <div class="col-3">
                                            <div t-attf-class="state-step #{'state-step-active' if passed else 'state-step-pending'}">
                                                <span t-attf-class="wujia-badge state-badge #{badge[1]}" t-out="badge[0]"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <div t-if="order.state == 'cancel'" class="text-center mt-2">
                                    <span class="wujia-badge wujia-badge-danger">Đơn đã bị hủy</span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Order info -->
                            <div class="col-md-6 col-12 mb-2">
                                <div class="card h-100">
                                    <div class="card-header"><h5 class="mb-0">Thông tin đơn</h5></div>
                                    <div class="card-body">
                                        <dl class="row mb-0 profile-dl">
                                            <dt class="col-sm-5">Mã đơn</dt>
                                            <dd class="col-sm-7" t-out="order.name"/>
                                            <dt class="col-sm-5">Ngày đặt</dt>
                                            <dd class="col-sm-7" t-out="order.date_order and order.date_order.strftime('%d/%m/%Y %H:%M') or ''"/>
                                            <dt class="col-sm-5">Cửa hàng</dt>
                                            <dd class="col-sm-7" t-out="order.franchise_id.name or '—'"/>
                                            <dt class="col-sm-5">Người đặt</dt>
                                            <dd class="col-sm-7" t-out="order.portal_requester_user_id.name or order.user_id.name or '—'"/>
                                            <dt class="col-sm-5">Tổng tiền</dt>
                                            <dd class="col-sm-7" t-out="'{:,.0f}'.format(order.amount_total or 0).replace(',', '.') + ' ₫'"/>
                                            <dt class="col-sm-5">Khối lượng</dt>
                                            <dd class="col-sm-7" t-out="'{:,.2f}'.format(order.total_planned_weight or 0) + ' kg'"/>
                                        </dl>
                                    </div>
                                </div>
                            </div>

                            <!-- Delivery info -->
                            <div class="col-md-6 col-12 mb-2">
                                <div class="card h-100">
                                    <div class="card-header"><h5 class="mb-0">Thông tin giao hàng</h5></div>
                                    <div class="card-body">
                                        <dl class="row mb-0 profile-dl">
                                            <dt class="col-sm-4">Địa chỉ</dt>
                                            <dd class="col-sm-8" t-out="order.partner_shipping_id.contact_address or order.franchise_id.address or '—'"/>
                                            <dt class="col-sm-4">SĐT</dt>
                                            <dd class="col-sm-8" t-out="order.partner_shipping_id.phone or order.franchise_id.phone or '—'"/>
                                            <dt class="col-sm-4">Ghi chú</dt>
                                            <dd class="col-sm-8" t-out="order.note or '—'"/>
                                        </dl>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Order lines -->
                        <div class="card">
                            <div class="card-header"><h5 class="mb-0">Chi tiết sản phẩm</h5></div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>STT</th>
                                                <th>Sản phẩm</th>
                                                <th class="text-end">SL</th>
                                                <th>ĐVT</th>
                                                <th class="text-end">Đơn giá</th>
                                                <th class="text-end">Thành tiền</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="order.order_line" t-as="line">
                                                <td t-out="line_index + 1"/>
                                                <td t-out="line.product_id.display_name"/>
                                                <td class="text-end" t-out="'{:,.0f}'.format(line.product_uom_qty or 0)"/>
                                                <td t-out="line.product_id.uom_id.name or ''"/>
                                                <td class="text-end" t-out="'{:,.0f}'.format(line.price_unit or 0).replace(',', '.') + ' ₫'"/>
                                                <td class="text-end" t-out="'{:,.0f}'.format(line.price_subtotal or 0).replace(',', '.') + ' ₫'"/>
                                            </tr>
                                        </tbody>
                                        <tfoot>
                                            <tr class="fw-bold">
                                                <td colspan="5" class="text-end">Tổng cộng</td>
                                                <td class="text-end" t-out="'{:,.0f}'.format(order.amount_total or 0).replace(',', '.') + ' ₫'"/>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="mt-2">
                            <a href="/portal/purchase-history" class="btn btn-secondary">
                                <i class="fa fa-arrow-left me-1"/>Quay lại
                            </a>
                        </div>
                    </div>
                </div>
                <!-- /desktop -->

                <!-- ============================================================
                     MOBILE (<992px) — Figma 4445:4 "Chi tiết đơn" (Sprint 13)
                     ============================================================ -->
                <div class="d-lg-none wujia-mhist-detail">
                    <div class="wujia-mhist-detail-head">
                        <a href="/portal/purchase-history" class="wujia-mhist-back" aria-label="Quay lại">
                            <i class="feather icon-chevron-left"/>
                        </a>
                        <h1 class="wujia-mhist-title">Chi tiết đơn</h1>
                    </div>

                    <!-- Card tóm tắt -->
                    <div class="wujia-mhist-summary">
                        <div class="wujia-mhist-summary-top">
                            <span class="wujia-mhist-summary-code" t-out="order.name"/>
                            <t t-set="mb" t-value="mobile_state_badges.get(order.state, (order.state, 'wujia-badge-muted'))"/>
                            <span t-attf-class="wujia-badge #{mb[1]}" t-out="mb[0]"/>
                        </div>
                        <div class="wujia-mhist-summary-bottom">
                            <span class="wujia-mhist-summary-date"
                                  t-out="order.date_order and order.date_order.strftime('%H:%M · %d/%m/%Y') or ''"/>
                            <span class="wujia-mhist-summary-amount"
                                  t-out="'{:,.0f}'.format(order.amount_total or 0).replace(',', '.') + ' đ'"/>
                        </div>
                    </div>

                    <!-- Thông tin đơn hàng -->
                    <div class="wujia-mhist-card">
                        <div class="wujia-mhist-card-head">Thông tin đơn hàng</div>
                        <div class="wujia-mhist-kv">
                            <span class="wujia-mhist-kv-label">Người đặt</span>
                            <span class="wujia-mhist-kv-value"
                                  t-out="order.portal_requester_user_id.name or order.user_id.name or '—'"/>
                        </div>
                        <div class="wujia-mhist-kv">
                            <span class="wujia-mhist-kv-label">Cửa hàng</span>
                            <span class="wujia-mhist-kv-value"
                                  t-out="(order.franchise_id.code + ' - ' if order.franchise_id.code else '') + (order.franchise_id.name or '—')"/>
                        </div>
                        <div class="wujia-mhist-kv">
                            <span class="wujia-mhist-kv-label">Tổng tiền</span>
                            <span class="wujia-mhist-kv-value"
                                  t-out="'{:,.0f}'.format(order.amount_total or 0).replace(',', '.') + ' đ'"/>
                        </div>
                        <div class="wujia-mhist-kv">
                            <span class="wujia-mhist-kv-label">Số dòng hàng</span>
                            <span class="wujia-mhist-kv-value"><t t-out="'%02d' % len(order.order_line)"/> sản phẩm</span>
                        </div>
                    </div>

                    <!-- Thông tin batch / giao hàng -->
                    <div class="wujia-mhist-card">
                        <div class="wujia-mhist-card-head">Thông tin batch / giao hàng</div>
                        <div class="wujia-mhist-kv">
                            <span class="wujia-mhist-kv-label">Số phiếu batch</span>
                            <span class="wujia-mhist-kv-value" t-out="order.batch_id.name or '—'"/>
                        </div>
                        <div class="wujia-mhist-kv">
                            <span class="wujia-mhist-kv-label">Thời gian khởi hành</span>
                            <span class="wujia-mhist-kv-value"
                                  t-out="order.batch_id.planned_departure and order.batch_id.planned_departure.strftime('%d/%m/%Y · %H:%M') or '—'"/>
                        </div>
                    </div>

                    <!-- Ghi chú khi đặt hàng — LUÔN hiện card (khớp layout Figma); rỗng →
                         placeholder. Dùng portal_note (ghi chú franchise nhập lúc đặt),
                         KHÔNG dùng order.note (= Terms&Conditions Odoo, sai ngữ nghĩa). -->
                    <div class="wujia-mhist-card">
                        <div class="wujia-mhist-card-head">Ghi chú khi đặt hàng</div>
                        <p class="wujia-mhist-note" t-out="order.portal_note or 'Không có ghi chú.'"/>
                    </div>

                    <!-- Danh sách sản phẩm -->
                    <div class="wujia-mhist-card">
                        <div class="wujia-mhist-card-head">Danh sách sản phẩm</div>
                        <div t-foreach="order.order_line" t-as="line" class="wujia-mhist-prod">
                            <span class="wujia-mhist-prod-main">
                                <span class="wujia-mhist-prod-name" t-out="line.product_id.display_name"/>
                                <span class="wujia-mhist-prod-spec">Quy cách: <t t-out="line.product_id.uom_id.name or '—'"/> · SL: x<t t-out="'{:,.0f}'.format(line.product_uom_qty or 0)"/></span>
                            </span>
                            <span class="wujia-mhist-prod-amount"
                                  t-out="'{:,.0f}'.format(line.price_subtotal or 0).replace(',', '.') + ' đ'"/>
                        </div>
                    </div>
                </div>
                <!-- /mobile -->

            </div>
        </t>
    </template>

</odoo>
