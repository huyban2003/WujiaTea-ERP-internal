<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="layout_sidenav_report"
              inherit_id="wujia_portal_layout.layout_sidenav"
              priority="65"
              name="Wujia Sidenav — Báo cáo">
        <xpath expr="//ul[@id='main-menu-navigation']" position="inside">
            <!-- Only show for owner/manager across ANY accessible franchise.
                 Staff-only users are silently excluded (clicking would redirect anyway). -->
            <t t-set="_report_access" t-value="request.env['wujia.franchise.member'].sudo().search_count([
                ('user_id', '=', request.env.user.id),
                ('role', 'in', ['owner', 'manager'])
            ], limit=1)"/>
            <li t-if="_report_access" class="nav-item" id="nav_item_report">
                <a href="/portal/reports/orders" class="text-black">
                    <i class="feather icon-bar-chart-2" aria-hidden="true"/>
                    <span class="menu-title">Báo cáo</span>
                </a>
            </li>
        </xpath>
    </template>

</odoo>
