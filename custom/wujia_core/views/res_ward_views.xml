<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_ward_list" model="ir.ui.view">
        <field name="name">res.ward.list</field>
        <field name="model">res.ward</field>
        <field name="arch" type="xml">
            <list string="Phường/Xã" sample="1">
                <field name="code"/>
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id" optional="hide"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_res_ward_form" model="ir.ui.view">
        <field name="name">res.ward.form</field>
        <field name="model">res.ward</field>
        <field name="arch" type="xml">
            <form string="Phường/Xã">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="state_id"
                                   options="{'no_create': True}"/>
                            <field name="country_id" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_res_ward_search" model="ir.ui.view">
        <field name="name">res.ward.search</field>
        <field name="model">res.ward</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <separator/>
                <filter string="Archived" name="filter_inactive"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Tỉnh/Thành" name="group_state"
                        context="{'group_by': 'state_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_res_ward" model="ir.actions.act_window">
        <field name="name">Phường/Xã</field>
        <field name="res_model">res.ward</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo phường/xã đầu tiên</p>
            <p>Phường/Xã thuộc tỉnh/thành, có thể gán vào khu vực kinh doanh để tổng hợp dữ liệu giao hàng.</p>
        </field>
    </record>

</odoo>
