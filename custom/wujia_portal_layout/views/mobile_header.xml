<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- WJ_Mobile_Header_Primary (BA Wujia_Source_UI_FINAL_v1) — header chuẩn cho
         MỌI trang mobile (Sprint 12, 2026-06-07). Render 1 lần trong app_layout,
         mobile-only (d-lg-none); navbar Vuexy desktop bị ẩn <992px qua _wujia_theme.css.
         Desktop (≥992px) GIỮ NGUYÊN navbar/sidebar Vuexy.

         BA final spec:
           - Header 104px, nền cyan #28A9DF liền khối (KHÔNG dải xanh đậm đáy).
           - Logo slot trắng bo trái (116×44, radius 14).
           - Right actions = Language / Cart shortcut / Avatar (nút tròn translucent ~38px).
           - BỎ notification bell (đã có tab Thông báo ở footer).
           - Cart = shortcut tới giỏ hiện tại (≠ tab Đặt hàng ở footer).

         Reuse: lang dropdown + avatar dropdown markup từ layout_top_navbar; cart badge
         class .wujia-header-cart-count (header_cart_badge.js poll cập nhật — JS đã đổi
         querySelectorAll để cập nhật cả badge desktop ẩn lẫn mobile). -->
    <template id="mobile_header" name="Wujia Mobile — Header Primary (BA FINAL v1)">
        <header class="wujia-mheader d-lg-none">
            <!-- Logo slot (placeholder per BA; dùng company.logo_web tạm — BA sẽ cấp
                 logo tối ưu mobile sau). -->
            <a href="/portal" class="wujia-mheader-logo" aria-label="Trang chủ">
                <img t-attf-src="data:image/png;base64,{{env.company.logo_web}}"
                     alt="Wujia" class="wujia-mheader-logo-img"/>
            </a>

            <div class="wujia-mheader-actions">
                <!-- Language -->
                <div class="dropdown dropdown-language wujia-mheader-action-wrap">
                    <a class="wujia-mheader-action dropdown-toggle" id="m-dropdown-flag" href="#"
                       data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"
                       aria-label="Language">
                        <t t-if="lang == 'vi_VN'">
                            <i class="flag-icon flag-icon-vn"/>
                        </t>
                        <t t-else="">
                            <i class="flag-icon flag-icon-us"/>
                        </t>
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="m-dropdown-flag">
                        <a class="dropdown-item" t-attf-href="/website/lang/en" data-url_code="en">
                            <i class="flag-icon flag-icon-us"/>
                            English
                        </a>
                        <a class="dropdown-item" t-attf-href="/website/lang/vi" data-url_code="vi">
                            <i class="flag-icon flag-icon-vn"/>
                            Việt Nam
                        </a>
                    </div>
                </div>

                <!-- Cart shortcut → giỏ hiện tại. Badge dùng lại .wujia-header-cart-count. -->
                <a class="wujia-mheader-action" href="/portal/order/cart" aria-label="Giỏ hàng">
                    <i class="feather icon-shopping-cart"/>
                    <span class="wujia-header-badge wujia-header-cart-count">0</span>
                </a>

                <!-- Avatar (dropdown profile / change-password / logout, như desktop). -->
                <div class="dropdown dropdown-user wujia-mheader-action-wrap">
                    <a class="wujia-mheader-action wujia-mheader-avatar dropdown-toggle" href="#"
                       data-toggle="dropdown" aria-label="Tài khoản">
                        <img class="round wujia-mheader-avatar-img"
                             t-att-src="'/web/image/res.users/' + str(request.env.user.id) + '/avatar_128'"
                             alt="avatar"/>
                    </a>
                    <!-- Figma Mobile_Account_Info màn 04 "Avatar menu pop-up": header
                         (tên + email) + 4 item VN + Đăng xuất đỏ. Mobile-only (header
                         d-lg-none); desktop dropdown (layout_top_navbar) GIỮ NGUYÊN. -->
                    <div class="dropdown-menu dropdown-menu-right wujia-mheader-menu">
                        <div class="wujia-mheader-menu-head">
                            <span class="wujia-mheader-menu-name" t-out="request.env.user.name"/>
                            <span class="wujia-mheader-menu-email"
                                  t-out="request.env.user.partner_id.email or request.env.user.login"/>
                        </div>
                        <div class="dropdown-divider"/>
                        <a class="dropdown-item" href="/portal/profile">
                            <i class="feather icon-user"/>
                            Thông tin tài khoản
                        </a>
                        <a class="dropdown-item" href="/portal/franchise-information">
                            <!-- toà nhà / cửa hàng — feather subset thiếu glyph 'building' → inline SVG (line-style khớp feather). -->
                            <svg class="wujia-menu-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round" aria-hidden="true">
                                <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
                                <path d="M9 22v-4h6v4"/>
                                <path d="M8 6h.01"/><path d="M12 6h.01"/><path d="M16 6h.01"/>
                                <path d="M8 10h.01"/><path d="M12 10h.01"/><path d="M16 10h.01"/>
                                <path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/>
                            </svg>
                            Thông tin cửa hàng
                        </a>
                        <a class="dropdown-item" href="/portal/change-password">
                            <!-- chìa khoá — feather subset thiếu glyph 'key' → inline SVG (feather key path). -->
                            <svg class="wujia-menu-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round" aria-hidden="true">
                                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                            </svg>
                            Đổi mật khẩu
                        </a>
                        <div class="dropdown-divider"/>
                        <a class="dropdown-item wujia-mheader-menu-logout" href="/portal/logout">
                            <i class="feather icon-log-out"/>
                            Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </header>
    </template>

</odoo>
