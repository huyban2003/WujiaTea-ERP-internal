<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="asset_vendor">
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/vendors/css/vendors.min.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/vendors/css/charts/apexcharts.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/vendors/css/tables/datatable/datatables.min.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/vendors/css/pickers/pickadate/pickadate.css"/>
        </template>
        <template id="asset_theme">
            <!-- Sprint 4.3: load Wujia design tokens + Inter font BEFORE Vuexy
                 vendor so cascade order keeps our CSS var :root rules active.
                 Sprint 9.5: ?v= query string busts browser cache (7-day TTL)
                 when we ship CSS changes — bump on every visual sprint. -->
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/_variables.css?v=1081"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/fonts/inter/inter.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/bootstrap.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/bootstrap-extended.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/colors.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/components.css?v=1010"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/themes/dark-layout.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/themes/semi-dark-layout.css"/>
        </template>
        <template id="asset_frontend">
            <t t-call="wujia_portal_layout.asset_vendor"/>
            <t t-call="wujia_portal_layout.asset_theme"/>
            <t t-call="wujia_portal_layout.asset_page_css"/>
            <t t-call="wujia_portal_layout.asset_style_css"/>
        </template>
        <template id="asset_frontend_js">
            <!-- <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script> -->
            <script src="/wujia_portal_layout/static/assets/js/core/libraries/jquery.min.js"/>
            <script src="/wujia_portal_layout/static/assets/vendors/js/vendors.min.js"/>
            <script src="/wujia_portal_layout/static/assets/vendors/js/pickers/pickadate/picker.js"/>
            <script src="/wujia_portal_layout/static/assets/vendors/js/pickers/pickadate/picker.date.js"/>
            <script src="/wujia_portal_layout/static/assets/vendors/js/pickers/pickadate/picker.time.js"/>
            <script src="/wujia_portal_layout/static/assets/vendors/js/pickers/pickadate/legacy.js"/>
            <script src="/wujia_portal_layout/static/assets/js/scripts/pickers/dateTime/pick-a-datetime.js"/>
            <script src="/wujia_portal_layout/static/assets/vendors/js/charts/apexcharts.min.js"/>
            <!-- <script src="/wujia_portal_layout/static/assets/js/scripts/charts/chart-apex.js"></script> -->
            <!-- <script src="/wujia_portal_layout/static/assets/js/charts/chart-apex.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/charts/chart-apex-detail-fund.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/charts/chart-apex-overview.js"></script> -->
            <script src="/wujia_portal_layout/static/assets/js/scripts/components.js"/>
            <t t-call="wujia_portal_layout.asset_page_js"/>

            <t t-call="wujia_portal_layout.asset_style_js"/>

            <t t-call="wujia_portal_layout.tables_js"/>
            <script src="/wujia_portal_layout/static/assets/js/orgchart/jquery.orgchart.js"></script>
            
        </template>

        <template id="asset_page_css">
            <t t-call="wujia_portal_layout.asset_css_menu" t-if="asset_menu"/>
            <t t-call="wujia_portal_layout.asset_css_authentication" t-if="authentication"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/pages/dashboard-ecommerce.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/pages/card-analytics.css"/>
        </template>

        <template id="asset_page_js">
            <t t-call="wujia_portal_layout.asset_js_menu" t-if="asset_menu"/>
        </template>

        <template id="asset_css_menu">
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/core/menu/menu-types/vertical-menu.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/core/colors/palette-gradient.css"/>
        </template>
        <template id="asset_js_menu">
            <script src="/wujia_portal_layout/static/assets/js/core/app-menu.js"/>
            <script src="/wujia_portal_layout/static/assets/js/core/app.js"/>
            
        </template>

        <template id="asset_style_css">
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/orgchart/jquery.orgchart.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/orgchart/org_chart_customize.css"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/style.css?v=1010"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/dashboard.css?v=1010"/>
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/member_dashboard_style.css?v=1060"/>
            <!-- Sprint 4.3: Wujia overrides last so it wins specificity over
                 both Vuexy vendor and legacy style.css. -->
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/_wujia_theme.css?v=1061"/>
            <!-- Sprint 8 (Issue List UI-11..UI-15): shared component primitives. -->
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/_components.css?v=1033"/>
        </template>

        <template id="tables_js">
            <!-- Sprint 4.2: removed scripts/datatables/datatable.js — it calls
                 $('.zero-configuration').DataTable() on classes that don't exist
                 in portal pages, and Odoo's AMD loader makes datatables.min.js
                 register as AMD module instead of attaching $.fn.DataTable,
                 so .DataTable() is undefined → uncaught TypeError that aborts
                 every $(document).ready callback registered after it (including
                 our _wujiaForceMenuExpanded sidebar fix). -->
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/pdfmake.min.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/vfs_fonts.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/datatables.min.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/datatables.buttons.min.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/buttons.html5.min.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/buttons.print.min.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/buttons.bootstrap.min.js"></script>
            <script src="/wujia_portal_layout/static/assets/js/scripts/tables/datatable/datatables.bootstrap4.min.js"></script>
     
        </template>

         <template id="asset_style_js">

             
             <script src="/wujia_portal_layout/static/assets/js/orgchart/jquery.orgchart.js"/>
             <script src="/wujia_portal_layout/static/assets/js/app.js"/>
             <script src="/wujia_portal_layout/static/assets/js/lang.js"/>
             <script src="/wujia_portal_layout/static/assets/js/my_js.js"/>
             <!-- Sprint 9.6 (2026-05-25): dynamic body-class swap for responsive menu. -->
             <script src="/wujia_portal_layout/static/assets/js/wujia_responsive_menu.js?v=1010"/>


             <script src="/wujia_portal_layout/static/assets/js/scripts/sweetalert2@11.js"/>
             
             <script src="https://cdnjs.com/libraries/orgchart"></script>
            
        </template>


        <template id="asset_css_authentication">
            <link rel="stylesheet" type="text/css" href="/wujia_portal_layout/static/assets/css/pages/authentication.css"/>
        </template>
       
    </data>
</odoo>