<odoo>
    <data>
        <template id="wujia_portal_layout.change_password_page">
            <t t-call="wujia_portal_layout.app_layout">

                <!-- ===== Desktop (>=992px) — Figma wujia_pc_05..08_change_password_v3.
                     4 state qua error/message; viền đỏ field suy từ nội dung error. ===== -->
                <t t-set="acct_page" t-value="'password'"/>
                <t t-set="acct_title">Đổi mật khẩu</t>
                <t t-set="acct_subtitle">Bảo mật tài khoản portal của bạn</t>
                <t t-set="acct_store_code" t-value="franchise_code"/>
                <t t-set="acct_store_name" t-value="franchise_name"/>
                <t t-set="acct_role_label" t-value="role_label"/>
                <t t-set="err_old" t-value="error and 'hiện tại không đúng' in error"/>
                <t t-set="err_confirm" t-value="error and 'xác nhận không khớp' in error"/>
                <t t-set="err_new" t-value="error and ('8 ký tự' in error or 'khác mật khẩu' in error)"/>

                <t t-call="wujia_portal_layout.pc_account_layout">
                    <div t-if="error" class="wj-pc-acct-banner is-error" role="alert" t-out="error"/>
                    <div t-if="message" class="wj-pc-acct-banner is-ok" role="status" t-out="message"/>

                    <div class="wj-pc-acct-pw-grid">
                        <!-- Form card -->
                        <div class="wj-pc-card">
                            <div class="wj-pc-card__head">
                                <div>
                                    <h3 class="wj-pc-acct-panel-title">Thông tin mật khẩu</h3>
                                    <p class="wj-pc-acct-panel-sub">Nhập mật khẩu hiện tại và mật khẩu mới để cập nhật tài khoản.</p>
                                </div>
                            </div>
                            <form method="POST" class="novalidate wj-pc-acct-pw-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="wj-pc-acct-pw-field">
                                    <label for="pc-old-password">Mật khẩu hiện tại</label>
                                    <div t-attf-class="wj-pc-acct-pw-input #{err_old and 'is-error' or ''}">
                                        <input type="password" id="pc-old-password" name="old-password"
                                               class="wj-pc-control" placeholder="••••••••" required="required"/>
                                        <button type="button" class="wj-pc-acct-eye" data-wujia-pwd-toggle="true">Hiện</button>
                                    </div>
                                    <span t-if="err_old" class="wj-pc-acct-field-err">Mật khẩu hiện tại không đúng.</span>
                                </div>

                                <div class="wj-pc-acct-pw-field">
                                    <label for="pc-new-password">Mật khẩu mới</label>
                                    <div t-attf-class="wj-pc-acct-pw-input #{err_new and 'is-error' or ''}">
                                        <input type="password" id="pc-new-password" name="new-password"
                                               class="wj-pc-control" placeholder="Ít nhất 8 ký tự"
                                               minlength="8" required="required"/>
                                        <button type="button" class="wj-pc-acct-eye" data-wujia-pwd-toggle="true">Hiện</button>
                                    </div>
                                    <span t-if="err_new" class="wj-pc-acct-field-err" t-out="error"/>
                                </div>

                                <div class="wj-pc-acct-pw-field">
                                    <label for="pc-con-password">Xác nhận mật khẩu mới</label>
                                    <div t-attf-class="wj-pc-acct-pw-input #{err_confirm and 'is-error' or ''}">
                                        <input type="password" id="pc-con-password" name="con-password"
                                               class="wj-pc-control" placeholder="Nhập lại mật khẩu mới"
                                               minlength="8" required="required"/>
                                        <button type="button" class="wj-pc-acct-eye" data-wujia-pwd-toggle="true">Hiện</button>
                                    </div>
                                    <span t-if="err_confirm" class="wj-pc-acct-field-err">Mật khẩu xác nhận không khớp.</span>
                                </div>

                                <div class="wj-pc-acct-pw-actions">
                                    <a href="/portal/change-password" class="wj-pc-btn wj-pc-btn--secondary">Hủy</a>
                                    <button type="submit"
                                            t-attf-class="wj-pc-btn wj-pc-btn--primary #{message and 'wj-pc-btn--disabled' or ''}">
                                        Lưu mật khẩu
                                    </button>
                                </div>
                            </form>
                        </div>

                        <!-- Aside: security tips + help -->
                        <div style="display:flex;flex-direction:column;gap:24px;">
                            <div class="wj-pc-card">
                                <div class="wj-pc-card__head">
                                    <h3 class="wj-pc-acct-panel-title">Lưu ý bảo mật</h3>
                                </div>
                                <ul class="wj-pc-acct-sec-list">
                                    <li>Mật khẩu mới nên có ít nhất 8 ký tự.</li>
                                    <li>Nên kết hợp chữ, số và ký tự đặc biệt.</li>
                                    <li>Không dùng lại mật khẩu dễ đoán.</li>
                                    <li>Không chia sẻ mật khẩu qua tin nhắn hoặc nhóm chat.</li>
                                </ul>
                            </div>
                            <div class="wj-pc-card">
                                <div class="wj-pc-card__head">
                                    <h3 class="wj-pc-acct-panel-title">Cần hỗ trợ?</h3>
                                </div>
                                <p class="wj-pc-acct-help-text">Nếu bạn không nhớ mật khẩu hiện tại hoặc tài khoản bị khóa, vui lòng liên hệ quản trị Ngô Gia để được hỗ trợ.</p>
                                <div class="wj-pc-acct-help-note">Yêu cầu hỗ trợ sẽ được xử lý theo quyền tài khoản.</div>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- ===== Mobile (<992px) — Figma Mobile_Account_Info màn 03 "Đổi mật khẩu".
                     BlankShell .wujia-mpage NGOÀI .content-wrapper. POST cùng route
                     /portal/change-password (field old-/new-/con-password GIỮ NGUYÊN). ===== -->
                <div class="d-lg-none wujia-mpage wujia-maccount">
                    <t t-call="wujia_portal_layout.wj_page_header">
                        <t t-set="ph_platform" t-value="'m'"/>
                        <t t-set="ph_variant" t-value="'title'"/>
                        <t t-set="ph_title">Đổi mật khẩu</t>
                    </t>

                    <div class="wujia-mdash-card">
                        <h2 class="wujia-maccount-cardtitle">Thông tin mật khẩu</h2>

                        <div t-if="error" class="wujia-maccount-alert is-error" role="alert" t-out="error"/>
                        <div t-if="message" class="wujia-maccount-alert is-ok" role="status" t-out="message"/>

                        <form method="POST" class="wujia-maccount-form novalidate">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="wujia-maccount-field">
                                <label for="m-old-password">Mật khẩu hiện tại</label>
                                <div class="wujia-maccount-pwd">
                                    <input type="password" id="m-old-password" name="old-password"
                                           class="wujia-maccount-input" placeholder="••••••••"
                                           required="required"/>
                                    <button type="button" class="wujia-maccount-eye"
                                            data-wujia-pwd-toggle="true" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="feather icon-eye"/>
                                    </button>
                                </div>
                            </div>

                            <div class="wujia-maccount-field">
                                <label for="m-new-password">Mật khẩu mới</label>
                                <div class="wujia-maccount-pwd">
                                    <input type="password" id="m-new-password" name="new-password"
                                           class="wujia-maccount-input" placeholder="••••••••"
                                           minlength="8" required="required"/>
                                    <button type="button" class="wujia-maccount-eye"
                                            data-wujia-pwd-toggle="true" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="feather icon-eye"/>
                                    </button>
                                </div>
                            </div>

                            <div class="wujia-maccount-field">
                                <label for="m-con-password">Nhập lại mật khẩu mới</label>
                                <div class="wujia-maccount-pwd">
                                    <input type="password" id="m-con-password" name="con-password"
                                           class="wujia-maccount-input" placeholder="••••••••"
                                           minlength="8" required="required"/>
                                    <button type="button" class="wujia-maccount-eye"
                                            data-wujia-pwd-toggle="true" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="feather icon-eye"/>
                                    </button>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 wujia-maccount-submit">
                                Lưu mật khẩu
                            </button>
                        </form>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
