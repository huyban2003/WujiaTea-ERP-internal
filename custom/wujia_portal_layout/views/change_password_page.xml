<odoo>
    <data>
        <template id="wujia_portal_layout.change_password_page">
            <t t-call="wujia_portal_layout.app_layout">

                <!-- ===== Desktop (>=992px) — GIỮ NGUYÊN 100%, bọc d-none d-lg-block (Sprint 18) ===== -->
                <div class="content-wrapper d-none d-lg-block">
                    <div class="content-body">
                        <!-- account setting page start -->
                        <section id="page-account-settings">
                            <div class="row">
                                <!-- right content section -->
                                <div class="col-md-12">
                                    <div class="card">
                                        <div class="card-content">
                                            <div class="card-body">
                                                <div>
                                                    <h1 class="wujia-page-title">Change Password</h1>
                                                </div>
                                                <hr/>
                                                <form class="novalidate" method="POST">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <div class="row">
                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <div class="controls">
                                                                    <label for="account-old-password">Old Password
                                                                    </label>
                                                                    <input type="password" class="form-control" name="old-password"
                                                                           id="account-old-password" required="required"
                                                                           placeholder="Old Password"
                                                                           data-validation-required-message="This old password field is required"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <div class="controls">
                                                                    <label for="account-new-password">New Password
                                                                    </label>
                                                                    <input type="password" name="new-password"
                                                                           id="account-new-password"
                                                                           class="form-control"
                                                                           placeholder="New Password" required="required"
                                                                           data-validation-required-message="The password field is required"
                                                                           minlength="6"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <div class="controls">
                                                                    <label for="account-retype-new-password">Retype New
                                                                        Password
                                                                    </label>
                                                                    <input type="password" name="con-password"
                                                                           class="form-control" required="required"
                                                                           id="account-retype-new-password"
                                                                           data-validation-match-match="password"
                                                                           placeholder="New Password"
                                                                           data-validation-required-message="The Confirm password field is required"
                                                                           minlength="6"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-12 d-flex flex-sm-row flex-column justify-content-start">
                                                            <p class="alert alert-danger" t-if="error" role="alert">
                                                                <t t-esc="error"/>
                                                            </p>

                                                            <p class="alert alert-success" t-if="message"
                                                               role="status">
                                                                <t t-esc="message"/>
                                                            </p>
                                                        </div>
                                                        <div class="col-12 d-flex flex-sm-row flex-column justify-content-start">
                                                            <button type="submit"
                                                                    class="btn btn-primary mr-sm-1 mb-1 mb-sm-0">
                                                                Change Password
                                                            </button>
                                                            <button type="reset" class="btn btn-outline-warning">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- account setting page end -->

                    </div>
                </div>

                <!-- ===== Mobile (<992px) — Figma Mobile_Account_Info màn 03 "Đổi mật khẩu".
                     BlankShell .wujia-mpage NGOÀI .content-wrapper. POST cùng route
                     /portal/change-password (field old-/new-/con-password GIỮ NGUYÊN). ===== -->
                <div class="d-lg-none wujia-mpage wujia-maccount">
                    <h1 class="wujia-maccount-pagetitle">
                        <i class="feather icon-lock"/> Đổi mật khẩu
                    </h1>

                    <div class="wujia-mdash-card">
                        <h2 class="wujia-maccount-cardtitle">Thông tin mật khẩu</h2>

                        <div t-if="error" class="wujia-maccount-alert is-error" role="alert" t-out="error"/>
                        <div t-if="message" class="wujia-maccount-alert is-ok" role="status" t-out="message"/>

                        <form method="POST" class="wujia-maccount-form novalidate">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="wujia-maccount-field">
                                <label for="m-old-password">Mật khẩu hiện tại</label>
                                <div class="wujia-maccount-pwd">
                                    <input type="password" id="m-old-password" name="old-password"
                                           class="wujia-maccount-input" placeholder="••••••••"
                                           required="required"/>
                                    <button type="button" class="wujia-maccount-eye"
                                            data-wujia-pwd-toggle="true" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="feather icon-eye"/>
                                    </button>
                                </div>
                            </div>

                            <div class="wujia-maccount-field">
                                <label for="m-new-password">Mật khẩu mới</label>
                                <div class="wujia-maccount-pwd">
                                    <input type="password" id="m-new-password" name="new-password"
                                           class="wujia-maccount-input" placeholder="••••••••"
                                           minlength="8" required="required"/>
                                    <button type="button" class="wujia-maccount-eye"
                                            data-wujia-pwd-toggle="true" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="feather icon-eye"/>
                                    </button>
                                </div>
                            </div>

                            <div class="wujia-maccount-field">
                                <label for="m-con-password">Nhập lại mật khẩu mới</label>
                                <div class="wujia-maccount-pwd">
                                    <input type="password" id="m-con-password" name="con-password"
                                           class="wujia-maccount-input" placeholder="••••••••"
                                           minlength="8" required="required"/>
                                    <button type="button" class="wujia-maccount-eye"
                                            data-wujia-pwd-toggle="true" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="feather icon-eye"/>
                                    </button>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 wujia-maccount-submit">
                                Lưu mật khẩu
                            </button>
                        </form>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>