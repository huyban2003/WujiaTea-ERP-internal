<odoo>
    <data>
        <template id="wujia_portal_layout.profile_page">
            <t t-call="wujia_portal_layout.app_layout">
                <!-- ===== Desktop (>=992px) — GIỮ NGUYÊN 100%, bọc d-none d-lg-block (Sprint 18) ===== -->
                <div class="content-wrapper d-none d-lg-block">
                    <div class="content-body">
                        <section id="page-account-settings">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="card">
                                        <div class="card-content">
                                            <div class="card-body">
                                                <h4 class="mb-3">Thông tin cá nhân</h4>

                                                <!-- Flash messages -->
                                                <div t-if="error" class="alert alert-danger" role="alert">
                                                    <t t-esc="error"/>
                                                </div>
                                                <div t-if="message" class="alert alert-success" role="status">
                                                    <t t-esc="message"/>
                                                </div>

                                                <form action="/portal/profile/update" method="POST"
                                                      enctype="multipart/form-data" class="novalidate">
                                                    <input type="hidden" name="csrf_token"
                                                           t-att-value="request.csrf_token()"/>

                                                    <div class="row">
                                                        <!-- Avatar block -->
                                                        <div class="col-12 mb-3">
                                                            <img id="img-upload" class="img-upload-user-profile"
                                                                 t-attf-src="/portal/profile/avatar/{{ user.id }}"
                                                                 alt="Avatar"/>
                                                            <div class="mt-2">
                                                                <label for="file_avatar_user_profile" class="custom-file-upload">
                                                                    Chọn hình (≤ 2MB, png/jpg/webp)
                                                                </label>
                                                                <input id="file_avatar_user_profile" type="file"
                                                                       name="avatar"
                                                                       accept="image/png,image/jpeg,image/webp"
                                                                       onchange="readURL(this);"/>
                                                            </div>
                                                        </div>

                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <label for="account-name">Họ tên *</label>
                                                                <input type="text" class="form-control"
                                                                       id="account-name" name="name"
                                                                       placeholder="Họ tên"
                                                                       t-att-value="profile.name"
                                                                       required="required"/>
                                                            </div>
                                                        </div>
                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <label for="account-email">Email liên hệ</label>
                                                                <input type="email" class="form-control"
                                                                       id="account-email" name="email"
                                                                       placeholder="Email"
                                                                       t-att-value="profile.email"/>
                                                                <small class="text-muted">
                                                                    Lưu ý: email này chỉ là email liên hệ. Để đổi email
                                                                    đăng nhập, liên hệ quản trị viên.
                                                                </small>
                                                            </div>
                                                        </div>
                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <label for="account-phone">Số điện thoại</label>
                                                                <input type="text" class="form-control"
                                                                       id="account-phone" name="phone"
                                                                       placeholder="Số điện thoại"
                                                                       t-att-value="profile.phone"/>
                                                            </div>
                                                        </div>
                                                        <div class="col-12">
                                                            <div class="form-group">
                                                                <label for="account-street">Địa chỉ</label>
                                                                <textarea name="street" id="account-street"
                                                                          class="form-control"
                                                                          placeholder="Địa chỉ"><t t-esc="profile.street"/></textarea>
                                                            </div>
                                                        </div>

                                                        <div class="col-12 mt-3 d-flex">
                                                            <button type="submit" class="btn btn-primary mr-2">
                                                                Lưu thay đổi
                                                            </button>
                                                            <a href="/portal" class="btn btn-outline-secondary">
                                                                Huỷ
                                                            </a>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                </div>

                <!-- ===== Mobile (<992px) — Figma Mobile_Account_Info màn 01 (READONLY).
                     BlankShell .wujia-mpage đặt NGOÀI .content-wrapper (pattern S15).
                     User chốt: chỉ-đọc đúng Figma, sửa hồ sơ vẫn ở desktop. ===== -->
                <div class="d-lg-none wujia-mpage wujia-maccount">
                    <div t-if="error" class="wujia-maccount-alert is-error" role="alert" t-out="error"/>
                    <div t-if="message" class="wujia-maccount-alert is-ok" role="status" t-out="message"/>

                    <h1 class="wujia-maccount-pagetitle">
                        <i class="feather icon-info"/> Thông tin tài khoản
                    </h1>

                    <div class="wujia-mdash-card">
                        <h2 class="wujia-maccount-cardtitle">Hồ sơ cá nhân</h2>
                        <div class="wujia-maccount-head">
                            <img class="wujia-maccount-avatar"
                                 t-attf-src="/portal/profile/avatar/{{ user.id }}" alt="Avatar"/>
                            <div class="wujia-maccount-head-main">
                                <span class="wujia-maccount-name" t-out="user.name"/>
                                <span class="wujia-maccount-login" t-out="user.login"/>
                            </div>
                            <span class="wujia-badge wujia-badge-success">Active</span>
                        </div>
                        <div class="wujia-maccount-kvlist">
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Họ tên</span>
                                <span class="wujia-maccount-kv-val" t-out="profile.name or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Login</span>
                                <span class="wujia-maccount-kv-val" t-out="user.login or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Email</span>
                                <span class="wujia-maccount-kv-val" t-out="profile.email or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">SĐT</span>
                                <span class="wujia-maccount-kv-val" t-out="profile.phone or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Cửa hàng</span>
                                <span class="wujia-maccount-kv-val" t-out="franchise_name or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Vai trò</span>
                                <span class="wujia-maccount-kv-val" t-out="role_label or '—'"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
