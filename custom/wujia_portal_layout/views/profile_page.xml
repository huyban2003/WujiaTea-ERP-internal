<odoo>
    <data>
        <template id="wujia_portal_layout.profile_page">
            <t t-call="wujia_portal_layout.app_layout">
                <!-- ===== Desktop (>=992px) — Figma wujia_pc_01_account_info_v3 (read-only).
                     Profile do HQ (Ngô Gia) quản lý → chỉ hiển thị, không form sửa. ===== -->
                <t t-set="acct_page" t-value="'profile'"/>
                <t t-set="acct_title">Thông tin tài khoản</t>
                <t t-set="acct_subtitle">Quản lý thông tin người dùng portal đang đăng nhập</t>
                <t t-set="acct_store_code" t-value="franchise_code"/>
                <t t-set="acct_store_name" t-value="franchise_name"/>
                <t t-set="acct_role_label" t-value="role_label"/>
                <t t-call="wujia_portal_layout.pc_account_layout">
                    <div t-if="error" class="wj-pc-acct-banner is-error" role="alert" t-out="error"/>
                    <div t-if="message" class="wj-pc-acct-banner is-ok" role="status" t-out="message"/>

                    <!-- Header card: avatar + name + email + chips + store box -->
                    <div class="wj-pc-acct-headcard">
                        <img class="wj-pc-acct-headcard__avatar" alt="avatar"
                             t-att-src="'/web/image/res.users/' + str(user.id) + '/avatar_128'"/>
                        <div class="wj-pc-acct-headcard__main">
                            <h2 class="wj-pc-acct-headcard__name" t-out="user.name"/>
                            <p class="wj-pc-acct-headcard__sub" t-out="profile.email or user.login"/>
                            <div class="wj-pc-acct-headcard__chips">
                                <span t-if="role_label" class="wj-pc-badge wj-pc-badge--confirmed" t-out="role_label"/>
                                <span class="wj-pc-badge wj-pc-badge--done">Đang hoạt động</span>
                            </div>
                        </div>
                        <div class="wj-pc-acct-headcard__box">
                            <span class="wj-pc-acct-headcard__box-label">Cửa hàng hiện tại</span>
                            <span class="wj-pc-acct-headcard__box-value">
                                <t t-out="franchise_code or ''"/><t t-if="franchise_code and franchise_name"> · </t><t t-out="franchise_name or '—'"/>
                            </span>
                            <span class="wj-pc-acct-headcard__box-sub">Dữ liệu hiển thị theo cửa hàng đang thao tác</span>
                        </div>
                    </div>

                    <!-- Panel: Thông tin cá nhân -->
                    <div class="wj-pc-card">
                        <div class="wj-pc-card__head">
                            <div>
                                <h3 class="wj-pc-acct-panel-title">Thông tin cá nhân</h3>
                                <p class="wj-pc-acct-panel-sub">Các thông tin cơ bản của tài khoản portal</p>
                            </div>
                        </div>
                        <div class="wj-pc-acct-kv-grid">
                            <div class="wj-pc-acct-field">
                                <span class="wj-pc-acct-field__label">Họ tên</span>
                                <span class="wj-pc-acct-field__value" t-out="profile.name or '—'"/>
                            </div>
                            <div class="wj-pc-acct-field">
                                <span class="wj-pc-acct-field__label">Email</span>
                                <span class="wj-pc-acct-field__value" t-out="profile.email or '—'"/>
                            </div>
                            <div class="wj-pc-acct-field">
                                <span class="wj-pc-acct-field__label">Số điện thoại</span>
                                <span class="wj-pc-acct-field__value" t-out="profile.phone or '—'"/>
                            </div>
                            <div class="wj-pc-acct-field">
                                <span class="wj-pc-acct-field__label">Vai trò portal</span>
                                <span class="wj-pc-acct-field__value wj-pc-acct-field__value--chip">
                                    <span t-if="role_label" class="wj-pc-badge wj-pc-badge--confirmed" t-out="role_label"/>
                                    <t t-else="">—</t>
                                </span>
                            </div>
                            <div class="wj-pc-acct-field">
                                <span class="wj-pc-acct-field__label">Cửa hàng hiện tại</span>
                                <span class="wj-pc-acct-field__value">
                                    <t t-out="franchise_code or ''"/><t t-if="franchise_code and franchise_name"> — </t><t t-out="franchise_name or '—'"/>
                                </span>
                            </div>
                            <div class="wj-pc-acct-field">
                                <span class="wj-pc-acct-field__label">Trạng thái tài khoản</span>
                                <span class="wj-pc-acct-field__value wj-pc-acct-field__value--chip">
                                    <span class="wj-pc-badge wj-pc-badge--done">Đang hoạt động</span>
                                </span>
                            </div>
                        </div>
                        <div class="wj-pc-acct-note">
                            Thông tin tài khoản được quản lý bởi Ngô Gia. Vui lòng liên hệ quản trị nếu cần cập nhật.
                        </div>
                    </div>
                </t>

                <!-- ===== Mobile (<992px) — Figma Mobile_Account_Info màn 01 (READONLY).
                     BlankShell .wujia-mpage đặt NGOÀI .content-wrapper (pattern S15).
                     User chốt: chỉ-đọc đúng Figma, sửa hồ sơ vẫn ở desktop. ===== -->
                <div class="d-lg-none wujia-mpage wujia-maccount">
                    <div t-if="error" class="wujia-maccount-alert is-error" role="alert" t-out="error"/>
                    <div t-if="message" class="wujia-maccount-alert is-ok" role="status" t-out="message"/>

                    <h1 class="wujia-maccount-pagetitle">
                        <i class="feather icon-info"/> Thông tin tài khoản
                    </h1>

                    <div class="wujia-mdash-card">
                        <h2 class="wujia-maccount-cardtitle">Hồ sơ cá nhân</h2>
                        <div class="wujia-maccount-head">
                            <img class="wujia-maccount-avatar"
                                 t-attf-src="/portal/profile/avatar/{{ user.id }}" alt="Avatar"/>
                            <div class="wujia-maccount-head-main">
                                <span class="wujia-maccount-name" t-out="user.name"/>
                                <span class="wujia-maccount-login" t-out="user.login"/>
                            </div>
                            <span class="wujia-badge wujia-badge-success">Active</span>
                        </div>
                        <div class="wujia-maccount-kvlist">
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Họ tên</span>
                                <span class="wujia-maccount-kv-val" t-out="profile.name or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Login</span>
                                <span class="wujia-maccount-kv-val" t-out="user.login or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Email</span>
                                <span class="wujia-maccount-kv-val" t-out="profile.email or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">SĐT</span>
                                <span class="wujia-maccount-kv-val" t-out="profile.phone or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Cửa hàng</span>
                                <span class="wujia-maccount-kv-val" t-out="franchise_name or '—'"/>
                            </div>
                            <div class="wujia-maccount-kv">
                                <span class="wujia-maccount-kv-key">Vai trò</span>
                                <span class="wujia-maccount-kv-val" t-out="role_label or '—'"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
